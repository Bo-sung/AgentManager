<Application x:Class="AgentManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AgentManager"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:agents="clr-namespace:AgentManager.Core.Agents;assembly=AgentManager.Core"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme/Colors.Dark.xaml"/>
                <ResourceDictionary Source="Theme/Theme.xaml"/>
                <ResourceDictionary Source="Theme/Icons.xaml"/>
                <ResourceDictionary Source="Theme/Strings.Ko.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 공유 컨버터: UserControl(뷰)들이 StaticResource로 쓰려면 App 스코프에 있어야 한다
                 (UserControl 로드 시점엔 Window.Resources가 아직 트리에 없어 못 봄). -->
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
            <controls:SelectedBrushConverter x:Key="SelBrush"/>
            <controls:PathToThumbnailConverter x:Key="PathThumb"/>
            <ObjectDataProvider x:Key="SandboxModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="agents:SandboxMode"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </Application.Resources>
</Application>
