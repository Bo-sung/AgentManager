<UserControl x:Class="AgentManager.Controls.Spinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 원본 .spin: 11px 링(accent-dim) + top accent arc, 0.7s linear 회전. -->
    <Grid Width="11" Height="11" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <RotateTransform x:Name="Rot"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Rot" Storyboard.TargetProperty="Angle"
                                         From="0" To="360" Duration="0:0:0.7" RepeatBehavior="Forever"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Ellipse Stroke="{DynamicResource AccentDim}" StrokeThickness="1.5"/>
        <Path Stroke="{DynamicResource Accent}" StrokeThickness="1.5"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Data="M 5.5,0.75 A 4.75,4.75 0 0 1 10.25,5.5"/>
    </Grid>
</UserControl>
