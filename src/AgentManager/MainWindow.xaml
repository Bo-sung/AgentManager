                        <DockPanel>
                            <CheckBox DockPanel.Dock="Left" Content="{StaticResource L.AutoInjectReport}" IsChecked="{Binding DelegateAutoInject}" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelDelegateCommand}"/>
                                <Button Style="{StaticResource AccentButton}" Command="{Binding ConfirmDelegateCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13" Foreground="{DynamicResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.SendDelegation}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <!-- body -->
