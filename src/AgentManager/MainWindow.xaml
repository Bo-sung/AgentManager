                                                            </Border.RenderTransform>
                                                        </Border>
                                                        <Border x:Name="SidebarBar2" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
