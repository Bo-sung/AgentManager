<Window x:Class="AgentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:AgentManager.ViewModels"
        xmlns:controls="clr-namespace:AgentManager.Controls"
        xmlns:agents="clr-namespace:AgentManager.Core.Agents;assembly=AgentManager.Core"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        x:Name="Root"
        Title="AgentManager" Height="760" Width="1380" WindowStyle="None"
        Background="{StaticResource Bg1}" Foreground="{StaticResource Txt0}"
        FontFamily="{StaticResource Sans}" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewAgentCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="R" Command="{Binding ToggleReviewCommand}"/>
    </Window.InputBindings>


    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <ObjectDataProvider x:Key="SandboxModes" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="agents:SandboxMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- ===== Transcript block templates ===== -->
        <DataTemplate DataType="{x:Type vm:UserBlock}">
            <Grid Margin="0,14" HorizontalAlignment="Right" MaxWidth="880">
                <Border Background="{StaticResource Bg3}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                        CornerRadius="10,10,2,10" Padding="13,11">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,5">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.SentEn}"
                                          IsChecked="{Binding ShowSent, Mode=TwoWay}"
                                          Visibility="{Binding HasSent, Converter={StaticResource BoolVis}}"
                                          Margin="9,0,0,0" ToolTip="{StaticResource L.SentEnTip}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="{StaticResource L.You}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding DisplayText, Mode=OneWay}"
                                 Foreground="{StaticResource Txt0}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AgentTextBlock}">
            <Grid Margin="0,16,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="4" Background="{StaticResource Bg2}"
                            BorderBrush="{StaticResource LineBright}" BorderThickness="1">
                        <TextBlock Text="{Binding DataContext.Badge, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="1" Height="46" Background="{StaticResource LineSoft}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,1,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="{Binding DataContext.AgentName, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" Margin="0,0,8,0"/>
                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}"
                                   Text="{Binding ModelLabel, Mode=OneWay}"/>
                        <ToggleButton Style="{StaticResource TogglePillButton}" Content="{StaticResource L.Original}"
                                      IsChecked="{Binding ShowOriginal, Mode=TwoWay}"
                                      Visibility="{Binding HasOriginal, Converter={StaticResource BoolVis}}"
                                      Margin="9,0,0,0" ToolTip="{StaticResource L.OriginalResponseTip}"/>
                        <Button Margin="9,0,0,0" Padding="4,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="{StaticResource Txt3}" ToolTip="{StaticResource L.Copy}"
                                Click="CopyAgentText_Click">
                            <controls:IconView Icon="{StaticResource IconCopy}" Width="13" Height="13"/>
                        </Button>
                    </StackPanel>
                    <controls:MarkdownViewer Text="{Binding DisplayText}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ToolBlock}">
            <Border Margin="40,8,0,8" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}"
                    BorderThickness="1" CornerRadius="7">
                <StackPanel>
                    <ToggleButton IsChecked="{Binding IsOpen}" Cursor="Hand" Background="Transparent" BorderThickness="0">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" Padding="11,8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Kind}" FontFamily="{StaticResource Mono}"
                                                   FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Stat}" FontFamily="{StaticResource Mono}"
                                                   FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.Original}"
                                                      IsChecked="{Binding ShowOriginal, Mode=TwoWay}"
                                                      Visibility="{Binding HasOriginal, Converter={StaticResource BoolVis}}"
                                                      Margin="0,0,9,0" ToolTip="{StaticResource L.OriginalOutputTip}"/>
                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                                                   Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0"
                            Padding="12,10" MaxHeight="220"
                            Visibility="{Binding IsOpen, Converter={StaticResource BoolVis}}">
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding DisplayBody, Mode=OneWay}"
                                 FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt1}"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ErrorBlock}">
            <Border Margin="40,8,0,8" Background="#14FF4D5E" BorderBrush="#66FF4D5E" BorderThickness="1"
                    CornerRadius="7" Padding="13,11">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                               Foreground="{StaticResource Err}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding Body, Mode=OneWay}"
                             FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt1}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WorkingBlock}">
            <StackPanel Orientation="Horizontal" Margin="40,8,0,4">
                <TextBlock Text="●" Foreground="{StaticResource Accent}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Text}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ThinkingBlock}">
            <StackPanel Margin="40,4,0,4">
                <ToggleButton IsChecked="{Binding IsOpen}" Cursor="Hand" Background="Transparent" BorderThickness="0"
                              HorizontalAlignment="Left">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" Padding="2,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource L.Thinking}" FontFamily="{StaticResource Mono}" FontSize="10"
                                               Foreground="{StaticResource Txt3}"/>
                                    <TextBlock x:Name="chev" Text=" ▸" FontSize="9" Foreground="{StaticResource Txt3}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="chev" Property="Text" Value=" ▾"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="2,0,0,0" Padding="12,4,0,2" Margin="2,2,0,0"
                        Visibility="{Binding IsOpen, Converter={StaticResource BoolVis}}">
                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding Text, Mode=OneWay}"
                             FontStyle="Italic" FontSize="12" Foreground="{StaticResource Txt2}"/>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Approval prompt: engine is blocked until Approve/Deny -->
        <DataTemplate DataType="{x:Type vm:ApprovalBlock}">
            <Border Margin="40,10,0,10" BorderBrush="{StaticResource Warn}" BorderThickness="1"
                    CornerRadius="7" Background="#10F5B531">
                <StackPanel>
                    <DockPanel Margin="13,10,13,0">
                        <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.ApprovalRequired}" FontFamily="{StaticResource Mono}"
                                   FontSize="10.5" Foreground="{StaticResource Warn}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding StateLabel}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ToolName}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                                   FontWeight="SemiBold" Foreground="{StaticResource Txt0}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                            CornerRadius="4" Margin="13,9" Padding="11,8" MaxHeight="120">
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding InputSummary, Mode=OneWay}"
                                 FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt1}"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="13,0,13,12"
                                Visibility="{Binding IsPending, Converter={StaticResource BoolVis}}">
                        <Button Content="{StaticResource L.ApproveRun}" Cursor="Hand" Padding="15,7" Margin="0,0,8,0"
                                FontWeight="SemiBold" FontSize="12" Foreground="#FF06160F"
                                Command="{Binding DataContext.ApproveCommand, ElementName=Root}" CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ab" Background="{StaticResource Ok}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ab" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.ApproveForSession}" Margin="0,0,8,0"
                                ToolTip="{StaticResource L.ApproveForSessionTip}"
                                Visibility="{Binding SupportsSessionApproval, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.ApproveForSessionCommand, ElementName=Root}" CommandParameter="{Binding}"/>
                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Reject}"
                                Command="{Binding DataContext.DenyCommand, ElementName=Root}" CommandParameter="{Binding}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== Titlebar ===================== -->
        <Border Grid.Row="0" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
            <Border.Background>
                <StaticResource ResourceKey="Bg2"/>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Rectangle Grid.ColumnSpan="5" Height="2" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFF5A2C" Offset="0"/>
                            <GradientStop Color="#00FF5A2C" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,18,0">
                    <TextBlock Text="◆" Foreground="{StaticResource Accent}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Agent" Foreground="{StaticResource Txt0}"/><Run Text="Manager" Foreground="{StaticResource Accent}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.File}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.NewAgent}" InputGestureText="Ctrl+N" Command="{Binding NewAgentCommand}"/>
                                <MenuItem Header="{StaticResource L.NewProject}" Command="{Binding NewProjectCommand}"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.Exit}" Click="CloseBtn_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Edit}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.CopyConversationMarkdown}" Click="CopyTranscript_Click"/>
                                <MenuItem Header="{StaticResource L.ExportTranscript}" Click="ExportTranscript_Click"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.SearchSessions}" InputGestureText="Ctrl+F" Click="FocusSearch_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.View}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.ToggleReviewPane}" InputGestureText="Ctrl+R" Command="{Binding ToggleReviewCommand}"/>
                                <MenuItem Header="{StaticResource L.MaximizeRestore}" Click="MaxBtn_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Agents}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.NewClaudeSession}" Click="NewAgentEngine_Click" Tag="cc"/>
                                <MenuItem Header="{StaticResource L.NewCodexSession}" Click="NewAgentEngine_Click" Tag="gx"/>
                                <MenuItem Header="{StaticResource L.NewGeminiSession}" Click="NewAgentEngine_Click" Tag="ag"/>
                                <MenuItem Header="{StaticResource L.NewAntigravitySession}" Click="NewAgentEngine_Click" Tag="agy"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Settings}" Command="{Binding ShowSettingsCommand}"/>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Help}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.AboutAgentManager}" Click="HelpAbout_Click"/>
                                <MenuItem Header="{StaticResource L.OpenDocsFolder}" Click="HelpDocs_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10">
                    <Ellipse Width="7" Height="7" Fill="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Run Text="{Binding RunningCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Running}"/></TextBlock>
                    <Ellipse Width="7" Height="7" Fill="{StaticResource Warn}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Run Text="{Binding WaitingCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Waiting}"/></TextBlock>
                    <Ellipse Width="7" Height="7" Fill="{StaticResource Ok}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{StaticResource Txt2}" VerticalAlignment="Center">
                        <Run Text="{Binding DoneCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Done}"/></TextBlock>
                    <TextBlock Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="18,0,10,0">
                        <Run Text="{StaticResource L.SumTkn}"/><Run Text="{Binding TotalTokensLabel, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                    <TextBlock Foreground="{StaticResource Txt2}" VerticalAlignment="Center">
                        <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding TotalCostLabel, Mode=OneWay}" Foreground="{StaticResource Ok}"/></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Style="{StaticResource MenuButton}" Content="—" Width="44" Click="MinBtn_Click" ToolTip="{StaticResource L.MinimizeTip}"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource MenuButton}" Content="▢" Width="44" Click="MaxBtn_Click" ToolTip="{StaticResource L.MaximizeTip}"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource MenuButton}" Content="✕" Width="44" Click="CloseBtn_Click" ToolTip="{StaticResource L.CloseTip}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Body ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding ReviewPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Style="{StaticResource AccentButton}" Margin="12,12,12,8"
                            Command="{Binding NewAgentCommand}">
                        <StackPanel Orientation="Horizontal">
                            <controls:IconView Icon="{StaticResource IconPlus}" Width="14" Height="14"
                                               Foreground="{StaticResource AccentText}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource L.NewAgent}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
 
                    <Border DockPanel.Dock="Top" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}"
                            BorderThickness="1" CornerRadius="7" Margin="12,0,12,8" Padding="6,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:IconView Grid.Column="0" Icon="{StaticResource IconSearch}" Width="13" Height="13"
                                               Foreground="{StaticResource Txt2}" Margin="4,0,6,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="SessionSearchBox" Grid.Column="1" Style="{StaticResource ComposerInput}" Background="Transparent"
                                     BorderThickness="0" Padding="0,7" VerticalAlignment="Center" AcceptsReturn="False"
                                     Text="{Binding SessionFilter, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>
 
                    <StackPanel DockPanel.Dock="Top" Margin="8,0,8,4" TextElement.Foreground="{StaticResource Txt0}">
                        <StackPanel Orientation="Horizontal" Margin="9,7" ToolTip="{StaticResource L.CurrentViewTip}">
                            <controls:IconView Icon="{StaticResource IconGrid}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource L.Orchestrator}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="9,7" TextElement.Foreground="{StaticResource Txt0}"
                                    ToolTip="{StaticResource L.ActivityHistoryTip}" Cursor="Hand"
                                    MouseLeftButtonUp="ActivityHistory_Click">
                            <controls:IconView Icon="{StaticResource IconHistory}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource L.ActivityHistory}" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="9,7" TextElement.Foreground="{StaticResource Txt3}"
                                    ToolTip="{StaticResource L.ScheduledTasksTip}">
                            <controls:IconView Icon="{StaticResource IconCalendar}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource L.ScheduledTasks}" Foreground="{StaticResource Txt3}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- footer -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="10,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource Bg4}" Margin="0,0,8,0">
                                <TextBlock Text="JK" FontFamily="{StaticResource Mono}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{StaticResource L.Local}" FontSize="12" Foreground="{StaticResource Txt0}"/>
                                <TextBlock Text="{Binding QuotaText}" Style="{StaticResource Lbl}" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- session list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <DockPanel Margin="14,14,14,6">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Active}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding ActiveSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}"/>
                                <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding ActiveSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                MouseLeftButtonUp="SessionRow_Click">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Archive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ActiveRenameBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                                                 BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ActiveRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Ellipse DockPanel.Dock="Right" Width="7" Height="7" VerticalAlignment="Top" Margin="6,4,0,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{StaticResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Accent}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="14,18,14,6" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" Text="{StaticResource L.Projects}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Projects.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Border Grid.Column="2" Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="8,0"/>
                                <Button Grid.Column="3" Style="{StaticResource HeaderIconButton}"
                                        ToolTip="{StaticResource L.AddProjectTip}" Command="{Binding NewProjectCommand}">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="12" Height="12"/>
                                </Button>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,7" Cursor="Hand"
                                                MouseLeftButtonUp="ProjectRow_Click" ToolTip="{Binding Path}">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.RemoveProject}" Command="{Binding DataContext.RemoveProjectCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ProjRenameBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                                                 BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Name, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameProjectCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding ElementName=ProjRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconFolder}" Width="13" Height="13"
                                                                   Foreground="{StaticResource Txt2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding SessionCount}" FontFamily="{StaticResource Mono}"
                                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="{StaticResource Txt0}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="14,14,14,6" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" VerticalAlignment="Center">
                                    <Run Text="PROJECT · "/><Run Text="{Binding Project, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding ProjectSessions.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Border Grid.Column="2" Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ProjectSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                MouseLeftButtonUp="SessionRow_Click">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Archive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ProjectRenameBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                                                 BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ProjectRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Ellipse DockPanel.Dock="Right" Width="7" Height="7" VerticalAlignment="Top" Margin="6,4,0,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{StaticResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Accent}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 헤더는 항상 표시: 목록이 비어도 재스캔 버튼으로 새 CLI 세션을 발견할 수 있어야 함 -->
                            <DockPanel Margin="14,18,14,6">
                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="24" Height="20" Padding="0"
                                        Foreground="{StaticResource Txt3}" ToolTip="{StaticResource L.RefreshCliHistoryTip}"
                                        Command="{Binding RefreshCliHistoryCommand}">
                                    <controls:IconView Icon="{StaticResource IconRefresh}" Width="11" Height="11"/>
                                </Button>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.CliHistory}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt2}" Margin="0,0,8,0"
                                           ToolTip="{StaticResource L.CliHistoryTip}"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding CliHistory.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt3}"/>
                                <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="8,0,8,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding CliHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,7" Cursor="Hand" Opacity="0.85"
                                                MouseLeftButtonUp="CliHistoryRow_Click"
                                                ToolTip="{StaticResource L.ImportCliTip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{StaticResource Txt1}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding TimeLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                               Foreground="{StaticResource Txt3}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="14,18,14,6">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Archived}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt2}" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding ArchivedSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt3}"/>
                                <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                Opacity="0.72" MouseLeftButtonUp="SessionRow_Click">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Unarchive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ArchivedRenameBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                                                 BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ArchivedRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt3}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main pane -->
            <Grid Grid.Column="1" DataContext="{Binding ActiveSession}">
                <!-- empty state -->
                <TextBlock Text="{StaticResource L.NoSessionStart}" FontFamily="{StaticResource Mono}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.HasActive, ElementName=Root}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <DockPanel>
                    <DockPanel.Style>
                        <Style TargetType="DockPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.HasActive, ElementName=Root}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DockPanel.Style>

                    <!-- tabbar -->
                    <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding Project}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Left" Text="  ›  " Foreground="{StaticResource Txt3}" VerticalAlignment="Center"/>
                            <!-- 리뷰 토글은 최우측: 패널이 우측에서 열리므로 위치=동작 (사용자 요청) -->
                            <Button DockPanel.Dock="Right" Width="30" Height="30"
                                    ToolTip="{StaticResource L.DiffReviewToggleTip}"
                                    Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Txt1}"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="6">
                                                        <controls:IconView Icon="{StaticResource IconPanel}"
                                                                           Foreground="{TemplateBinding Foreground}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Txt0}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource LineBright}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding DataContext.IsReviewOpen, ElementName=Root}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Border DockPanel.Dock="Right" Background="{StaticResource Bg3}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="20" Padding="8,3" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Txt1}"/>
                            </Border>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                    ToolTip="{StaticResource L.OpenIdeTip}"
                                    Command="{Binding DataContext.OpenIdeCommand, ElementName=Root}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconIde}" Width="13" Height="13"
                                                       Foreground="{StaticResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.OpenIde}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                    ToolTip="{StaticResource L.ExportTip}" Click="ExportTranscript_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconFile}" Width="12" Height="12"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.Export}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                    ToolTip="{StaticResource L.CopyAllTip}" Click="CopyTranscript_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconCopy}" Width="12" Height="12"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.CopyAll}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Border>

                    <!-- status strip -->
                    <Border DockPanel.Dock="Top" Height="38" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="16,0" LastChildFill="False" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusLabel}" Foreground="{StaticResource Txt1}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Border DockPanel.Dock="Left" Background="{StaticResource AccentDim}"
                                    BorderThickness="1" CornerRadius="13" Padding="9,3" VerticalAlignment="Center" Margin="0,0,16,0"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource Warn}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource L.Running}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{StaticResource Txt0}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding LastSignalLabel}" Foreground="{StaticResource Txt2}"/>
                                </StackPanel>
                            </Border>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{StaticResource Txt2}">
                                <Run Text="{StaticResource L.StatusAgent}"/><Run Text="{Binding AgentName, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{StaticResource Txt2}">
                                <Run Text="{StaticResource L.StatusModel}"/><Run Text="{Binding Model, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                            <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                          IsChecked="{Binding TranslationEnabled, Mode=TwoWay}"
                                          Content="{Binding TranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"
                                          Margin="16,0,0,0"/>
                            <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                          IsChecked="{Binding RequireApproval, Mode=TwoWay}"
                                          Content="{StaticResource L.Approval}" ToolTip="{StaticResource L.ApprovalToggleTip}"
                                          Margin="8,0,0,0"/>
                            <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding Source={StaticResource SandboxModes}}"
                                      SelectedItem="{Binding Sandbox, Mode=TwoWay}"
                                      FontFamily="{StaticResource Mono}" FontSize="10" Width="132" Height="24"
                                      Background="{StaticResource Bg1}" Foreground="{StaticResource Txt1}"
                                      BorderBrush="{StaticResource Line}" Margin="8,0,0,0"/>
                            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource Txt2}">
                                <Run Text="{StaticResource L.Tkn}"/><Run Text="{Binding TokensLabel, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource Txt2}" Margin="0,0,16,0">
                                <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding CostLabel, Mode=OneWay}" Foreground="{StaticResource Ok}"/></TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- composer (bottom) -->
                    <Border DockPanel.Dock="Bottom" Margin="14,0,14,14" MinWidth="520" HorizontalAlignment="Stretch">
                        <StackPanel>
                            <Border Margin="4,0,4,8" Background="{StaticResource AccentDim}" BorderThickness="1" CornerRadius="8"
                                    Padding="11,8" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource Warn}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{StaticResource Txt0}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding LastSignalLabel}" Foreground="{StaticResource Txt2}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource L.Running}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding BusyLine}" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Background="{StaticResource Bg3}" BorderThickness="1.5" CornerRadius="10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                <Setter Property="BorderBrush" Value="{StaticResource GxLine}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                <Setter Property="BorderBrush" Value="{StaticResource InfoLine}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                <Setter Property="BorderBrush" Value="{StaticResource AgyLine}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Bottom" Padding="9,0,9,9" Height="50">
                                        <DockPanel VerticalAlignment="Bottom" LastChildFill="True">
                                            <Button DockPanel.Dock="Left" Style="{StaticResource ComposerIconButton}"
                                                    Margin="0,0,8,0"
                                                    ToolTip="{StaticResource L.AttachImageTip}"
                                                    Click="AttachImage_Click">
                                                <controls:IconView Icon="{StaticResource IconAttach}" Width="15" Height="15"/>
                                            </Button>
                                            <Border DockPanel.Dock="Left" Height="30" CornerRadius="15" Padding="12,0" BorderThickness="1"
                                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                                    ToolTip="{StaticResource L.AgentEngineTip}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                <Setter Property="Background" Value="{StaticResource GxDim}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource GxLine}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                <Setter Property="Background" Value="{StaticResource InfoDim}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource InfoLine}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                <Setter Property="Background" Value="{StaticResource AgyDim}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource AgyLine}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" Width="16" Height="16"
                                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" Text="{Binding Badge}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource Txt1}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                        <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                        <Setter Property="Foreground" Value="{StaticResource Info}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                        <Setter Property="Foreground" Value="{StaticResource Agy}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border DockPanel.Dock="Left" Style="{StaticResource ComposerPill}" Margin="0,0,8,0"
                                                    VerticalAlignment="Center" ToolTip="{Binding Branch}">
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:IconView Icon="{StaticResource IconBranch}" Width="13" Height="13"
                                                                       Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Txt1}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{StaticResource L.WorktreePrefix}" Foreground="{StaticResource Txt2}"/><Run Text="{Binding BranchTail, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                                                <ToggleButton x:Name="ModelMenuBtn" Style="{StaticResource TogglePillButton}"
                                                              Height="30" Padding="12,0" Cursor="Hand" ToolTip="{StaticResource L.ModelSelectTip}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconSpark}" Width="13" Height="13"
                                                                           Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                   Text="{Binding Model}" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                            <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                            <Setter Property="Foreground" Value="{StaticResource Info}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                            <Setter Property="Foreground" Value="{StaticResource Agy}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                           Foreground="{StaticResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ToggleButton>
                                                <Popup IsOpen="{Binding IsChecked, ElementName=ModelMenuBtn, Mode=TwoWay}"
                                                       StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                    <Border Background="{StaticResource Bg3}" BorderBrush="{StaticResource LineBright}" BorderThickness="1"
                                                            CornerRadius="7" Padding="5" Margin="8" MinWidth="200">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7">
                                                                <Run Text="{Binding AgentName, Mode=OneWay}"/><Run Text="{StaticResource L.DotModel}"/>
                                                            </TextBlock>
                                                            <ItemsControl ItemsSource="{Binding AvailableModels}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Click="ModelOption_Click" Cursor="Hand"
                                                                                Background="Transparent" BorderThickness="0"
                                                                                HorizontalContentAlignment="Stretch" Padding="0">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="mi" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                        <ContentPresenter/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="mi" Property="Background" Value="{StaticResource Bg4}"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt0}" Text="{Binding}"/>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Grid DockPanel.Dock="Left" Margin="0,0,8,0"
                                                  Visibility="{Binding HasEffort, Converter={StaticResource BoolVis}}">
                                                <ToggleButton x:Name="EffortMenuBtn" Style="{StaticResource TogglePillButton}"
                                                              Height="30" Padding="12,0" Cursor="Hand"
                                                              ToolTip="{StaticResource L.EffortTip}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                                           Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                   Text="{Binding ReasoningEffort}" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                            <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                           Foreground="{StaticResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </ToggleButton>
                                                <Popup IsOpen="{Binding IsChecked, ElementName=EffortMenuBtn, Mode=TwoWay}"
                                                       StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                    <Border Background="{StaticResource Bg3}" BorderBrush="{StaticResource LineBright}" BorderThickness="1"
                                                            CornerRadius="7" Padding="5" Margin="8" MinWidth="160">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7" Text="{StaticResource L.ReasoningEffort}"/>
                                                            <ItemsControl ItemsSource="{Binding EffortOptions}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Click="EffortOption_Click" Cursor="Hand"
                                                                                Background="Transparent" BorderThickness="0"
                                                                                HorizontalContentAlignment="Stretch" Padding="0">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="ei" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                        <ContentPresenter/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="ei" Property="Background" Value="{StaticResource Bg4}"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt0}" Text="{Binding}"/>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                            <Button DockPanel.Dock="Right" Width="32" Height="32" Cursor="Hand" Foreground="White"
                                                    Margin="6,0,0,0" ToolTip="{StaticResource L.StopTip}"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                                                    Command="{Binding DataContext.StopCommand, ElementName=Root}">
                                                <controls:IconView Icon="{StaticResource IconStop}" Filled="True" Width="14" Height="14"/>
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="sb" Background="{StaticResource Err}" CornerRadius="7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="sb" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                                    Foreground="{StaticResource AccentText}" ToolTip="{StaticResource L.SendTip}"
                                                    Command="{Binding DataContext.SendCommand, ElementName=Root}">
                                                <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource ComposerIconButton}"
                                                    Margin="0,0,8,0" Click="Dictate_Click"
                                                    ToolTip="{StaticResource L.DictateTip}">
                                                <controls:IconView Icon="{StaticResource IconMic}" Width="15" Height="15"/>
                                            </Button>
                                            <TextBlock/>
                                        </DockPanel>
                                    </Border>
                                    <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding PendingImages}" Margin="13,0,13,4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource AccentLine}" BorderThickness="1"
                                                        CornerRadius="10" Padding="8,3" Margin="0,2,6,2" ToolTip="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🖼" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                                   Foreground="{StaticResource Txt1}" MaxWidth="180"
                                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        <Button Content="✕" FontSize="9" Margin="6,0,0,0" Padding="2,0"
                                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                Foreground="{StaticResource Txt2}" ToolTip="{StaticResource L.Remove}"
                                                                Click="RemovePendingImage_Click"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid MinHeight="58">
                                        <TextBox x:Name="ComposerBox" Style="{StaticResource ComposerInput}" MinHeight="58" MaxHeight="160"
                                                 Padding="15,12,15,2"
                                                 VerticalContentAlignment="Top"
                                                 Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}"
                                                 KeyDown="Composer_KeyDown"
                                                 PreviewKeyDown="Composer_PreviewKeyDown"/>
                                        <TextBlock Margin="15,12,15,0" Foreground="{StaticResource Txt2}" IsHitTestVisible="False"
                                                   FontSize="13.5" LineHeight="20" VerticalAlignment="Top">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Draft}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{StaticResource L.MessagePrefix}"/><Run Text="{Binding Cli, Mode=OneWay}"/><Run Text="{StaticResource L.MessageSuffix}"/>
                                        </TextBlock>
                                    </Grid>
                                </DockPanel>
                            </Border>
                            <DockPanel Margin="4,6,4,0" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="9.5">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.EnterHint}" Foreground="{StaticResource Txt3}"/>
                                <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Txt3}">
                                    <Run Text="{Binding Cli, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Branch, Mode=OneWay}"/>
                                </TextBlock>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- transcript -->
                    <!-- 가상화 필수: 긴 트랜스크립트(CLI 가져오기 수백 블록)에서 보이는 항목만 생성한다.
                         가상화가 동작하려면 ScrollViewer가 ItemsControl 템플릿 안에 있어야 함 -->
                    <ItemsControl x:Name="TranscriptList" ItemsSource="{Binding Transcript}"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  PreviewMouseWheel="TranscriptScroll_PreviewMouseWheel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer x:Name="PART_TranscriptScroll" VerticalScrollBarVisibility="Auto" Focusable="False">
                                    <!-- 전폭 사용: 중앙 880px 캡 대신 좌우 최소 여백 (사용자 요청) -->
                                    <ItemsPresenter Margin="14,16,14,12"/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                    </ItemsControl>
                </DockPanel>
            </Grid>

            <!-- Review pane -->
            <Border Grid.Column="2" DataContext="{Binding ActiveSession}" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineSoft}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.DiffReview}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt0}"
                                       VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <TextBlock Text="{Binding ReviewStatus}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                       Foreground="{StaticResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.CloseTip}"
                                    Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.RefreshChangesTip}"
                                    Command="{Binding DataContext.RefreshReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconRefresh}" Width="13" Height="13"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Changes}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Changes.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ListBox x:Name="ReviewChangesList" ItemsSource="{Binding Changes}" SelectedItem="{Binding SelectedChange, Mode=TwoWay}"
                                     SelectionChanged="ReviewChanges_SelectionChanged"
                                     Background="Transparent" BorderThickness="0" MaxHeight="190"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="row" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg4}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="8,7">
                                            <Border DockPanel.Dock="Left" Width="24" Height="22" CornerRadius="4"
                                                    Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding KindLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatLabel}" FontFamily="{StaticResource Mono}"
                                                       FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Path}" FontFamily="{StaticResource Mono}" FontSize="11"
                                                       Foreground="{StaticResource Txt0}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <DockPanel Margin="0,14,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Artifacts}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Artifacts.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding Artifacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Background="{StaticResource Bg1}" BorderThickness="1" CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Err}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <DockPanel Margin="9,7,9,5">
                                                    <Border DockPanel.Dock="Left" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Kind}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Accent}"/>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt3}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Txt0}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="9,7" MaxHeight="120">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Content}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                                   Foreground="{StaticResource Txt1}" TextWrapping="Wrap"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{StaticResource L.NoArtifacts}" FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Txt3}" Margin="2,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Artifacts.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                        Foreground="{StaticResource AccentText}" Margin="8,0,0,0"
                                        Command="{Binding DataContext.SendDiffFeedbackCommand, ElementName=Root}"
                                        CommandParameter="{Binding Text, ElementName=DiffFeedbackBox}"
                                        Click="DiffFeedbackSend_Click">
                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                </Button>
                                <TextBox x:Name="DiffFeedbackBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="9"
                                         AcceptsReturn="False" MinHeight="32"
                                         TextWrapping="NoWrap" ToolTip="{StaticResource L.FeedbackPlaceholder}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource AccentButton}" Content="{StaticResource L.MergeMain}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.MergeMainTip}"
                                        Command="{Binding DataContext.MergeReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Content="{StaticResource L.CommitOnly}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.CommitReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Discard}"
                                        ToolTip="{StaticResource L.DiscardTip}"
                                        Command="{Binding DataContext.DiscardReviewCommand, ElementName=Root}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Worktree}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding WorktreeLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="32" Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="12,0">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Diff}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedChange.Path}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="270"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <controls:DiffViewer Text="{Binding DiffText}"/>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== New-agent overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewAgent, Converter={StaticResource BoolVis}}">
            <Border Width="540" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewWorker}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewAgentCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SpawnAgent}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Engines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,9,0" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                            CornerRadius="7" Padding="11,13" Cursor="Hand" MouseLeftButtonUp="EngineOpt_Click">
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="4" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <controls:IconView Style="{StaticResource EngineIconByDef}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                            <TextBlock Text="{Binding Desc}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding NewAgentTitle, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,8,0,0" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}">
                            <Run Text="{StaticResource L.Selected}"/><Run Text="{Binding NewAgentSelectedEngine.Name, Mode=OneWay}" Foreground="{StaticResource Accent}"/></TextBlock>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewAgentCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateSessionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.LaunchAgent}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== New-project overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewProject, Converter={StaticResource BoolVis}}">
            <Border Width="560" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewProject}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewProjectCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.RegisterWorkspaceFolder}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Name}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.FolderPath}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="8,0,0,0"
                                    ToolTip="{StaticResource L.BrowseProjectTip}" Click="BrowseProjectFolder_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconFolder}" Width="13" Height="13"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.Browse}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                     BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                     Text="{Binding NewProjectPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                        <TextBlock Text="{StaticResource L.MissingFolderNote}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{StaticResource Txt3}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding NewProjectError}" FontFamily="{StaticResource Mono}" FontSize="10"
                                   Foreground="{StaticResource Err}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewProjectCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateProjectCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.AddProject}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Settings overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowSettings, Converter={StaticResource BoolVis}}">
            <Border Width="620" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelSettingsCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SettingsTitle}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{StaticResource L.SettingsSubtitle}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelSettingsCommand}"/>
                                <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.SaveSettings}" Command="{Binding SaveSettingsCommand}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SettingsStatus}" FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Ok}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="540">
                    <StackPanel Margin="18">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.EnginesHeader}" Style="{StaticResource Lbl}"/>
                            <TextBlock DockPanel.Dock="Right" Text="{StaticResource L.AutoDetectHint}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt3}"/>
                        </DockPanel>

                        <TextBlock Text="{StaticResource L.ClaudeCliPath}" Style="{StaticResource Lbl}" Margin="0,2,0,7"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding SettingsClaudePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding ClaudeDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                   Foreground="{StaticResource Txt2}" Margin="2,4,0,0" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ClaudeDetectLabel}"/>

                        <TextBlock Text="{StaticResource L.CodexCliPath}" Style="{StaticResource Lbl}" Margin="0,14,0,7"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding SettingsCodexPath, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding CodexDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                   Foreground="{StaticResource Txt2}" Margin="2,4,0,0" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CodexDetectLabel}"/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.GeminiCliAuto}" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding GeminiDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding GeminiDetectLabel}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.AntigravityAgyAuto}" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding AgyDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding AgyDetectLabel}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource LineSoft}" Margin="0,18,0,16"/>

                        <TextBlock Text="{StaticResource L.OllamaTranslation}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.Endpoint}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                         Text="{Binding SettingsOllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.StatusModel}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                         Text="{Binding SettingsOllamaModel, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,10,0,0" HorizontalAlignment="Left"
                                      IsChecked="{Binding SettingsDefaultTranslationEnabled, Mode=TwoWay}"
                                      Content="{StaticResource L.DefaultTranslation}"
                                      ToolTip="{StaticResource L.DefaultTranslationTip}"/>

                        <Border Height="1" Background="{StaticResource LineSoft}" Margin="0,18,0,16"/>

                        <TextBlock Text="{StaticResource L.Behavior}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                        <TextBlock Text="{StaticResource L.ConcurrentLimit}" Style="{StaticResource Lbl}" Margin="0,2,0,7"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding MaxConcurrentSessions, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <ToggleButton Style="{StaticResource TogglePillButton}"
                                          IsChecked="{Binding SettingsWarnNoWorktree, Mode=TwoWay}"
                                          Content="{StaticResource L.NonGitNotice}"
                                          ToolTip="{StaticResource L.NonGitNoticeTip}"/>
                            <ToggleButton Style="{StaticResource TogglePillButton}" Margin="8,0,0,0"
                                          IsChecked="{Binding SettingsLightTheme, Mode=TwoWay}"
                                          Content="{StaticResource L.LightTheme}"
                                          ToolTip="{StaticResource L.LightThemeTip}"/>
                            <ToggleButton Style="{StaticResource TogglePillButton}" Margin="8,0,0,0"
                                          IsChecked="{Binding SettingsEnglishUi, Mode=TwoWay}"
                                          Content="{StaticResource L.EnglishUi}"
                                          ToolTip="{StaticResource L.EnglishUiTip}"/>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource LineSoft}" Margin="0,18,0,16"/>

                        <TextBlock Text="{StaticResource L.Project}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                        <TextBlock Text="{StaticResource L.McpConfigPath}" Style="{StaticResource Lbl}" Margin="0,0,0,7"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding ActiveProject.McpConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <DockPanel Margin="0,14,0,0">
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}"
                                    ToolTip="{StaticResource L.AddExtraPathTip}"
                                    Click="AddExtraPath_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11"
                                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.AddFolder}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{StaticResource L.ExtraFolders}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding ActiveProject.ExtraPaths}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="26"
                                                ToolTip="{StaticResource L.Remove}"
                                                Command="{Binding DataContext.RemoveExtraPathCommand, ElementName=Root}"
                                                CommandParameter="{Binding}">
                                            <controls:IconView Icon="{StaticResource IconX}" Width="10" Height="10"/>
                                        </Button>
                                        <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                CornerRadius="6" Padding="9,6" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                       Foreground="{StaticResource Txt1}" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

