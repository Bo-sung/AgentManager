                        </DockPanel>
                    </Border>
                    <controls:MarkdownViewer Text="{Binding InstallGuideMarkdown}" Margin="18,8,18,16"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== New-agent overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewAgent, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewAgent}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="540" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.LayoutTransform><ScaleTransform ScaleX="{Binding ModalScale}" ScaleY="{Binding ModalScale}"/></Border.LayoutTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewAgent}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewWorker}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewAgentCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SpawnAgent}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding NewAgentEngineOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,9,0" Background="{DynamicResource Bg1}" BorderThickness="1"
                                            CornerRadius="7" Padding="11,13" controls:MouseClick.Command="{Binding DataContext.SelectEngineCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Dimmed}" Value="True"><Setter Property="Cursor" Value="Arrow"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.BorderBrush>
                                            <MultiBinding Converter="{StaticResource SelBrush}">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.NewAgentSelectedEngine.Id" ElementName="Root"/>
                                            </MultiBinding>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <StackPanel>
                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Dimmed}" Value="True"><Setter Property="Opacity" Value="0.4"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Border Width="30" Height="30" CornerRadius="4" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                        <controls:IconView Style="{StaticResource EngineIconByDef}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                    <TextBlock Text="{Binding Desc}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{StaticResource L.InstallGuide}" FontSize="9.5" Foreground="{DynamicResource Accent}" Cursor="Hand" TextDecorations="Underline" Margin="0,7,0,0"
                                                           ToolTip="{Binding InstallUrl}"
                                                           controls:MouseClick.Command="{Binding DataContext.OpenUrlCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding InstallUrl}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowInstallBadge}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <Border CornerRadius="3" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="5,1">
                                                    <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding ShowInstallBadge}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                    <TextBlock Text="{StaticResource L.NotInstalled}" FontFamily="{StaticResource Mono}" FontSize="8.5" Foreground="{DynamicResource Txt2}"/>
                                                </Border>
                                                <Border CornerRadius="3" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Err}" BorderThickness="1" Padding="5,1">
                                                    <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding ShowLimitBadge}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                    <TextBlock Text="{StaticResource L.LimitReached}" FontFamily="{StaticResource Mono}" FontSize="8.5" Foreground="{DynamicResource Err}"/>
                                                </Border>
                                                <Border CornerRadius="3" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" Padding="5,1">
                                                    <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding ShowApiBadge}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                    <TextBlock Text="{StaticResource L.ApiBadge}" FontFamily="{StaticResource Mono}" FontSize="8.5" Foreground="{DynamicResource Accent}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewAgentTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.ModelPick}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding NewAgentModels}" SelectedItem="{Binding NewAgentModel, Mode=TwoWay}"/>
