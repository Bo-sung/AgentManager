                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt3}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main pane -->
            <Grid Grid.Column="1" DataContext="{Binding ActiveSession}">
                <!-- In-app activity history shell -->

                <!-- Session View Wrapper -> views/SessionView -->
                <views:SessionView Visibility="{Binding DataContext.IsSessionView, ElementName=Root, Converter={StaticResource BoolVis}}"/>

                <!-- Orchestrator View -->
                <views:OrchestratorView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsOrchestratorView, Converter={StaticResource BoolVis}}"/>

                <!-- Activity History View -->
                <views:HistoryView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsHistoryView, Converter={StaticResource BoolVis}}"/>

                <!-- Scheduled Tasks View -->
                <views:ScheduledView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsScheduledView, Converter={StaticResource BoolVis}}"/>

                <!-- ===================== Settings (full center pane) -> views/SettingsView ===================== -->
                <views:SettingsView DataContext="{Binding DataContext, ElementName=Root}"
                                    Visibility="{Binding IsSettingsView, Converter={StaticResource BoolVis}}"/>
            </Grid>

            <!-- Review pane -->
            <Border Grid.Column="2" DataContext="{Binding ActiveSession}" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineSoft}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.DiffReview}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt0}"
                                       VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <TextBlock Text="{Binding ReviewStatus}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                       Foreground="{StaticResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.CloseTip}"
                                    Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.RefreshChangesTip}"
                                    Command="{Binding DataContext.RefreshReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconRefresh}" Width="13" Height="13"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Changes}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Changes.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ListBox x:Name="ReviewChangesList" ItemsSource="{Binding Changes}" SelectedItem="{Binding SelectedChange, Mode=TwoWay}"
                                     SelectionChanged="ReviewChanges_SelectionChanged"
                                     Background="Transparent" BorderThickness="0" MaxHeight="190"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="row" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg4}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="8,7">
                                            <Border DockPanel.Dock="Left" Width="24" Height="22" CornerRadius="4"
                                                    Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding KindLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatLabel}" FontFamily="{StaticResource Mono}"
                                                       FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Path}" FontFamily="{StaticResource Mono}" FontSize="11"
                                                       Foreground="{StaticResource Txt0}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <DockPanel Margin="0,14,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Artifacts}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Artifacts.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding Artifacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Background="{StaticResource Bg1}" BorderThickness="1" CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Err}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <DockPanel Margin="9,7,9,5">
                                                    <Border DockPanel.Dock="Left" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Kind}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Accent}"/>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt3}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Txt0}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="9,7" MaxHeight="120">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Content}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                                   Foreground="{StaticResource Txt1}" TextWrapping="Wrap"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{StaticResource L.NoArtifacts}" FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Txt3}" Margin="2,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Artifacts.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                        Foreground="{StaticResource AccentText}" Margin="8,0,0,0"
                                        Command="{Binding DataContext.SendDiffFeedbackCommand, ElementName=Root}"
                                        CommandParameter="{Binding Text, ElementName=DiffFeedbackBox}"
                                        Click="DiffFeedbackSend_Click">
                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                </Button>
                                <TextBox x:Name="DiffFeedbackBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="9"
                                         AcceptsReturn="False" MinHeight="32"
                                         TextWrapping="NoWrap" ToolTip="{StaticResource L.FeedbackPlaceholder}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource AccentButton}" Content="{StaticResource L.MergeMain}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.MergeMainTip}"
                                        Command="{Binding DataContext.MergeReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Content="{StaticResource L.CommitOnly}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.CommitReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Discard}"
                                        ToolTip="{StaticResource L.DiscardTip}"
                                        Command="{Binding DataContext.DiscardReviewCommand, ElementName=Root}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Worktree}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding WorktreeLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="32" Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="12,0">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Diff}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedChange.Path}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="270"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <controls:DiffViewer Text="{Binding DiffText}"/>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== New-schedule overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewSchedule, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewSchedule}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="620" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewSchedule}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewSchedule}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewScheduleCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SchedCreateTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding NewScheduleTitle, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.SchedPrompt}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" MinHeight="78"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding NewSchedulePrompt, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <ListBox ItemsSource="{Binding Engines}" SelectedItem="{Binding NewScheduleSelectedEngine, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="rt" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                        CornerRadius="7" Padding="10" Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{StaticResource LineBright}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                        <Setter TargetName="rt" Property="Background" Value="{StaticResource AccentDim}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Badge}" FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Cli}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.SchedCadence}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewScheduleCadence, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{StaticResource L.SchedCadenceHint}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt3}" Margin="2,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.SchedTargetBranch}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewScheduleTargetBranch, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding NewScheduleError}" FontFamily="{StaticResource Mono}" FontSize="10"
                                   Foreground="{StaticResource Err}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewScheduleCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateScheduleCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconCalendar}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.SaveSchedule}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== About / keyboard shortcuts overlay ===================== -->
        <Grid x:Name="AboutOverlay" Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowAbout, Converter={StaticResource BoolVis}}"
              MouseLeftButtonUp="AboutOverlay_BackdropClick">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowAbout}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10"
                    MouseLeftButtonUp="AboutOverlay_CardClick" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowAbout}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.AboutTitle}" Style="{StaticResource Lbl}"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CloseAboutCommand}"
                                    ToolTip="{StaticResource L.CloseTip}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="AgentManager" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Margin="18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="7" Background="{StaticResource Bg1}"
                                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,13,0">
                                <controls:IconView Icon="{StaticResource IconLayers}" Width="22" Height="22"
                                                   Foreground="{StaticResource Accent}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="13" Foreground="{StaticResource Txt0}">
                                    <Run Text="Agent"/><Run Text="Manager" Foreground="{StaticResource Accent}"/><Run Text=" "/><Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding AboutBuildLabel, Mode=OneWay}" Style="{StaticResource Lbl}" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{StaticResource L.AboutDescription}" FontSize="12.5"
                                   Foreground="{StaticResource Txt1}" TextWrapping="Wrap" LineHeight="20"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="{StaticResource L.KeyboardShortcuts}" Style="{StaticResource Lbl}" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource L.ShortcutSpawn}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+N"/></Border>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource L.ShortcutViews}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+1 / Ctrl+2 / Ctrl+3"/></Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource L.ShortcutDiff}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+R"/></Border>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource L.ShortcutSettings}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+,"/></Border>

                            <Border Grid.Row="4" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource L.ShortcutSend}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Enter"/></Border>
                        </Grid>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.Close}" Command="{Binding CloseAboutCommand}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== New-agent overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewAgent, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewAgent}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="540" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewAgent}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewWorker}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewAgentCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SpawnAgent}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Engines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,9,0" Background="{StaticResource Bg1}" BorderThickness="1"
                                            CornerRadius="7" Padding="11,13" Cursor="Hand" controls:MouseClick.Command="{Binding DataContext.SelectEngineCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                        <Border.BorderBrush>
                                            <MultiBinding Converter="{StaticResource SelBrush}">
                                                <Binding Path="Id"/>
                                                <Binding Path="DataContext.NewAgentSelectedEngine.Id" ElementName="Root"/>
                                            </MultiBinding>
                                        </Border.BorderBrush>
                                        <StackPanel>
                                            <Border Width="30" Height="30" CornerRadius="4" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <controls:IconView Style="{StaticResource EngineIconByDef}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                            <TextBlock Text="{Binding Desc}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewAgentTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.ModelPick}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding NewAgentModels}" SelectedItem="{Binding NewAgentModel, Mode=TwoWay}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{StaticResource L.WorktreeLabel}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7" Padding="11,9">
                            <DockPanel>
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconBranch}" Width="13" Height="13" Foreground="{StaticResource Txt2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{StaticResource L.Isolated}" Style="{StaticResource Lbl}" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NewAgentBranchPreview, Mode=OneWay}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt1}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewAgentCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateSessionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.LaunchAgent}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== New-project overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewProject, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewProject}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="560" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewProject}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewProject}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewProjectCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.RegisterWorkspaceFolder}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Name}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.FolderPath}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="8,0,0,0"
                                    ToolTip="{StaticResource L.BrowseProjectTip}" Click="BrowseProjectFolder_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconFolder}" Width="13" Height="13"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.Browse}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBox Style="{StaticResource SettingsInput}"
                                     Text="{Binding NewProjectPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                        <TextBlock Text="{StaticResource L.MissingFolderNote}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{StaticResource Txt3}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding NewProjectError}" FontFamily="{StaticResource Mono}" FontSize="10"
                                   Foreground="{StaticResource Err}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewProjectCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateProjectCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.AddProject}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
