                                                   Foreground="{DynamicResource Accent}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="13" Foreground="{DynamicResource Txt0}">
                                    <Run Text="Agent"/><Run Text="Manager" Foreground="{DynamicResource Accent}"/><Run Text=" "/><Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding AboutBuildLabel, Mode=OneWay}" Style="{StaticResource Lbl}" FontSize="9"/>
                            </StackPanel>

                            <!-- update check / apply -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding UpdateStatusText}" FontSize="11.5" VerticalAlignment="Center"
                                               Margin="0,0,8,0" Foreground="{DynamicResource Txt1}"/>
                                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.CheckUpdate}"
                                            Command="{Binding CheckUpdateCommand}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0"
                                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolVis}}">
                                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.ViewChangelog}"
                                            Command="{Binding OpenChangelogCommand}" Margin="0,0,6,0"/>
                                    <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.UpdateNow}"
                                            Command="{Binding ApplyUpdateCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{StaticResource L.AboutDescription}" FontSize="12.5"
                                   Foreground="{DynamicResource Txt1}" TextWrapping="Wrap" LineHeight="20"
