                    </Border>

                    <StackPanel Margin="18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="40" Height="40" CornerRadius="7" Background="{StaticResource Bg1}"
                                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,13,0">
                                <controls:IconView Icon="{StaticResource IconLayers}" Width="22" Height="22"
                                                   Foreground="{StaticResource Accent}" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="13" Foreground="{StaticResource Txt0}">
                                    <Run Text="Agent"/><Run Text="Manager" Foreground="{StaticResource Accent}"/><Run Text=" "/><Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding AboutBuildLabel, Mode=OneWay}" Style="{StaticResource Lbl}" FontSize="9"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{StaticResource L.AboutDescription}" FontSize="12.5"
                                   Foreground="{StaticResource Txt1}" TextWrapping="Wrap" LineHeight="20"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="{StaticResource L.KeyboardShortcuts}" Style="{StaticResource Lbl}" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource L.ShortcutSpawn}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+N"/></Border>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource L.ShortcutViews}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+1 / Ctrl+2 / Ctrl+3"/></Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource L.ShortcutDiff}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+R"/></Border>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource L.ShortcutSettings}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+,"/></Border>

                            <Border Grid.Row="4" Grid.ColumnSpan="2" Height="1" Background="{StaticResource LineSoft}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource L.ShortcutSend}" Foreground="{StaticResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Enter"/></Border>
                        </Grid>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.Close}" Click="CloseAbout_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

