<Window x:Class="AgentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:AgentManager.ViewModels"
        xmlns:controls="clr-namespace:AgentManager.Controls"
        xmlns:agents="clr-namespace:AgentManager.Core.Agents;assembly=AgentManager.Core"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:views="clr-namespace:AgentManager.Views"
        x:Name="Root"
        Title="AgentManager" Height="760" Width="1380" WindowStyle="None"
        Background="{DynamicResource Bg1}" Foreground="{DynamicResource Txt0}"
        FontFamily="{StaticResource Sans}" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="N" Command="{Binding NewAgentCommand}"/>
        <KeyBinding Modifiers="Ctrl" Key="R" Command="{Binding ToggleReviewCommand}"/>
    </Window.InputBindings>


    <Window.Resources>
        <!-- BoolVis / SelBrush 컨버터는 App.xaml(공유 스코프)로 이동 — 뷰 UserControl들도 사용 -->
        <Style x:Key="KbdChip" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="TextElement.FontFamily" Value="{StaticResource Mono}"/>
            <Setter Property="TextElement.FontSize" Value="11"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource Accent}"/>
        </Style>
        <!-- SandboxModes ObjectDataProvider는 App.xaml(공유 스코프)로 이동 — SessionView가 사용 -->

        <!-- ===== Transcript block templates ===== -->
        <DataTemplate DataType="{x:Type vm:UserBlock}">
            <Grid Margin="0,14" HorizontalAlignment="Right" MaxWidth="880">
                <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                        CornerRadius="10,10,2,10" Padding="13,11">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,5">
                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.SentEn}"
                                           IsChecked="{Binding ShowSent, Mode=TwoWay}"
                                           Visibility="{Binding HasSent, Converter={StaticResource BoolVis}}"
                                           Margin="9,0,0,0" ToolTip="{StaticResource L.SentEnTip}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="{StaticResource L.You}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding DisplayText, Mode=OneWay}"
                                 Foreground="{DynamicResource Txt0}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AgentTextBlock}">
            <Grid Margin="0,16,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="4" Background="{DynamicResource Bg2}"
                            BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                            ToolTip="{Binding DataContext.AgentName, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                        <!-- 엔진별 브랜드 아이콘+색 (DataContext=세션). 이전엔 Badge 텍스트+하드코딩 Accent였다. -->
                        <controls:IconView Style="{StaticResource EngineIcon}" Width="15" Height="15"
                                           DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="1" Height="46" Background="{DynamicResource LineSoft}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,1,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="{Binding DataContext.AgentName, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" Margin="0,0,8,0"/>
                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}"
                                   Text="{Binding ModelLabel, Mode=OneWay}"/>
                        <ToggleButton Style="{StaticResource TogglePillButton}" Content="{StaticResource L.Original}"
                                      IsChecked="{Binding ShowOriginal, Mode=TwoWay}"
                                      Visibility="{Binding HasOriginal, Converter={StaticResource BoolVis}}"
                                      Margin="9,0,0,0" ToolTip="{StaticResource L.OriginalResponseTip}"/>
                        <Button Margin="9,0,0,0" Padding="4,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="{DynamicResource Txt3}" ToolTip="{StaticResource L.Copy}"
                                Click="CopyAgentText_Click">
                            <controls:IconView Icon="{StaticResource IconCopy}" Width="13" Height="13"/>
                        </Button>
                        <Button Margin="6,0,0,0" Padding="4,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="{DynamicResource Txt3}" ToolTip="{StaticResource L.DelegateToWorker}"
                                Command="{Binding DataContext.OpenDelegateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <controls:IconView Icon="{StaticResource IconLayers}" Width="13" Height="13"/>
                        </Button>
                    </StackPanel>
                    <controls:MarkdownViewer Text="{Binding DisplayText}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DelegationBlock}">
            <Border Margin="40,8,0,8" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel DataContext="{Binding Delegation}">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,9,0">
                            <TextBlock Text="{Binding WorkerBadge}" FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource Txt1}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusLabel}" FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource L.Delegation}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Accent}"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding WorkerName, Mode=OneWay}" FontWeight="SemiBold"/><Run Text=" · "/><Run Text="{Binding WorkerModel, Mode=OneWay}" Foreground="{DynamicResource Txt2}"/>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                    <Border Margin="0,9,0,0" Background="{DynamicResource Bg2}" CornerRadius="6" Padding="9">
                        <TextBlock Text="{Binding Prompt}" FontSize="11" Foreground="{DynamicResource Txt2}" TextWrapping="Wrap"/>
                    </Border>
                    <StackPanel Visibility="{Binding IsReady, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{StaticResource L.Report}" Style="{StaticResource Lbl}" Margin="0,11,0,5"/>
                        <Border Background="{DynamicResource Bg2}" CornerRadius="6" Padding="9">
                            <TextBlock Text="{Binding Report}" FontSize="11" Foreground="{DynamicResource Txt1}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Visibility="{Binding IsFailed, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="{StaticResource L.ErrorLabel}" Style="{StaticResource Lbl}" Margin="0,11,0,5" Foreground="{DynamicResource Err}"/>
                        <Border Background="{DynamicResource DelBg}" CornerRadius="6" Padding="9">
                            <TextBlock Text="{Binding Error}" FontSize="11" Foreground="{DynamicResource Err}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                    <DockPanel Margin="0,10,0,0">
                        <Button DockPanel.Dock="Left" Style="{StaticResource MenuButton}" Padding="2,0" HorizontalAlignment="Left"
                                Command="{Binding DataContext.OpenWorkerCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <controls:IconView Icon="{StaticResource IconIde}" Width="12" Height="12" Foreground="{DynamicResource Txt2}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource L.OpenWorkerSession}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource AccentButton}" Visibility="{Binding IsReady, Converter={StaticResource BoolVis}}"
                                    Command="{Binding DataContext.PasteReportCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                                <TextBlock Text="{StaticResource L.PasteReport}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold"/>
                            </Button>
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Redelegate}" Visibility="{Binding IsFailed, Converter={StaticResource BoolVis}}"
                                    Command="{Binding DataContext.RedelegateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ToolBlock}">
            <Border Margin="40,8,0,8" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}"
                    BorderThickness="1" CornerRadius="7">
                <StackPanel>
                    <ToggleButton IsChecked="{Binding IsOpen}" Cursor="Hand" Background="Transparent" BorderThickness="0">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="Transparent" Padding="11,8">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Kind}" FontFamily="{StaticResource Mono}"
                                                   FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Stat}" FontFamily="{StaticResource Mono}"
                                                   FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.Original}"
                                                      IsChecked="{Binding ShowOriginal, Mode=TwoWay}"
                                                      Visibility="{Binding HasOriginal, Converter={StaticResource BoolVis}}"
                                                      Margin="0,0,9,0" ToolTip="{StaticResource L.OriginalOutputTip}"/>
                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                                                   Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0"
                            Padding="12,10" MaxHeight="220"
                            Visibility="{Binding IsOpen, Converter={StaticResource BoolVis}}">
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding DisplayBody, Mode=OneWay}"
                                 FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt1}"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ErrorBlock}">
            <Border Margin="40,8,0,8" Background="#14FF4D5E" BorderBrush="#66FF4D5E" BorderThickness="1"
                    CornerRadius="7" Padding="13,11">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                               Foreground="{DynamicResource Err}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding Body, Mode=OneWay}"
                             FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt1}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WorkingBlock}">
            <StackPanel Orientation="Horizontal" Margin="40,8,0,4">
                <!-- 원본 @keyframes blink(opacity 1↔0 steps(2) 1s): 라이브 작업 표시 점 깜빡임 -->
                <TextBlock Text="●" Foreground="{DynamicResource Accent}" Margin="0,0,8,0">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" Duration="0:0:1">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="0"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="{Binding Text}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ThinkingBlock}">
            <StackPanel Margin="40,4,0,4">
                <ToggleButton IsChecked="{Binding IsOpen}" Cursor="Hand" Background="Transparent" BorderThickness="0"
                               HorizontalAlignment="Left">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="Transparent" Padding="2,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource L.Thinking}" FontFamily="{StaticResource Mono}" FontSize="10"
                                               Foreground="{DynamicResource Txt3}"/>
                                    <TextBlock x:Name="chev" Text=" ▸" FontSize="9" Foreground="{DynamicResource Txt3}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="2,0,0,0" Padding="12,4,0,2" Margin="2,2,0,0"
                        Visibility="{Binding IsOpen, Converter={StaticResource BoolVis}}">
                    <TextBox Style="{StaticResource SelectableText}" Text="{Binding Text, Mode=OneWay}"
                             FontStyle="Italic" FontSize="12" Foreground="{DynamicResource Txt2}"/>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- Approval prompt: engine is blocked until Approve/Deny -->
        <DataTemplate DataType="{x:Type vm:ApprovalBlock}">
            <Border Margin="40,10,0,10" BorderBrush="{DynamicResource Warn}" BorderThickness="1"
                    CornerRadius="7" Background="#10F5B531">
                <StackPanel>
                    <DockPanel Margin="13,10,13,0">
                        <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.ApprovalRequired}" FontFamily="{StaticResource Mono}"
                                   FontSize="10.5" Foreground="{DynamicResource Warn}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding StateLabel}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ToolName}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </DockPanel>
                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                            CornerRadius="4" Margin="13,9" Padding="11,8" MaxHeight="120">
                        <TextBox Style="{StaticResource SelectableText}" Text="{Binding InputSummary, Mode=OneWay}"
                                 FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt1}"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="13,0,13,12"
                                Visibility="{Binding IsPending, Converter={StaticResource BoolVis}}">
                        <Button Content="{StaticResource L.ApproveRun}" Cursor="Hand" Padding="15,7" Margin="0,0,8,0"
                                FontWeight="SemiBold" FontSize="12" Foreground="#FF06160F"
                                Command="{Binding DataContext.ApproveCommand, ElementName=Root}" CommandParameter="{Binding}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ab" Background="{DynamicResource Ok}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ab" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.ApproveForSession}" Margin="0,0,8,0"
                                ToolTip="{StaticResource L.ApproveForSessionTip}"
                                Visibility="{Binding SupportsSessionApproval, Converter={StaticResource BoolVis}}"
                                Command="{Binding DataContext.ApproveForSessionCommand, ElementName=Root}" CommandParameter="{Binding}"/>
                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Reject}"
                                Command="{Binding DataContext.DenyCommand, ElementName=Root}" CommandParameter="{Binding}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== Titlebar ===================== -->
        <Border Grid.Row="0" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- accent 장식 바: Fill은 accent 브러시(라이브 추종), 가로 페이드는 OpacityMask로 -->
                <Rectangle Grid.ColumnSpan="5" Height="2" Width="120" HorizontalAlignment="Left" VerticalAlignment="Top"
                           Fill="{DynamicResource Accent}">
                    <Rectangle.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.OpacityMask>
                </Rectangle>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,18,0">
                    <TextBlock Text="◆" Foreground="{DynamicResource Accent}" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock FontFamily="{StaticResource Mono}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Agent" Foreground="{DynamicResource Txt0}"/><Run Text="Manager" Foreground="{DynamicResource Accent}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Agents}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.NewAgent}" InputGestureText="Ctrl+N" Command="{Binding NewAgentCommand}"/>
                                <MenuItem Header="{StaticResource L.NewProject}" Command="{Binding NewProjectCommand}"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.NewClaudeSession}" Command="{Binding NewAgentForEngineCommand}" CommandParameter="cc"/>
                                <MenuItem Header="{StaticResource L.NewCodexSession}" Command="{Binding NewAgentForEngineCommand}" CommandParameter="gx"/>
                                <MenuItem Header="{StaticResource L.NewAntigravitySession}" Command="{Binding NewAgentForEngineCommand}" CommandParameter="agy"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.OrchestratorDashboard}" InputGestureText="Ctrl+1" Command="{Binding ShowViewCommand}" CommandParameter="orchestrator"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.View}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.Orchestrator}" InputGestureText="Ctrl+1" Command="{Binding ShowViewCommand}" CommandParameter="orchestrator"/>
                                <MenuItem Header="{StaticResource L.ActivityHistory}" InputGestureText="Ctrl+2" Command="{Binding ShowViewCommand}" CommandParameter="history"/>
                                <MenuItem Header="{StaticResource L.ScheduledTasks}" InputGestureText="Ctrl+3" Command="{Binding ShowViewCommand}" CommandParameter="scheduled"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.ToggleReviewPane}" InputGestureText="Ctrl+R" Command="{Binding ToggleReviewCommand}"/>
                                <MenuItem Header="{StaticResource L.Settings}" InputGestureText="Ctrl+," Command="{Binding ShowSettingsCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource MenuButton}" Content="{StaticResource L.Help}" Click="MenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{StaticResource L.KeyboardShortcuts}" Command="{Binding ShowAboutCommand}"/>
                                <MenuItem Header="{StaticResource L.OpenDocsFolder}" Click="HelpDocs_Click"/>
                                <Separator/>
                                <MenuItem Header="{StaticResource L.AboutAgentManager}" Command="{Binding ShowAboutCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                            TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10">
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Run Text="{Binding RunningCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Running}"/></TextBlock>
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource Warn}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,14,0">
                        <Run Text="{Binding WaitingCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Waiting}"/></TextBlock>
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource Ok}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Foreground="{DynamicResource Txt2}" VerticalAlignment="Center">
                        <Run Text="{Binding DoneCount, Mode=OneWay}"/><Run Text=" " /><Run Text="{StaticResource L.Done}"/></TextBlock>
                    <TextBlock Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="18,0,10,0">
                        <Run Text="{StaticResource L.SumTkn}"/><Run Text="{Binding TotalTokensLabel, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                    <TextBlock Foreground="{DynamicResource Txt2}" VerticalAlignment="Center">
                        <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding TotalCostLabel, Mode=OneWay}" Foreground="{DynamicResource Ok}"/></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Stretch" Height="34"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinBtn" Style="{StaticResource MenuButton}" shell:WindowChrome.IsHitTestVisibleInChrome="True" Content="—" Width="44" Height="34" Click="MinBtn_Click" ToolTip="{StaticResource L.MinimizeTip}"/>
                    <Button x:Name="MaxBtn" Style="{StaticResource MenuButton}" shell:WindowChrome.IsHitTestVisibleInChrome="True" Content="▢" Width="44" Height="34" Click="MaxBtn_Click" ToolTip="{StaticResource L.MaximizeTip}"/>
                    <Button x:Name="CloseBtn" Style="{StaticResource MenuButton}" shell:WindowChrome.IsHitTestVisibleInChrome="True" Content="✕" Width="44" Height="34" Click="CloseBtn_Click" ToolTip="{StaticResource L.CloseTip}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Body ===================== -->
        <Grid Grid.Row="1">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding BodyScale}" ScaleY="{Binding BodyScale}"/>
            </Grid.LayoutTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ReviewCol" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Style="{StaticResource AccentButton}" Margin="12,12,12,8"
                            Command="{Binding NewAgentCommand}">
                        <StackPanel Orientation="Horizontal">
                            <controls:IconView Icon="{StaticResource IconPlus}" Width="14" Height="14"
                                               Foreground="{DynamicResource AccentText}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource L.NewAgent}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
 
                    <Border DockPanel.Dock="Top" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}"
                            BorderThickness="1" CornerRadius="7" Margin="12,0,12,8" Padding="6,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <controls:IconView Grid.Column="0" Icon="{StaticResource IconSearch}" Width="13" Height="13"
                                               Foreground="{DynamicResource Txt2}" Margin="4,0,6,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="SessionSearchBox" Grid.Column="1" Style="{StaticResource ComposerInput}" Background="Transparent"
                                     BorderThickness="0" Padding="0,7" VerticalAlignment="Center" AcceptsReturn="False"
                                     Text="{Binding SessionFilter, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>
 
                    <StackPanel DockPanel.Dock="Top" Margin="8,0,8,4">
                        <StackPanel.Resources>
                            <Style x:Key="NavItemBase" TargetType="Border">
                                <Setter Property="Padding" Value="9,7"/>
                                <Setter Property="CornerRadius" Value="5"/>
                                <Setter Property="Margin" Value="0,0,0,1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="TextElement.Foreground" Value="{DynamicResource Txt1}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                        <Setter Property="TextElement.Foreground" Value="{DynamicResource Txt0}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Resources>
                        <!-- Orchestrator -->
                        <Border controls:MouseClick.Command="{Binding ShowViewCommand}" controls:MouseClick.CommandParameter="orchestrator" ToolTip="{StaticResource L.CurrentViewTip}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource NavItemBase}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOrchestratorView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <controls:IconView Icon="{StaticResource IconGrid}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource L.Orchestrator}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Activity History -->
                        <Border controls:MouseClick.Command="{Binding ShowViewCommand}" controls:MouseClick.CommandParameter="history" ToolTip="{StaticResource L.ActivityHistoryTip}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource NavItemBase}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHistoryView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <controls:IconView Icon="{StaticResource IconHistory}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource L.ActivityHistory}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- Scheduled Tasks -->
                        <Border controls:MouseClick.Command="{Binding ShowViewCommand}" controls:MouseClick.CommandParameter="scheduled" ToolTip="{StaticResource L.ScheduledTasksTip}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource NavItemBase}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScheduledView}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                            <Setter Property="TextElement.Foreground" Value="{DynamicResource Accent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <controls:IconView Icon="{StaticResource IconCalendar}" Width="15" Height="15" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource L.ScheduledTasks}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- footer -->
                    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="10,8">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30" Height="30"
                                    Command="{Binding ShowSettingsCommand}" ToolTip="{StaticResource L.Settings}" VerticalAlignment="Center">
                                <controls:IconView Icon="{StaticResource IconSettings}" Width="16" Height="16"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30" Height="30"
                                    Command="{Binding CheckUsageCommand}" ToolTip="{StaticResource L.CheckUsage}" VerticalAlignment="Center">
                                <controls:IconView Icon="{StaticResource IconRefresh}" Width="15" Height="15"/>
                            </Button>
                            <Border DockPanel.Dock="Left" Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Bg4}" Margin="0,0,8,0">
                                <controls:IconView Icon="{StaticResource IconUser}" Width="13" Height="13" Foreground="{DynamicResource Txt2}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{StaticResource L.Local}" FontSize="12" Foreground="{DynamicResource Txt0}"/>
                                <TextBlock Text="{Binding QuotaText}" Style="{StaticResource Lbl}" FontSize="9"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- session list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <DockPanel Margin="14,14,14,6">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Active}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding ActiveSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}"/>
                                <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding ActiveSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DataTemplate.Resources>
                                            <Storyboard x:Key="SidebarSparkStoryboard">
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SidebarBar1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1">
                                                    <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                                    <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                                        <EasingDoubleKeyFrame.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </EasingDoubleKeyFrame.EasingFunction>
                                                    </EasingDoubleKeyFrame>
                                                    <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SidebarBar2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.13">
                                                    <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                                    <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                                        <EasingDoubleKeyFrame.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </EasingDoubleKeyFrame.EasingFunction>
                                                    </EasingDoubleKeyFrame>
                                                    <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SidebarBar3" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.26">
                                                    <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                                    <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                                        <EasingDoubleKeyFrame.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </EasingDoubleKeyFrame.EasingFunction>
                                                    </EasingDoubleKeyFrame>
                                                    <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SidebarBar4" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.39">
                                                    <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                                    <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                                        <EasingDoubleKeyFrame.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </EasingDoubleKeyFrame.EasingFunction>
                                                    </EasingDoubleKeyFrame>
                                                    <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                                                </DoubleAnimationUsingKeyFrames>
                                                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SidebarBar5" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.52">
                                                    <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                                    <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                                        <EasingDoubleKeyFrame.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut"/>
                                                        </EasingDoubleKeyFrame.EasingFunction>
                                                    </EasingDoubleKeyFrame>
                                                    <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                                                </DoubleAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </DataTemplate.Resources>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                controls:MouseClick.Command="{Binding DataContext.SelectSessionCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Archive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ActiveRenameBox" Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}"
                                                                 BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ActiveRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,4,0,0">
                                                    <!-- Spark Equalizer when running -->
                                                    <StackPanel x:Name="SidebarSpark" Orientation="Horizontal" VerticalAlignment="Center" Height="9" Margin="0,0,6,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Border x:Name="SidebarBar1" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleY="0.22"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                        <Border x:Name="SidebarBar2" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleY="0.22"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                        <Border x:Name="SidebarBar3" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleY="0.22"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                        <Border x:Name="SidebarBar4" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleY="0.22"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                        <Border x:Name="SidebarBar5" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleY="0.22"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                    </StackPanel>
                                                    <controls:StatusDot Status="{Binding Status}" VerticalAlignment="Center" Margin="-5,0"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Accent}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsRunning}" Value="True"/>
                                                                            <Condition Binding="{Binding DataContext.StreamLogs, ElementName=Root}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <!-- 실행 중 이퀄라이저: Style이 아니라 DataTemplate.Triggers에서 시작해야 TargetName(SidebarBar*) 해석 가능 -->
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="SidebarSparkAnim" Storyboard="{StaticResource SidebarSparkStoryboard}"/>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="SidebarSparkAnim"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="14,18,14,6" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" Text="{StaticResource L.Projects}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Projects.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Border Grid.Column="2" Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0"/>
                                <Button Grid.Column="3" Style="{StaticResource HeaderIconButton}"
                                        ToolTip="{StaticResource L.AddProjectTip}" Command="{Binding NewProjectCommand}">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="12" Height="12"/>
                                </Button>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Projects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,7" Cursor="Hand"
                                                controls:MouseClick.Command="{Binding DataContext.SelectProjectCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}" ToolTip="{Binding Path}">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.RemoveProject}" Command="{Binding DataContext.RemoveProjectCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ProjRenameBox" Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}"
                                                                 BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding RenameDraft, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameProjectCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconFolder}" Width="13" Height="13"
                                                                   Foreground="{DynamicResource Txt2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding SessionCount}" FontFamily="{StaticResource Mono}"
                                                           FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12.5" Foreground="{DynamicResource Txt0}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- WORKERS group (워커 위임 풀) -->
                            <StackPanel Visibility="{Binding HasProjectWorkers, Converter={StaticResource BoolVis}}">
                                <DockPanel Margin="14,14,14,6">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.WorkersGroup}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Info}" Margin="0,0,8,0"/>
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding ProjectWorkers.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}"/>
                                    <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding ProjectWorkers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="6,1" CornerRadius="7" Padding="10,7" Cursor="Hand"
                                                    controls:MouseClick.Command="{Binding DataContext.SelectSessionCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource Bg3}"/></Trigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Info}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4" Margin="0,0,9,0"
                                                            Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1">
                                                        <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Ellipse DockPanel.Dock="Right" Width="7" Height="7" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource Ok}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBusy}" Value="True"><Setter Property="Fill" Value="{DynamicResource Run}"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis">
                                                            <Run Text="{Binding Model, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding DelegationTrLabel, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <Grid Margin="14,14,14,6" Height="22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource Lbl}" VerticalAlignment="Center">
                                    <Run Text="{StaticResource L.Project}"/><Run Text=" · "/><Run Text="{Binding Project, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding ProjectSessions.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Border Grid.Column="2" Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ProjectSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                controls:MouseClick.Command="{Binding DataContext.SelectSessionCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Archive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ProjectRenameBox" Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}"
                                                                 BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ProjectRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Ellipse DockPanel.Dock="Right" Width="7" Height="7" VerticalAlignment="Top" Margin="6,4,0,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{DynamicResource Txt3}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{DynamicResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{DynamicResource Warn}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{DynamicResource Ok}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{DynamicResource Err}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Accent}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsRunning}" Value="True"/>
                                                                            <Condition Binding="{Binding DataContext.StreamLogs, ElementName=Root}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 헤더는 항상 표시: 목록이 비어도 재스캔 버튼으로 새 CLI 세션을 발견할 수 있어야 함 -->
                            <DockPanel Margin="14,18,14,6">
                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="24" Height="20" Padding="0"
                                        Foreground="{DynamicResource Txt3}" ToolTip="{StaticResource L.RefreshCliHistoryTip}"
                                        Command="{Binding RefreshCliHistoryCommand}">
                                    <controls:IconView Icon="{StaticResource IconRefresh}" Width="11" Height="11"/>
                                </Button>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.CliHistory}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Txt2}" Margin="0,0,8,0"
                                           ToolTip="{StaticResource L.CliHistoryTip}"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding CliHistory.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}"/>
                                <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0,8,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding CliHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,7" Cursor="Hand" Opacity="0.85"
                                                controls:MouseClick.Command="{Binding DataContext.ImportCliSessionCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}"
                                                ToolTip="{StaticResource L.ImportCliTip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{DynamicResource Txt1}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding TimeLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                               Foreground="{DynamicResource Txt3}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="14,18,14,6">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Archived}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Txt2}" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{Binding ArchivedSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}"/>
                                <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding ArchivedSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6,1" CornerRadius="7" Padding="10,8" Cursor="Hand"
                                                Opacity="0.72" controls:MouseClick.Command="{Binding DataContext.SelectSessionCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="{StaticResource L.Unarchive}" Command="{Binding DataContext.ArchiveSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Fork}" Command="{Binding DataContext.ForkSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <MenuItem Header="{StaticResource L.Delete}" Command="{Binding DataContext.DeleteSessionCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                                                    <Separator/>
                                                    <StackPanel Width="190" Margin="8,6">
                                                        <TextBlock Text="{StaticResource L.Rename}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="ArchivedRenameBox" Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}"
                                                                 BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="8"
                                                                 AcceptsReturn="False" Text="{Binding Title, Mode=OneWay}"/>
                                                        <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Apply}" Margin="0,8,0,0"
                                                                Command="{Binding DataContext.RenameSessionCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding Text, ElementName=ArchivedRenameBox}"/>
                                                    </StackPanel>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Left" Width="26" Height="26" CornerRadius="4" Margin="0,0,9,0"
                                                        Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1">
                                                    <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Main pane -->
            <Grid Grid.Column="1" DataContext="{Binding ActiveSession}">
                <!-- In-app activity history shell -->

                <!-- Session View Wrapper -> views/SessionView -->
                <views:SessionView Visibility="{Binding DataContext.IsSessionView, ElementName=Root, Converter={StaticResource BoolVis}}"/>

                <!-- Orchestrator View -->
                <views:OrchestratorView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsOrchestratorView, Converter={StaticResource BoolVis}}"/>

                <!-- Activity History View -->
                <views:HistoryView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsHistoryView, Converter={StaticResource BoolVis}}"/>

                <!-- Scheduled Tasks View -->
                <views:ScheduledView DataContext="{Binding DataContext, ElementName=Root}"
                                  Visibility="{Binding IsScheduledView, Converter={StaticResource BoolVis}}"/>

                <!-- ===================== Settings (full center pane) -> views/SettingsView ===================== -->
                <views:SettingsView DataContext="{Binding DataContext, ElementName=Root}"
                                    Visibility="{Binding IsSettingsView, Converter={StaticResource BoolVis}}"/>
            </Grid>

            <!-- Review pane -->
            <Border Grid.Column="2" DataContext="{Binding ActiveSession}" Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource LineSoft}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.DiffReview}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Txt0}"
                                       VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <TextBlock Text="{Binding ReviewStatus}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                       Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.CloseTip}"
                                    Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.RefreshChangesTip}"
                                    Command="{Binding DataContext.RefreshReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconRefresh}" Width="13" Height="13"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Changes}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Changes.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{DynamicResource Txt2}"/>
                            </DockPanel>
                            <ListBox x:Name="ReviewChangesList" ItemsSource="{Binding Changes}" SelectedItem="{Binding SelectedChange, Mode=TwoWay}"
                                     SelectionChanged="ReviewChanges_SelectionChanged"
                                     Background="Transparent" BorderThickness="0" MaxHeight="190"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="row" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{DynamicResource Bg3}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{DynamicResource Bg4}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="8,7">
                                            <Border DockPanel.Dock="Left" Width="24" Height="22" CornerRadius="4"
                                                    Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding KindLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                           Foreground="{DynamicResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatLabel}" FontFamily="{StaticResource Mono}"
                                                       FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Path}" FontFamily="{StaticResource Mono}" FontSize="11"
                                                       Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <DockPanel Margin="0,14,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Artifacts}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Artifacts.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{DynamicResource Txt2}"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding Artifacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Background="{DynamicResource Bg1}" BorderThickness="1" CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Err}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <DockPanel Margin="9,7,9,5">
                                                    <Border DockPanel.Dock="Left" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Kind}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Accent}"/>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5" Foreground="{DynamicResource Txt0}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="9,7" MaxHeight="120">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Content}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                                   Foreground="{DynamicResource Txt1}" TextWrapping="Wrap"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{StaticResource L.NoArtifacts}" FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{DynamicResource Txt3}" Margin="2,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Artifacts.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                        Foreground="{DynamicResource AccentText}" Margin="8,0,0,0"
                                        Command="{Binding DataContext.SendDiffFeedbackCommand, ElementName=Root}"
                                        CommandParameter="{Binding Text, ElementName=DiffFeedbackBox}"
                                        Click="DiffFeedbackSend_Click">
                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                </Button>
                                <TextBox x:Name="DiffFeedbackBox" Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}"
                                         BorderBrush="{DynamicResource Line}" BorderThickness="1" Padding="9"
                                         AcceptsReturn="False" MinHeight="32"
                                         TextWrapping="NoWrap" ToolTip="{StaticResource L.FeedbackPlaceholder}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource AccentButton}" Content="{StaticResource L.MergeMain}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.MergeMainTip}"
                                        Command="{Binding DataContext.MergeReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Content="{StaticResource L.CommitOnly}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.CommitReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Discard}"
                                        ToolTip="{StaticResource L.DiscardTip}"
                                        Command="{Binding DataContext.DiscardReviewCommand, ElementName=Root}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Worktree}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding WorktreeLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="32" Background="{DynamicResource Bg1}"
                                BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="12,0">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Diff}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedChange.Path}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="270"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <controls:DiffViewer Text="{Binding DiffText}"/>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== New-schedule overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewSchedule, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewSchedule}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="620" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.LayoutTransform><ScaleTransform ScaleX="{Binding ModalScale}" ScaleY="{Binding ModalScale}"/></Border.LayoutTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewSchedule}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewSchedule}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewScheduleCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SchedCreateTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding NewScheduleTitle, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.SchedPrompt}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{DynamicResource Bg1}" Padding="10"
                                 BorderBrush="{DynamicResource Line}" BorderThickness="1" MinHeight="78"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding NewSchedulePrompt, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <ListBox ItemsSource="{Binding Engines}" SelectedItem="{Binding NewScheduleSelectedEngine, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="rt" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                                                        CornerRadius="7" Padding="10" Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                        <Setter TargetName="rt" Property="Background" Value="{DynamicResource AccentDim}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Badge}" FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Cli}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.SchedCadence}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewScheduleCadence, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{StaticResource L.SchedCadenceHint}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{DynamicResource Txt3}" Margin="2,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.SchedTargetBranch}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource SettingsInput}"
                                         Text="{Binding NewScheduleTargetBranch, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding NewScheduleError}" FontFamily="{StaticResource Mono}" FontSize="10"
