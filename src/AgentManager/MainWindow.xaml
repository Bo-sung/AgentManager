                        <TextBlock Text="{StaticResource L.KeyboardShortcuts}" Style="{StaticResource Lbl}" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{StaticResource L.ShortcutSpawn}" Foreground="{DynamicResource Txt1}" FontSize="12.5" Padding="0,8"/>
                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+N"/></Border>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource LineSoft}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{StaticResource L.ShortcutViews}" Foreground="{DynamicResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+1 / Ctrl+2 / Ctrl+3"/></Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource LineSoft}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{StaticResource L.ShortcutDiff}" Foreground="{DynamicResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+R"/></Border>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource LineSoft}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{StaticResource L.ShortcutSettings}" Foreground="{DynamicResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Ctrl+,"/></Border>

                            <Border Grid.Row="4" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource LineSoft}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{StaticResource L.ShortcutSend}" Foreground="{DynamicResource Txt1}" FontSize="12.5" Padding="0,8" Margin="0,1,0,0"/>
                            <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource KbdChip}"><TextBlock Text="Enter"/></Border>
                        </Grid>
                    </StackPanel>

                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Background="{DynamicResource Bg1}" Padding="18,14">
