                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <ToggleButton Style="{StaticResource TogglePillButton}" HorizontalAlignment="Left"
                                                  IsChecked="{Binding NewAgentTranslation, Mode=TwoWay}"
                                                  Content="{Binding NewAgentTranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"/>
                                    <controls:IconView Icon="{StaticResource IconWarn}" Width="15" Height="15" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Warn}" ToolTip="{StaticResource L.OllamaOffWarn}"
                                                       Visibility="{Binding OllamaDown, Converter={StaticResource BoolVis}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{StaticResource L.WorktreeLabel}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="11,9">
                            <DockPanel>
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconBranch}" Width="13" Height="13" Foreground="{DynamicResource Txt2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{StaticResource L.Isolated}" Style="{StaticResource Lbl}" FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding NewAgentBranchPreview, Mode=OneWay}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Background="{DynamicResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewAgentCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateSessionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                       Foreground="{DynamicResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.LaunchAgent}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Worker-assign overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowWorkerAssign, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowWorkerAssign}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
