                            <Button Style="{StaticResource ChipButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,2,0,0"
                                    Content="{StaticResource L.AddNewWorker}" Command="{Binding ToggleNewWorkerCommand}"/>
                            <!-- 일괄 fan-out: 유휴 워커 전체에 같은 프롬프트 동시 위임 -->
                            <Button Style="{StaticResource ChipButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,6,0,0"
                                    Command="{Binding DelegateAllCommand}" Visibility="{Binding CanDelegateAll, Converter={StaticResource BoolVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconLayers}" Width="12" Height="12" Foreground="{DynamicResource Info}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock VerticalAlignment="Center"><Run Text="{StaticResource L.DelegateAll}"/><Run Text=" ("/><Run Text="{Binding IdleWorkerCount, Mode=OneWay}"/><Run Text=")"/></TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- new worker form -->
                            <Border Margin="0,12,0,0" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14"
                                    Visibility="{Binding DelegateNewWorkerOpen, Converter={StaticResource BoolVis}}">
                                <StackPanel>
                                    <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding WorkerEngines}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,9,0" Background="{DynamicResource Bg2}" BorderThickness="1" CornerRadius="7" Padding="10,11" Cursor="Hand"
                                                        controls:MouseClick.Command="{Binding DataContext.SelectWorkerEngineCommand, Source={x:Reference Root}}" controls:MouseClick.CommandParameter="{Binding}">
                                                    <Border.BorderBrush>
                                                        <MultiBinding Converter="{StaticResource SelBrush}">
                                                            <Binding Path="Id"/>
                                                            <Binding Path="DataContext.NewWorkerEngine.Id" ElementName="Root"/>
                                                        </MultiBinding>
                                                    </Border.BorderBrush>
                                                    <StackPanel>
                                                        <Border Width="28" Height="28" CornerRadius="4" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,7">
                                                            <controls:IconView Style="{StaticResource EngineIconByDef}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{StaticResource L.WorkerName}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                            <TextBox Style="{StaticResource SettingsInput}" Text="{Binding NewWorkerName, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{StaticResource L.ModelPick}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding NewWorkerModels}" SelectedItem="{Binding NewWorkerModel, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Grid>
                                    <DockPanel Margin="0,12,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.TranslationPolicy}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                        <CheckBox DockPanel.Dock="Right" Content="{StaticResource L.TranslationOn}" IsChecked="{Binding NewWorkerTranslationEnabled}" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="{Binding NewWorkerTranslationEnabled, Converter={StaticResource BoolVis}}">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="{StaticResource L.TranslateSource}" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                            <ComboBox MinWidth="130" ItemsSource="{Binding AvailableTranslationLanguages}" SelectedValuePath="Id" SelectedValue="{Binding NewWorkerSource, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{StaticResource L.TranslateTarget}" Style="{StaticResource Lbl}" Margin="0,0,0,4"/>
                                            <ComboBox MinWidth="130" ItemsSource="{Binding AvailableTranslationLanguages}" SelectedValuePath="Id" SelectedValue="{Binding NewWorkerTarget, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{StaticResource L.WorkerFixedNote}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- delegation prompt -->
                            <TextBlock Text="{StaticResource L.DelegationPrompt}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                            <TextBox Style="{StaticResource SettingsInput}" Text="{Binding DelegatePrompt, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="84" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>

                            <!-- worktree -->
                            <CheckBox Margin="0,14,0,0" Content="{StaticResource L.ShareMainWorktree}" IsChecked="{Binding DelegateWorktreeShared}" Foreground="{DynamicResource Txt2}"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== No-idle-worker overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNoIdleWorker, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNoIdleWorker}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.LayoutTransform><ScaleTransform ScaleX="{Binding ModalScale}" ScaleY="{Binding ModalScale}"/></Border.LayoutTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNoIdleWorker}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="WORKERS" Style="{StaticResource Lbl}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelDelegateCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.NoIdleWorker}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <TextBlock Margin="18" Text="{StaticResource L.NoIdleWorkerBody}" FontSize="12.5" Foreground="{DynamicResource Txt2}" TextWrapping="Wrap"/>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Background="{DynamicResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Close}" Margin="0,0,9,0" Command="{Binding CancelDelegateCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding NoIdleCreateCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="13" Height="13" Foreground="{DynamicResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.Create}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== New-project overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewProject, Converter={StaticResource BoolVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowNewProject}" Value="True">
                            <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayFadeIn}"/></DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Width="560" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="10" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><TranslateTransform Y="0"/></Border.RenderTransform>
                <Border.LayoutTransform><ScaleTransform ScaleX="{Binding ModalScale}" ScaleY="{Binding ModalScale}"/></Border.LayoutTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowNewProject}" Value="True">
                                <DataTrigger.EnterActions><BeginStoryboard Storyboard="{StaticResource OverlayRiseIn}"/></DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewProject}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewProjectCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.RegisterWorkspaceFolder}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Name}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.FolderPath}" Style="{StaticResource Lbl}" Margin="0,16,0,8"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="8,0,0,0"
                                    ToolTip="{StaticResource L.BrowseProjectTip}" Click="BrowseProjectFolder_Click">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconFolder}" Width="13" Height="13"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.Browse}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBox Style="{StaticResource SettingsInput}"
                                     Text="{Binding NewProjectPath, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>
                        <TextBlock Text="{StaticResource L.MissingFolderNote}" FontFamily="{StaticResource Mono}"
                                   FontSize="10" Foreground="{DynamicResource Txt3}" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding NewProjectError}" FontFamily="{StaticResource Mono}" FontSize="10"
                                   Foreground="{DynamicResource Err}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Background="{DynamicResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewProjectCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateProjectCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconPlus}" Width="13" Height="13"
                                                       Foreground="{DynamicResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.AddProject}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Zoom % toast ===================== -->
        <Border Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#CC05080B"
                BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="10" Padding="24,15" IsHitTestVisible="False"
                Visibility="{Binding ShowZoomToast, Converter={StaticResource BoolVis}}">
            <TextBlock Text="{Binding ZoomToastText}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
        </Border>

    </Grid>
</Window>
