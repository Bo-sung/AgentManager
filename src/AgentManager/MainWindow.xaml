                    </TextBlock>

                    <DockPanel>
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasActive, ElementName=Root}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>

                        <!-- tabbar -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="14,0">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Project}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" Text="  ›  " Foreground="{StaticResource Txt3}" VerticalAlignment="Center"/>
                                <!-- 리뷰 토글은 최우측: 패널이 우측에서 열리므로 위치=동작 (사용자 요청) -->
                                <Button DockPanel.Dock="Right" Width="30" Height="30"
                                        ToolTip="{StaticResource L.DiffReviewToggleTip}"
                                        Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Txt1}"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1" CornerRadius="6">
                                                            <controls:IconView Icon="{StaticResource IconPanel}"
                                                                               Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Txt0}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource LineBright}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding DataContext.IsReviewOpen, ElementName=Root}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border DockPanel.Dock="Right" Background="{StaticResource Bg3}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="20" Padding="8,3" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Txt1}"/>
                                </Border>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.OpenIdeTip}"
                                        Command="{Binding DataContext.OpenIdeCommand, ElementName=Root}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconIde}" Width="13" Height="13"
                                                           Foreground="{StaticResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.OpenIde}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.ExportTip}" Click="ExportTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconFile}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.Export}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.CopyAllTip}" Click="CopyTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconCopy}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.CopyAll}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>

                        <!-- status strip -->
                        <Border DockPanel.Dock="Top" Height="38" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="16,0" LastChildFill="False" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusLabel}" Foreground="{StaticResource Txt1}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Border DockPanel.Dock="Left" Background="{StaticResource AccentDim}"
                                        BorderThickness="1" CornerRadius="13" Padding="9,3" VerticalAlignment="Center" Margin="0,0,16,0"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{StaticResource L.Running}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{StaticResource Txt0}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding LastSignalLabel}" Foreground="{StaticResource Txt2}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{StaticResource Txt2}">
                                    <Run Text="{StaticResource L.StatusAgent}"/><Run Text="{Binding AgentName, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{StaticResource Txt2}">
                                    <Run Text="{StaticResource L.StatusModel}"/><Run Text="{Binding Model, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                              IsChecked="{Binding TranslationEnabled, Mode=TwoWay}"
                                              Content="{Binding TranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"
                                              Margin="16,0,0,0"/>
                                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                              IsChecked="{Binding RequireApproval, Mode=TwoWay}"
                                              Content="{StaticResource L.Approval}" ToolTip="{StaticResource L.ApprovalToggleTip}"
                                              Margin="8,0,0,0"/>
                                <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding Source={StaticResource SandboxModes}}"
                                          SelectedItem="{Binding Sandbox, Mode=TwoWay}"
                                          FontFamily="{StaticResource Mono}" FontSize="10" Width="132" Height="24"
                                          Background="{StaticResource Bg1}" Foreground="{StaticResource Txt1}"
                                          BorderBrush="{StaticResource Line}" Margin="8,0,0,0"/>
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource Txt2}">
                                    <Run Text="{StaticResource L.Tkn}"/><Run Text="{Binding TokensLabel, Mode=OneWay}" Foreground="{StaticResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{StaticResource Txt2}" Margin="0,0,16,0">
                                    <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding CostLabel, Mode=OneWay}" Foreground="{StaticResource Ok}"/></TextBlock>
                            </DockPanel>
                        </Border>

                        <!-- composer (bottom) -->
                        <Border DockPanel.Dock="Bottom" Margin="14,0,14,14" MinWidth="520" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <Border Margin="4,0,4,8" Background="{StaticResource AccentDim}" BorderThickness="1" CornerRadius="8"
                                        Padding="11,8" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{StaticResource Txt0}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding LastSignalLabel}" Foreground="{StaticResource Txt2}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource L.Running}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding BusyLine}" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border Background="{StaticResource Bg3}" BorderThickness="1.5" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                    <Setter Property="BorderBrush" Value="{StaticResource GxLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                    <Setter Property="BorderBrush" Value="{StaticResource InfoLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AgyLine}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Bottom" Padding="9,0,9,9" Height="50">
                                            <DockPanel VerticalAlignment="Bottom" LastChildFill="True">
                                                <Button DockPanel.Dock="Left" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{StaticResource L.AttachImageTip}"
                                                        Click="AttachImage_Click">
                                                    <controls:IconView Icon="{StaticResource IconAttach}" Width="15" Height="15"/>
                                                </Button>
                                                <Border DockPanel.Dock="Left" Height="30" CornerRadius="15" Padding="12,0" BorderThickness="1"
                                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                                        ToolTip="{StaticResource L.AgentEngineTip}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                    <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                    <Setter Property="Background" Value="{StaticResource GxDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource GxLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                    <Setter Property="Background" Value="{StaticResource InfoDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource InfoLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                    <Setter Property="Background" Value="{StaticResource AgyDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AgyLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Style="{StaticResource EngineIcon}" Width="16" Height="16"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Text="{Binding Badge}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Txt1}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                            <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                            <Setter Property="Foreground" Value="{StaticResource Info}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                            <Setter Property="Foreground" Value="{StaticResource Agy}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <Border DockPanel.Dock="Left" Style="{StaticResource ComposerPill}" Margin="0,0,8,0"
                                                        VerticalAlignment="Center" ToolTip="{Binding Branch}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconBranch}" Width="13" Height="13"
                                                                           Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{StaticResource Txt1}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{StaticResource L.WorktreePrefix}" Foreground="{StaticResource Txt2}"/><Run Text="{Binding BranchTail, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                                                    <ToggleButton x:Name="ModelMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand" ToolTip="{StaticResource L.ModelSelectTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconSpark}" Width="13" Height="13"
                                                                               Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding Model}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="ag">
                                                                                <Setter Property="Foreground" Value="{StaticResource Info}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                                <Setter Property="Foreground" Value="{StaticResource Agy}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{StaticResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=ModelMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{StaticResource Bg3}" BorderBrush="{StaticResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="200">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7">
                                                                    <Run Text="{Binding AgentName, Mode=OneWay}"/><Run Text="{StaticResource L.DotModel}"/>
                                                                </TextBlock>
                                                                <ItemsControl ItemsSource="{Binding AvailableModels}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="ModelOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="mi" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="mi" Property="Background" Value="{StaticResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0"
                                                      Visibility="{Binding HasEffort, Converter={StaticResource BoolVis}}">
                                                    <ToggleButton x:Name="EffortMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand"
                                                                  ToolTip="{StaticResource L.EffortTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                                               Foreground="{StaticResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding ReasoningEffort}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{StaticResource Gx}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{StaticResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=EffortMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{StaticResource Bg3}" BorderBrush="{StaticResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="160">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7" Text="{StaticResource L.ReasoningEffort}"/>
                                                                <ItemsControl ItemsSource="{Binding EffortOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="EffortOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="ei" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="ei" Property="Background" Value="{StaticResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <Button DockPanel.Dock="Right" Width="32" Height="32" Cursor="Hand" Foreground="White"
                                                        Margin="6,0,0,0" ToolTip="{StaticResource L.StopTip}"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                                                        Command="{Binding DataContext.StopCommand, ElementName=Root}">
                                                    <controls:IconView Icon="{StaticResource IconStop}" Filled="True" Width="14" Height="14"/>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="sb" Background="{StaticResource Err}" CornerRadius="7">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="sb" Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                                        Foreground="{StaticResource AccentText}" ToolTip="{StaticResource L.SendTip}"
                                                        Command="{Binding DataContext.SendCommand, ElementName=Root}">
                                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                                </Button>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0" Click="Dictate_Click"
                                                        ToolTip="{StaticResource L.DictateTip}">
                                                    <controls:IconView Icon="{StaticResource IconMic}" Width="15" Height="15"/>
                                                </Button>
                                                <TextBlock/>
                                            </DockPanel>
                                        </Border>
                                        <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding PendingImages}" Margin="13,0,13,4">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource AccentLine}" BorderThickness="1"
                                                            CornerRadius="10" Padding="8,3" Margin="0,2,6,2" ToolTip="{Binding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🖼" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                                       Foreground="{StaticResource Txt1}" MaxWidth="180"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            <Button Content="✕" FontSize="9" Margin="6,0,0,0" Padding="2,0"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                    Foreground="{StaticResource Txt2}" ToolTip="{StaticResource L.Remove}"
                                                                    Click="RemovePendingImage_Click"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid MinHeight="58">
                                            <TextBox x:Name="ComposerBox" Style="{StaticResource ComposerInput}" MinHeight="58" MaxHeight="160"
                                                     Padding="15,12,15,2"
                                                     VerticalContentAlignment="Top"
                                                     Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}"
                                                     KeyDown="Composer_KeyDown"
                                                     PreviewKeyDown="Composer_PreviewKeyDown"
                                                     TextChanged="ComposerBox_TextChanged"/>
                                            <TextBlock Margin="15,12,15,0" Foreground="{StaticResource Txt2}" IsHitTestVisible="False"
                                                       FontSize="13.5" LineHeight="20" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Draft}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{StaticResource L.MessagePrefix}"/><Run Text="{Binding Cli, Mode=OneWay}"/><Run Text="{StaticResource L.MessageSuffix}"/>
                                            </TextBlock>
                                            <Popup x:Name="ComposerSuggestionPopup"
                                                   IsOpen="{Binding DataContext.IsComposerSuggestionOpen, ElementName=Root}"
                                                   PlacementTarget="{Binding ElementName=ComposerBox}"
                                                   Placement="Top"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="False"
                                                   HorizontalOffset="10"
                                                   VerticalOffset="-5">
                                                <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Width="380" MaxHeight="250">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="3"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <!-- Header -->
                                                        <Border Grid.Row="0" Background="{StaticResource Bg3}" Padding="10,6" CornerRadius="8,8,0,0" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                                                            <TextBlock Text="{Binding DataContext.ComposerSuggestionHeader, ElementName=Root}" Foreground="{StaticResource Txt1}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource Mono}"/>
                                                        </Border>
                                                        <!-- Suggestions List -->
                                                        <ListBox Grid.Row="1" x:Name="SuggestionList"
                                                                 ItemsSource="{Binding DataContext.ComposerSuggestions, ElementName=Root}"
                                                                 SelectedItem="{Binding DataContext.SelectedComposerSuggestion, ElementName=Root}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 MouseDoubleClick="SuggestionList_DoubleClick"
                                                                 KeyDown="SuggestionList_KeyDown"
                                                                 MaxHeight="200" Padding="0,4">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Padding" Value="10,6"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource Bg3}"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsSelected" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDim}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,3,0"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Icon/Indicator based on type -->
                                                                        <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="📄"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Session">
                                                                                            <Setter Property="Text" Value="⚡"/>
                                                                                            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Command">
                                                                                            <Setter Property="Text" Value="⚙️"/>
                                                                                            <Setter Property="Foreground" Value="{StaticResource Info}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <!-- Label -->
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{StaticResource Txt0}" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource Mono}"/>
                                                                        <!-- Type Text -->
                                                                        <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="{StaticResource Txt2}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="{StaticResource Mono}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Grid>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DockPanel>
                                </Border>
                                <DockPanel Margin="4,6,4,0" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="9.5">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.EnterHint}" Foreground="{StaticResource Txt3}"/>
                                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Txt3}">
                                        <Run Text="{Binding Cli, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Branch, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- transcript -->
                        <!-- 가상화 필수: 긴 트랜스크립트(CLI 가져오기 수백 블록)에서 보이는 항목만 생성한다.
                             가상화가 동작하려면 ScrollViewer가 ItemsControl 템플릿 안에 있어야 함 -->
                        <ItemsControl x:Name="TranscriptList" ItemsSource="{Binding Transcript}"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel"
                                      PreviewMouseWheel="TranscriptScroll_PreviewMouseWheel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer x:Name="PART_TranscriptScroll" VerticalScrollBarVisibility="Auto" Focusable="False">
                                        <!-- 전폭 사용: 중앙 880px 캡 대신 좌우 최소 여백 (사용자 요청) -->
                                        <ItemsPresenter Margin="14,16,14,12"/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                    </DockPanel>
                </Grid>

                <!-- Orchestrator View -->
                <Grid DataContext="{Binding DataContext, ElementName=Root}"
                      Visibility="{Binding IsOrchestratorView, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource Bg0}">
                    <Grid.Resources>
                        <!-- Spark Animation (5 staggered bars equalizer style scale) -->
                        <Storyboard x:Key="SparkStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.13">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar3" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.26">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar4" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.39">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar5" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.52">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>

                        <!-- shared orchestrator session card (live + recent) -->
                        <DataTemplate x:Key="OrchCardTemplate">
                            <Border Width="236" Margin="0,0,12,12" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLive}" Value="False">
                                                <Setter Property="Opacity" Value="0.72"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="SparkAnimation" Storyboard="{StaticResource SparkStoryboard}"/>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="SparkAnimation"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel LastChildFill="True">
                                    <!-- Head -->
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                            <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Margin="0,0,5,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Txt3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Foreground" Value="{StaticResource Accent}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Foreground" Value="{StaticResource Warn}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Foreground" Value="{StaticResource Ok}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Foreground" Value="{StaticResource Err}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Ellipse Width="7" Height="7" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{StaticResource Accent}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AgentName}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                            <TextBlock Text="{Binding Model}" FontSize="9" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Foot -->
                                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TokensLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4"
                                                Command="{Binding DataContext.SelectSessionCommand, ElementName=Root}" CommandParameter="{Binding}" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{StaticResource L.OpenSessionBtn}" FontSize="10" VerticalAlignment="Center"/>
                                                <controls:IconView Icon="{StaticResource IconChevRight}" Width="11" Height="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4" Margin="0,0,6,0" Click="OrchCardDiff_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:IconView Icon="{StaticResource IconLayers}" Width="10" Height="10" Foreground="{StaticResource Txt1}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{StaticResource L.OrchDiff}" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>

                                    <!-- Body -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <controls:IconView Icon="{StaticResource IconBranch}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BranchTail}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RunningElapsedLabel}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Accent}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="9" Margin="0,0,8,0">
                                                <Border x:Name="Bar1" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar2" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar3" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar4" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar5" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Accent}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiff}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Border Height="5" CornerRadius="2.5" Background="{StaticResource Bg4}" Margin="0,6,0,4" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding DiffAddedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemovedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemainderStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource Add}"/>
                                                    <Border Grid.Column="1" Background="{StaticResource Del}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="10">
                                                <Run Text="+" Foreground="{StaticResource Add}"/><Run Text="{Binding DiffAdded, Mode=OneWay}" Foreground="{StaticResource Add}"/>
                                                <Run Text=" "/>
                                                <Run Text="−" Foreground="{StaticResource Del}"/><Run Text="{Binding DiffRemoved, Mode=OneWay}" Foreground="{StaticResource Del}"/>
                                                <Run Text=" · " Foreground="{StaticResource Txt2}"/>
                                                <Run Text="{Binding DiffFiles, Mode=OneWay}" Foreground="{StaticResource Txt2}"/>
                                                <Run Text=" " Foreground="{StaticResource Txt2}"/>
                                                <Run Text="{Binding FilesSuffix, Mode=OneWay}" Foreground="{StaticResource Txt2}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </Grid.Resources>
                    <DockPanel LastChildFill="True">
                        <!-- Head -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel LastChildFill="False">
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconGrid}" Width="16" Height="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Orchestrator}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <Run Text="· "/><Run Text="{StaticResource L.OrchSubtitle}"/></TextBlock>
                                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Command="{Binding NewAgentCommand}" VerticalAlignment="Center" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11" Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.NewAgent}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>

                        <!-- Scrollable view -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16" HorizontalAlignment="Stretch">
                                <!-- KPIs -->
                                <UniformGrid Columns="5" Rows="1" Height="78" Margin="0,0,0,22">
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiActive}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding RunningCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiActiveSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiAwaiting}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Warn}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding WaitingCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiAwaitingSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiCompleted}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Ok}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding DoneCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiCompletedSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFailed}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Err}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding FailedCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiFailedSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource AccentLine}" BorderThickness="1" CornerRadius="6" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFleet}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Txt1}" Margin="0,0,0,3" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FleetThroughputLabel}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                <TextBlock Text="{StaticResource L.KpiFleetSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- Live workers -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.LiveWorkers}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ActiveSessions.Count}" Style="{StaticResource CodeChip}"/>
                                    <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyLive}" FontSize="11" Foreground="{StaticResource Txt3}" Margin="2,0,0,12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ActiveSessions}" ItemTemplate="{StaticResource OrchCardTemplate}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- Recent &amp; completed -->
                                <DockPanel Margin="0,8,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.RecentCompleted}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ProjectSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                    <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyRecent}" FontSize="11" Foreground="{StaticResource Txt3}" Margin="2,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProjectSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ProjectSessions}" ItemTemplate="{StaticResource OrchCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>

                <!-- Activity History View -->
                <Grid DataContext="{Binding DataContext, ElementName=Root}"
                      Visibility="{Binding IsHistoryView, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource Bg0}">
                    <DockPanel LastChildFill="True">
                        <!-- Head -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{StaticResource L.ActivityHistoryHeader}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt1}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding HistorySummaryText}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>

                                <!-- Status Filter -->
                                <ComboBox Grid.Column="3" SelectedValue="{Binding HistoryStatusFilter, Mode=TwoWay}" SelectedValuePath="Tag" Height="28" VerticalAlignment="Center">
                                    <ComboBoxItem Content="{StaticResource L.FilterAll}" Tag="all"/>
                                    <ComboBoxItem Content="{StaticResource L.FilterActive}" Tag="active"/>
                                    <ComboBoxItem Content="{StaticResource L.Waiting}" Tag="waiting"/>
                                    <ComboBoxItem Content="{StaticResource L.Done}" Tag="done"/>
                                    <ComboBoxItem Content="Failed" Tag="error"/>
                                </ComboBox>

                                <!-- Agent Filter -->
                                <ComboBox Grid.Column="5" SelectedValue="{Binding HistoryAgentFilter, Mode=TwoWay}" SelectedValuePath="Tag" Height="28" VerticalAlignment="Center">
                                    <ComboBoxItem Content="{StaticResource L.FilterAllAgents}" Tag="all"/>
                                    <ComboBoxItem Content="Claude Code" Tag="cc"/>
                                    <ComboBoxItem Content="Codex" Tag="gx"/>
                                    <ComboBoxItem Content="Gemini" Tag="ag"/>
                                    <ComboBoxItem Content="Antigravity" Tag="agy"/>
                                </ComboBox>

                                <!-- Search -->
                                <Border Grid.Column="7" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="7" Height="28" VerticalAlignment="Center" Padding="6,0,8,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:IconView Grid.Column="0" Icon="{StaticResource IconSearch}" Width="12" Height="12" Foreground="{StaticResource Txt2}" Margin="4,0,6,0" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Style="{StaticResource ComposerInput}" Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Center" AcceptsReturn="False" TextWrapping="NoWrap" Text="{Binding HistoryFilterText, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Bottom status / filter summary bar -->
                        <Border DockPanel.Dock="Bottom" Height="36" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="14,0">
                            <DockPanel VerticalAlignment="Center">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding HistoryFilterSummaryText}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Txt3}" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Refresh}" Command="{Binding RefreshHistoryCommand}"/>
                            </DockPanel>
                        </Border>

                        <!-- Content List -->
                        <ListView ItemsSource="{Binding HistoryRows}" Background="Transparent" BorderThickness="0" SelectionMode="Single" ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" Padding="8" Grid.IsSharedSizeScope="True">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" CornerRadius="6" Padding="12,10" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="HistoryRow_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource LineSoft}"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="34"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="TimeCol"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="TokensCol"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Dot LED-like with Glow -->
                                            <Grid Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center" HorizontalAlignment="Left" ToolTip="{Binding StatusLabel}">
                                                <!-- Outer Glow Ring -->
                                                <Ellipse Width="12" Height="12" Opacity="0.15">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{StaticResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <!-- Inner Solid Dot -->
                                                <Ellipse Width="6" Height="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Fill" Value="{StaticResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>

                                            <!-- Engine Badge with Brand Icon -->
                                            <Border Grid.Column="1" Width="24" Height="24" CornerRadius="5" Background="{StaticResource Bg0}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Left" ToolTip="{Binding AgentName}">
                                                <controls:IconView Style="{StaticResource EngineIcon}" Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Main Text Block -->
                                            <StackPanel Grid.Column="2" Margin="8,0,16,0" VerticalAlignment="Center">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Right" Background="{StaticResource Bg3}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="6,2" Margin="8,0,0,0" Visibility="{Binding IsArchived, Converter={StaticResource BoolVis}}">
                                                        <TextBlock Text="{StaticResource L.ArchivedBadge}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{StaticResource Txt2}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt3}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                    <Run Text="{Binding Project, Mode=OneWay}" Foreground="{StaticResource Txt2}"/><Run Text=" / "/><Run Text="{Binding Branch, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Stacked Time & Blocks metadata column -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,16,0" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding StartedText}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt1}"/>
                                                <TextBlock Text="{Binding BlocksText}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Stacked Tokens & Cost metadata column -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="0,0,8,0" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TokensText}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt1}"/>
                                                <TextBlock Text="{Binding CostText}" FontFamily="{StaticResource Mono}" FontSize="9.5" Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Ok}"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="Text" Value="-">
                                                                    <Setter Property="Foreground" Value="{StaticResource Txt2}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </Grid>

                <!-- Scheduled Tasks View -->
                <Grid DataContext="{Binding DataContext, ElementName=Root}"
                      Visibility="{Binding IsScheduledView, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource Bg0}">
                    <DockPanel LastChildFill="True">
                        <!-- Head -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel LastChildFill="False">
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconCalendar}" Width="15" Height="15" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.ScheduledTasks}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <Run Text="· "/><Run Text="{Binding ScheduledJobs.Count, Mode=OneWay}"/><Run Text=" "/><Run Text="{StaticResource L.SchedJobsSuffix}"/></TextBlock>
                                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Command="{Binding NewScheduleCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconPlus}" Width="13" Height="13"
                                                           Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.NewSchedule}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>

                        <!-- Scrollable view -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16" HorizontalAlignment="Stretch">
                                <ItemsControl ItemsSource="{Binding ScheduledJobs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="150"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon -->
                                                    <controls:IconView Grid.Column="0" Icon="{StaticResource IconCalendar}" Width="16" Height="16" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                                    <!-- Main Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" Margin="0,0,0,4"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="24" Height="20" CornerRadius="4" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding EngineBadge}" FontFamily="{StaticResource Mono}" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Txt1}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding EngineName}" FontSize="11" Foreground="{StaticResource Txt1}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                            
                                                            <controls:IconView Icon="{StaticResource IconRefresh}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding CadenceText}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                                            <controls:IconView Icon="{StaticResource IconBranch}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding TargetBranch}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Next run -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <TextBlock Text="{StaticResource L.SchedNextRun}" FontSize="9.5" Foreground="{StaticResource Txt2}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding NextRunLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Accent}" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>

                <!-- ===================== Settings (full center pane) ===================== -->
                <Grid DataContext="{Binding DataContext, ElementName=Root}"
                      Visibility="{Binding IsSettingsView, Converter={StaticResource BoolVis}}"
                      Background="{StaticResource Bg0}">
                    <DockPanel LastChildFill="True">
                        <!-- header -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel>
                                <controls:IconView Icon="{StaticResource IconSettings}" Width="16" Height="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{StaticResource L.SettingsSubtitle}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource L.SettingsWorkspace}" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30" Command="{Binding CancelSettingsCommand}" ToolTip="{StaticResource L.CloseTip}">
                                    <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                                </Button>
                            </DockPanel>
                        </Border>
                        <!-- footer -->
                        <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="16,12">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelSettingsCommand}"/>
                                    <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.SaveSettings}" Command="{Binding SaveSettingsCommand}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SettingsStatus}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Ok}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- body: TOC + sections -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="168"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="16,18,4,0" TextElement.FontSize="11.5">
                                <TextBlock Text="{StaticResource L.SecRuntimes}" Tag="SecRuntimes" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecTranslation}" Tag="SecTranslation" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecOrchestration}" Tag="SecOrchestration" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecPermissions}" Tag="SecPermissions" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecAppearance}" Tag="SecAppearance" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecProject}" Tag="SecProject" MouseLeftButtonUp="SettingsToc_Click" Foreground="{StaticResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                            </StackPanel>

                            <ScrollViewer Grid.Column="1" x:Name="SettingsScroll" VerticalScrollBarVisibility="Auto" Padding="6,0,0,0">
                                <StackPanel Margin="14,18,18,18" MaxWidth="720" HorizontalAlignment="Left">
                                    <!-- 01 Runtimes -->
                                    <StackPanel x:Name="SecRuntimes">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="01" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecRuntimes}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <!-- Claude (cc) -->
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="5" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,10,0">
                                                        <TextBlock Text="CC" FontFamily="{StaticResource Mono}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineCc, Mode=TwoWay}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ClaudeDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding ClaudeDetectLabel}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Claude Code" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                        <TextBlock Text="claude · anthropic · cli" FontSize="10" Foreground="{StaticResource Txt2}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.ClaudeCliPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding SettingsClaudePath, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.DefaultModel}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                <ComboBox ItemsSource="{Binding CcModels}" SelectedItem="{Binding SettingsModelCc, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="240"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Tag="cc" Click="EngineSignIn_Click" Content="{StaticResource L.SignIn}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{StaticResource L.AuthCliManaged}" FontSize="9.5" Foreground="{StaticResource Txt3}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                        <!-- Codex (gx) -->
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="5" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,10,0">
                                                        <TextBlock Text="GX" FontFamily="{StaticResource Mono}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gx}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineGx, Mode=TwoWay}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding CodexDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding CodexDetectLabel}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="GPT / Codex" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                        <TextBlock Text="codex · openai · cli" FontSize="10" Foreground="{StaticResource Txt2}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.CodexCliPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding SettingsCodexPath, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.DefaultModel}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                <ComboBox ItemsSource="{Binding GxModels}" SelectedItem="{Binding SettingsModelGx, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="240"/>
                                                <DockPanel Margin="0,8,0,0">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Tag="gx" Click="EngineSignIn_Click" Content="{StaticResource L.SignIn}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{StaticResource L.AuthCliManaged}" FontSize="9.5" Foreground="{StaticResource Txt3}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                        <!-- Gemini (ag) + Antigravity (agy) auto-detect -->
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="5" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                                            <TextBlock Text="AG" FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Info}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineAg, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Gemini CLI" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding GeminiDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding GeminiDetectLabel}"/>
                                                    <ComboBox ItemsSource="{Binding AgModels}" SelectedItem="{Binding SettingsModelAg, Mode=TwoWay}" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                                                    <Button Style="{StaticResource ChipButton}" Tag="ag" Click="EngineSignIn_Click" Content="{StaticResource L.SignIn}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="5" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                                            <TextBlock Text="AGY" FontFamily="{StaticResource Mono}" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Agy}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineAgy, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Antigravity" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding AgyDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding AgyDetectLabel}"/>
                                                    <ComboBox ItemsSource="{Binding AgyModels}" SelectedItem="{Binding SettingsModelAgy, Mode=TwoWay}" Margin="0,8,0,0" HorizontalAlignment="Stretch"/>
                                                    <Button Style="{StaticResource ChipButton}" Tag="agy" Click="EngineSignIn_Click" Content="{StaticResource L.SignIn}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- 02 Translation (ours) -->
                                    <StackPanel x:Name="SecTranslation" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="02" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecTranslation}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="220"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{StaticResource L.Endpoint}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding SettingsOllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{StaticResource L.StatusModel}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding SettingsOllamaModel, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,10,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsDefaultTranslationEnabled, Mode=TwoWay}" Content="{StaticResource L.DefaultTranslation}" ToolTip="{StaticResource L.DefaultTranslationTip}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 03 Orchestration -->
                                    <StackPanel x:Name="SecOrchestration" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="03" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecOrchestration}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.ConcurrentLimit}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Width="120" HorizontalAlignment="Left" Text="{Binding MaxConcurrentSessions, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,12,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsWarnNoWorktree, Mode=TwoWay}" Content="{StaticResource L.NonGitNotice}" ToolTip="{StaticResource L.NonGitNoticeTip}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.WorktreeBase}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding SettingsWorktreeBase, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.WorktreeBaseHint}" FontSize="9.5" Foreground="{StaticResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <ToggleButton Style="{StaticResource TogglePillButton}" IsChecked="{Binding SettingsAutoStart, Mode=TwoWay}" Content="{StaticResource L.AutoStartLast}"/>
                                                    <ToggleButton Style="{StaticResource TogglePillButton}" Margin="8,0,0,0" IsChecked="{Binding SettingsStreamLogs, Mode=TwoWay}" Content="{StaticResource L.StreamLogsToggle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 04 Permissions -->
                                    <StackPanel x:Name="SecPermissions" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="04" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecPermissions}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.ApprovalPolicyTitle}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.ApprovalPolicyDesc}" FontSize="10.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,10" TextWrapping="Wrap"/>
                                                <!-- ask -->
                                                <Border Tag="ask" MouseLeftButtonUp="ApprovalPolicy_Click" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9" Margin="0,0,0,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="ask">
                                                                    <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicyAsk}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicyAskSub}" FontSize="10" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- safe -->
                                                <Border Tag="safe" MouseLeftButtonUp="ApprovalPolicy_Click" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9" Margin="0,0,0,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="safe">
                                                                    <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicySafe}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicySafeSub}" FontSize="10" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- yolo -->
                                                <Border Tag="yolo" MouseLeftButtonUp="ApprovalPolicy_Click" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="yolo">
                                                                    <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Warn}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicyYolo}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicyYoloSub}" FontSize="10" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{StaticResource L.PermNetworkNote}" FontSize="9.5" Foreground="{StaticResource Txt3}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 05 Appearance -->
                                    <StackPanel x:Name="SecAppearance" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="05" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecAppearance}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton Style="{StaticResource TogglePillButton}" IsChecked="{Binding SettingsLightTheme, Mode=TwoWay}" Content="{StaticResource L.LightTheme}" ToolTip="{StaticResource L.LightThemeTip}"/>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="8,0,0,0" IsChecked="{Binding SettingsEnglishUi, Mode=TwoWay}" Content="{StaticResource L.EnglishUi}" ToolTip="{StaticResource L.EnglishUiTip}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <!-- Accent color -->
                                                <TextBlock Text="{StaticResource L.AccentColor}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.AccentColorDesc}" FontSize="10.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,10"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Resources>
                                                        <Style TargetType="Border" x:Key="Swatch">
                                                            <Setter Property="Width" Value="26"/>
                                                            <Setter Property="Height" Value="26"/>
                                                            <Setter Property="CornerRadius" Value="13"/>
                                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding SettingsAccent}" Value="ember"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="ember"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Txt0}"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding SettingsAccent}" Value="amber"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="amber"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Txt0}"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding SettingsAccent}" Value="teal"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="teal"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Txt0}"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding SettingsAccent}" Value="azure"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="azure"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Txt0}"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding SettingsAccent}" Value="violet"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="violet"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Txt0}"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Resources>
                                                    <Border Style="{StaticResource Swatch}" Background="#FFFF5A2C" Tag="ember" MouseLeftButtonUp="AccentSwatch_Click" ToolTip="Ember"/>
                                                    <Border Style="{StaticResource Swatch}" Background="#FFF5B531" Tag="amber" MouseLeftButtonUp="AccentSwatch_Click" ToolTip="Amber"/>
                                                    <Border Style="{StaticResource Swatch}" Background="#FF2BD4C4" Tag="teal" MouseLeftButtonUp="AccentSwatch_Click" ToolTip="Teal"/>
                                                    <Border Style="{StaticResource Swatch}" Background="#FF5B8CFF" Tag="azure" MouseLeftButtonUp="AccentSwatch_Click" ToolTip="Azure"/>
                                                    <Border Style="{StaticResource Swatch}" Background="#FFA87BFF" Tag="violet" MouseLeftButtonUp="AccentSwatch_Click" ToolTip="Violet"/>
                                                </StackPanel>
                                                <!-- Density -->
                                                <TextBlock Text="{StaticResource L.Density}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" Margin="0,16,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Tag="comfortable" MouseLeftButtonUp="DensitySeg_Click" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="14,7" Margin="0,0,8,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SettingsDensity}" Value="comfortable">
                                                                        <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.DensityComfortable}" FontSize="11.5" Foreground="{StaticResource Txt0}"/>
                                                    </Border>
                                                    <Border Tag="compact" MouseLeftButtonUp="DensitySeg_Click" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="14,7">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SettingsDensity}" Value="compact">
                                                                        <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.DensityCompact}" FontSize="11.5" Foreground="{StaticResource Txt0}"/>
                                                    </Border>
                                                </StackPanel>
                                                <!-- Telemetry -->
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,16,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsTelemetry, Mode=TwoWay}" Content="{StaticResource L.Telemetry}"/>
                                                <TextBlock Text="{StaticResource L.TelemetryDesc}" FontSize="9.5" Foreground="{StaticResource Txt3}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 06 Project (ours) -->
                                    <StackPanel x:Name="SecProject" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="06" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecProject}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.McpConfigPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10" BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False" Text="{Binding ActiveProject.McpConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <DockPanel Margin="0,14,0,0">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" ToolTip="{StaticResource L.AddExtraPathTip}" Click="AddExtraPath_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{StaticResource L.AddFolder}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <TextBlock Text="{StaticResource L.ExtraFolders}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding ActiveProject.ExtraPaths}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="26" ToolTip="{StaticResource L.Remove}" Command="{Binding DataContext.RemoveExtraPathCommand, ElementName=Root}" CommandParameter="{Binding}">
                                                                    <controls:IconView Icon="{StaticResource IconX}" Width="10" Height="10"/>
                                                                </Button>
                                                                <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,6" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{StaticResource Txt1}" TextTrimming="CharacterEllipsis"/>
                                                                </Border>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- Review pane -->
            <Border Grid.Column="2" DataContext="{Binding ActiveSession}" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineSoft}" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                        <DockPanel Margin="14,0">
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.DiffReview}" Style="{StaticResource Lbl}" Foreground="{StaticResource Txt0}"
                                       VerticalAlignment="Center" Margin="0,0,9,0"/>
                            <TextBlock Text="{Binding ReviewStatus}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                       Foreground="{StaticResource Txt2}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.CloseTip}"
                                    Command="{Binding DataContext.ToggleReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="30"
                                    ToolTip="{StaticResource L.RefreshChangesTip}"
                                    Command="{Binding DataContext.RefreshReviewCommand, ElementName=Root}">
                                <controls:IconView Icon="{StaticResource IconRefresh}" Width="13" Height="13"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="12,10">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Changes}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Changes.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ListBox x:Name="ReviewChangesList" ItemsSource="{Binding Changes}" SelectedItem="{Binding SelectedChange, Mode=TwoWay}"
                                     SelectionChanged="ReviewChanges_SelectionChanged"
                                     Background="Transparent" BorderThickness="0" MaxHeight="190"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="row" Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg3}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="row" Property="Background" Value="{StaticResource Bg4}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="8,7">
                                            <Border DockPanel.Dock="Left" Width="24" Height="22" CornerRadius="4"
                                                    Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding KindLabel}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                           Foreground="{StaticResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatLabel}" FontFamily="{StaticResource Mono}"
                                                       FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Path}" FontFamily="{StaticResource Mono}" FontSize="11"
                                                       Foreground="{StaticResource Txt0}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <DockPanel Margin="0,14,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Artifacts}" Style="{StaticResource Lbl}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Artifacts.Count}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}"/>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding Artifacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Background="{StaticResource Bg1}" BorderThickness="1" CornerRadius="7">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource Err}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <DockPanel Margin="9,7,9,5">
                                                    <Border DockPanel.Dock="Left" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                            CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Kind}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Accent}"/>
                                                    </Border>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdatedAt, StringFormat={}{0:HH:mm:ss}}"
                                                               FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt3}"/>
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource Txt0}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="9,7" MaxHeight="120">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBlock Text="{Binding Content}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                                   Foreground="{StaticResource Txt1}" TextWrapping="Wrap"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{StaticResource L.NoArtifacts}" FontFamily="{StaticResource Mono}" FontSize="10"
                                       Foreground="{StaticResource Txt3}" Margin="2,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Artifacts.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                        Foreground="{StaticResource AccentText}" Margin="8,0,0,0"
                                        Command="{Binding DataContext.SendDiffFeedbackCommand, ElementName=Root}"
                                        CommandParameter="{Binding Text, ElementName=DiffFeedbackBox}"
                                        Click="DiffFeedbackSend_Click">
                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                </Button>
                                <TextBox x:Name="DiffFeedbackBox" Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" Padding="9"
                                         AcceptsReturn="False" MinHeight="32"
                                         TextWrapping="NoWrap" ToolTip="{StaticResource L.FeedbackPlaceholder}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource AccentButton}" Content="{StaticResource L.MergeMain}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.MergeMainTip}"
                                        Command="{Binding DataContext.MergeReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Content="{StaticResource L.CommitOnly}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.CommitReviewCommand, ElementName=Root}"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Discard}"
                                        ToolTip="{StaticResource L.DiscardTip}"
                                        Command="{Binding DataContext.DiscardReviewCommand, ElementName=Root}"/>
                            </DockPanel>
                        </Border>
                        <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Padding="12,10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Worktree}" Style="{StaticResource Lbl}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding WorktreeLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                    <DockPanel>
                        <Border DockPanel.Dock="Top" Height="32" Background="{StaticResource Bg1}"
                                BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="12,0">
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Diff}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedChange.Path}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="270"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <controls:DiffViewer Text="{Binding DiffText}"/>
                        </ScrollViewer>
                    </DockPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===================== New-schedule overlay ===================== -->
        <Grid Grid.RowSpan="2" Background="#9E05080B" Visibility="{Binding ShowNewSchedule, Converter={StaticResource BoolVis}}">
            <Border Width="620" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.NewSchedule}" Style="{StaticResource Lbl}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Command="{Binding CancelNewScheduleCommand}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="{StaticResource L.SchedCreateTitle}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <StackPanel Margin="18">
                        <TextBlock Text="{StaticResource L.Task}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                 Text="{Binding NewScheduleTitle, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.SchedPrompt}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                 BorderBrush="{StaticResource Line}" BorderThickness="1" MinHeight="78"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding NewSchedulePrompt, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{StaticResource L.Runtime}" Style="{StaticResource Lbl}" Margin="0,14,0,8"/>
                        <ListBox ItemsSource="{Binding Engines}" SelectedItem="{Binding NewScheduleSelectedEngine, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,8,0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="rt" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                        CornerRadius="7" Padding="10" Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{StaticResource LineBright}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="rt" Property="BorderBrush" Value="{StaticResource AccentLine}"/>
                                                        <Setter TargetName="rt" Property="Background" Value="{StaticResource AccentDim}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Badge}" FontFamily="{StaticResource Mono}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Cli}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Txt2}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{StaticResource L.SchedCadence}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                         Text="{Binding NewScheduleCadence, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="{StaticResource L.SchedCadenceHint}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                           Foreground="{StaticResource Txt3}" Margin="2,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{StaticResource L.SchedTargetBranch}" Style="{StaticResource Lbl}" Margin="0,0,0,8"/>
                                <TextBox Style="{StaticResource ComposerInput}" Background="{StaticResource Bg1}" Padding="10"
                                         BorderBrush="{StaticResource Line}" BorderThickness="1" AcceptsReturn="False"
                                         Text="{Binding NewScheduleTargetBranch, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding NewScheduleError}" FontFamily="{StaticResource Mono}" FontSize="10"
                                   Foreground="{StaticResource Err}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,1,0,0" Background="{StaticResource Bg1}" Padding="18,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelNewScheduleCommand}"/>
                            <Button Style="{StaticResource AccentButton}" Command="{Binding CreateScheduleCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconView Icon="{StaticResource IconCalendar}" Width="13" Height="13"
                                                       Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{StaticResource L.SaveSchedule}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== About / keyboard shortcuts overlay ===================== -->
        <Grid x:Name="AboutOverlay" Grid.RowSpan="2" Background="#9E05080B" Visibility="Collapsed"
              MouseLeftButtonUp="AboutOverlay_BackdropClick">
            <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{StaticResource Bg2}"
                    BorderBrush="{StaticResource LineBright}" BorderThickness="1" CornerRadius="10"
                    MouseLeftButtonUp="AboutOverlay_CardClick">
                <StackPanel>
                    <Border BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="18,15">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.AboutTitle}" Style="{StaticResource Lbl}"
                                       Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Click="CloseAbout_Click"
                                    ToolTip="{StaticResource L.CloseTip}">
                                <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13"/>
                            </Button>
                            <TextBlock Text="AgentManager" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
