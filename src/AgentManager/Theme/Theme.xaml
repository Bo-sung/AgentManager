<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 색 토큰은 Colors.Dark.xaml / Colors.Light.xaml로 분리 — App 시작 시 테마 설정에 따라
         Theme.xaml보다 먼저 머지된다 (StaticResource가 그 팔레트를 캡처). -->

    <CornerRadius x:Key="RSm">4</CornerRadius>
    <CornerRadius x:Key="RMd">7</CornerRadius>
    <CornerRadius x:Key="RLg">10</CornerRadius>

    <!-- ===== 오버레이/모달 진입 애니메이션 (원본 @keyframes fade .15s / rise .2s ease) =====
         backdrop = OverlayFadeIn(불투명 0→1), card = OverlayRiseIn(Y 10→0 + 0→1, EaseOut).
         각 요소 자신을 타깃(TargetName 없음) → 요소의 Style.DataTrigger EnterActions에서 시작. -->
    <Storyboard x:Key="OverlayFadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
    </Storyboard>
    <Storyboard x:Key="OverlayRiseIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                         From="10" To="0" Duration="0:0:0.2">
            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 원본 타이포그래피 재현: 번들된 IBM Plex (Latin). 한글 등 미포함 글리프는 WPF 폰트
         폴백이 시스템 폰트(Malgun Gothic 등)로 자동 처리한다(원본도 IBM Plex는 Latin 전용). -->
    <FontFamily x:Key="Sans">pack://application:,,,/Resources/Fonts/#IBM Plex Sans</FontFamily>
    <FontFamily x:Key="Mono">pack://application:,,,/Resources/Fonts/#IBM Plex Mono</FontFamily>

    <!-- ===== Dark ToolTip (기본 흰 배경 → 테마 색) ===== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Bg4}"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineBright}"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}" Margin="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="#FF000000"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Dark ContextMenu / MenuItem (우클릭 메뉴, 타이틀바 드롭다운) ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource Bg3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineBright}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="7" Padding="5" Margin="6">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                        </Border.Effect>
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="10,7">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="{TemplateBinding InputGestureText}"
                                       FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}"
                                       Margin="18,0,0,0" VerticalAlignment="Center"/>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Bg4}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Txt3}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{DynamicResource LineSoft}" Margin="6,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 메뉴 안의 Separator는 암시 스타일이 아니라 이 전용 키로 조회된다 (기본은 밝은 시스템 색 = 흰 줄) -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{DynamicResource LineSoft}" Margin="6,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Base text ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="Lbl" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- ===== Accent "New Agent" button ===== -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentBright}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Ghost / chip button ===== -->
    <!-- 트랜스크립트 본문용: 선택/복사 가능한 읽기전용 텍스트 (TextBlock 대체) -->
    <Style x:Key="SelectableText" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="SelectionBrush" Value="#3DFF5A2C"/>
        <Setter Property="Cursor" Value="IBeam"/>
    </Style>

    <!-- 다크 테마 체크박스(키 지정 — 전역 영향 없음). pi 모델 체크리스트용. -->
    <Style x:Key="ModelCheck" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="box" Width="14" Height="14" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,7,0"
                                Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1">
                            <Path x:Name="chk" Data="M3 7 L6 10 L11 4" Stroke="White" StrokeThickness="1.7"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{DynamicResource Accent}"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Bg3}"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource Line}"
                            BorderThickness="1" CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TogglePillButton" TargetType="ToggleButton">
        <Setter Property="Height" Value="24"/>
        <Setter Property="Background" Value="{DynamicResource Bg1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="9,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="b" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentDim}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Titlebar menu button ===== -->
    <Style x:Key="MenuButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="9,3"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg3}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Send button (accent square) ===== -->
    <Style x:Key="SendButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Accent}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7" Width="32" Height="32">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentBright}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg4}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Composer controls ===== -->
    <Style x:Key="ComposerIconButton" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Width="30" Height="30" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg4}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeaderIconButton" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg3}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComposerPill" TargetType="Border">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="{DynamicResource Bg1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="10,0"/>
    </Style>

    <!-- ===== Composer textbox ===== -->
    <Style x:Key="ComposerInput" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="Padding" Value="13,11"/>
    </Style>

    <!-- 설정/입력용 단일행 TextBox (ComposerInput 기반 + Bg1 배경·테두리). 반복되던 인라인 속성을 통합. -->
    <Style x:Key="SettingsInput" TargetType="TextBox" BasedOn="{StaticResource ComposerInput}">
        <Setter Property="Background" Value="{DynamicResource Bg1}"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="AcceptsReturn" Value="False"/>
    </Style>

    <!-- API 키 입력용 마스킹 PasswordBox (주변 ComposerInput TextBox와 외형 일치) -->
    <Style x:Key="ApiKeyBox" TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource Bg1}"/>
        <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource Sans}"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ===== Dark scrollbar (thin, rounded thumb — matches the design CSS) ===== -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="tb" Background="{DynamicResource Bg4}" CornerRadius="4"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tb" Property="Background" Value="{DynamicResource Bg5}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumb}" Margin="2,0"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumb}" Margin="0,2"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== Dark ComboBox ===== -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg4}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="tg" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}"
                                            BorderThickness="1" CornerRadius="12" Padding="10,0,24,0">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <ContentPresenter x:Name="cp" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="0"/>
                        </ToggleButton>
                        <!-- IsEditable=True 일 때만 보이는 편집 텍스트박스(WPF 필수 파트). 위에 올려 타이핑/선택 표시 처리 -->
                        <TextBox x:Name="PART_EditableTextBox" Visibility="Collapsed" Background="Transparent"
                                 Foreground="{DynamicResource Txt0}" CaretBrush="{DynamicResource Txt0}" BorderThickness="0"
                                 Padding="0" Margin="10,0,26,0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>
                        <Path Data="M0,0 L4,4 L8,0" Stroke="{DynamicResource Txt2}" StrokeThickness="1.4"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,10,0" IsHitTestVisible="False"/>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" StaysOpen="False"
                               AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                    CornerRadius="7" Padding="4" Margin="0,4,8,8" MinWidth="{TemplateBinding ActualWidth}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                </Border.Effect>
                                <ScrollViewer MaxHeight="220">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="cp" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== HUD primitives (design .ticks / .code-chip) ===== -->
    <!-- Decorative corner ticks: drop as an overlay child inside a Grid; non-interactive. -->
    <Style x:Key="HudTicks" TargetType="Control">
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Grid Margin="3">
                        <Border Width="6" Height="6" HorizontalAlignment="Left" VerticalAlignment="Top"
                                BorderBrush="{DynamicResource LineBright}" BorderThickness="1,1,0,0"/>
                        <Border Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                BorderBrush="{DynamicResource LineBright}" BorderThickness="0,0,1,1"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Mono accent code chip (design .code-chip) -->
    <Style x:Key="CodeChip" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Mono}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
