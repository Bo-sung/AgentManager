<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:AgentManager.Controls">

    <Style TargetType="{x:Type c:IconView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:IconView}">
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="P" Data="{TemplateBinding Icon}"
                                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Filled" Value="True">
                            <Setter TargetName="P" Property="Fill"
                                    Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="P" Property="Stroke" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Icon set extracted 1:1 from design/am-data.jsx (24x24 viewBox, stroke 1.6, round caps/joins) ===== -->
    <!-- Use with Controls/IconView: <c:IconView Icon="{StaticResource IconPanel}"/> (Foreground = stroke color) -->

    <PathGeometry x:Key="IconPlus" Figures="M12 5v14M5 12h14"/>

    <GeometryGroup x:Key="IconHistory">
        <PathGeometry Figures="M3 12a9 9 0 1 0 3-6.7L3 8"/>
