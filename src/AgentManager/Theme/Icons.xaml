<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:AgentManager.Controls">

    <!-- 엔진 브랜드 색(고정) — 강조색/테마 변경과 무관하게 모델 아이콘 색을 유지한다 -->
    <SolidColorBrush x:Key="CcBrand" Color="#FFFF5A2C"/>
    <SolidColorBrush x:Key="GxBrand" Color="#FF8B5CF6"/>
    <!-- Antigravity 공식 CI 무지개(파랑→초록→빨강→주황) -->
    <LinearGradientBrush x:Key="AgyGradient" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#FF4285F4" Offset="0"/>
        <GradientStop Color="#FF34A853" Offset="0.4"/>
        <GradientStop Color="#FFEA4335" Offset="0.72"/>
        <GradientStop Color="#FFFB8C00" Offset="1"/>
    </LinearGradientBrush>
    <!-- pi(pi.dev)는 모노크롬 마크(흰색 on #09090b) → 강조색과 무관한 고정 zinc 라이트 -->
    <SolidColorBrush x:Key="PiBrand" Color="#FFE4E4E7"/>
    <!-- Antigravity 솔리드(고정 틸) — 작은 텍스트용. 아이콘/컴포저 하이라이트는 AgyGradient(무지개) 사용. -->
    <SolidColorBrush x:Key="AgyBrand" Color="#FF2BC5B4"/>
    <!-- 엔진 테두리/딤 고정 변형(강조색·테마 무관). 컴포저 외곽·엔진 알약용. -->
    <SolidColorBrush x:Key="CcBrandLine" Color="#66FF5A2C"/>
    <SolidColorBrush x:Key="CcBrandDim"  Color="#24FF5A2C"/>
    <SolidColorBrush x:Key="GxBrandLine" Color="#668B5CF6"/>
    <SolidColorBrush x:Key="GxBrandDim"  Color="#248B5CF6"/>
    <SolidColorBrush x:Key="AgyBrandLine" Color="#662BC5B4"/>
    <SolidColorBrush x:Key="AgyBrandDim"  Color="#242BC5B4"/>

    <Style TargetType="{x:Type c:IconView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:IconView}">
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="P" Data="{TemplateBinding Icon}"
                                  Stroke="{TemplateBinding Foreground}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Filled" Value="True">
                            <Setter TargetName="P" Property="Fill"
                                    Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="P" Property="Stroke" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

