    <!-- 엔진별 아이콘+색 자동 선택 (DataContext에 AgentId 필요: SessionViewModel/CliHistoryItemViewModel) -->
    <Style x:Key="EngineIcon" TargetType="{x:Type c:IconView}" BasedOn="{StaticResource {x:Type c:IconView}}">
        <Setter Property="Width" Value="15"/>
        <Setter Property="Height" Value="15"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding AgentId}" Value="cc">
                <Setter Property="Icon" Value="{StaticResource IconEngineClaude}"/>
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                <Setter Property="Icon" Value="{StaticResource IconEngineOpenAi}"/>
                <Setter Property="Foreground" Value="{StaticResource Gx}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding AgentId}" Value="ag">
                <Setter Property="Icon" Value="{StaticResource IconEngineGemini}"/>
                <Setter Property="Foreground" Value="{StaticResource Info}"/>
                <Setter Property="Filled" Value="True"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                <Setter Property="Icon" Value="{StaticResource IconEngineAgy}"/>
                <Setter Property="Foreground" Value="{StaticResource Agy}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- EngineDef(DataContext.Id) 용 변형 — New Agent 엔진 목록 -->
    <Style x:Key="EngineIconByDef" TargetType="{x:Type c:IconView}" BasedOn="{StaticResource {x:Type c:IconView}}">
        <Setter Property="Width" Value="17"/>
        <Setter Property="Height" Value="17"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Id}" Value="cc">
                <Setter Property="Icon" Value="{StaticResource IconEngineClaude}"/>
                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="gx">
                <Setter Property="Icon" Value="{StaticResource IconEngineOpenAi}"/>
                <Setter Property="Foreground" Value="{StaticResource Gx}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="ag">
                <Setter Property="Icon" Value="{StaticResource IconEngineGemini}"/>
                <Setter Property="Foreground" Value="{StaticResource Info}"/>
                <Setter Property="Filled" Value="True"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="agy">
                <Setter Property="Icon" Value="{StaticResource IconEngineAgy}"/>
                <Setter Property="Foreground" Value="{StaticResource Agy}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

