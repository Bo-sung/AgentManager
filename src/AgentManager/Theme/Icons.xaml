    <GeometryGroup x:Key="IconSettings">
        <EllipseGeometry Center="12,12" RadiusX="3" RadiusY="3"/>
        <PathGeometry Figures="M12 2.5v3M12 18.5v3M21.5 12h-3M5.5 12h-3M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1M18.4 18.4l-2.1-2.1M7.7 7.7L5.6 5.6"/>
    </GeometryGroup>

