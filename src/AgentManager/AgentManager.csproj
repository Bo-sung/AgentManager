<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\AgentManager.Core\AgentManager.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle IBM Plex (OFL) for design-fidelity typography; Korean falls back to system. -->
    <Resource Include="Resources\Fonts\*.ttf" />
    <!-- Install/setup guide content (rendered by MarkdownViewer → theme-matched). -->
    <Resource Include="Resources\Guide.*.md" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- 1.13.1: 세션 삭제 시 에이전트 브랜치 정리(머지된 것만 삭제, 미머지 보존) — 브랜치 누적 버그 수정 -->
    <Version>1.13.1</Version>
    <Product>AgentManager</Product>
  </PropertyGroup>

</Project>
