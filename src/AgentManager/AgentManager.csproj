<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\AgentManager.Core\AgentManager.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle IBM Plex (OFL) for design-fidelity typography; Korean falls back to system. -->
    <Resource Include="Resources\Fonts\*.ttf" />
    <!-- Install/setup guide content (rendered by MarkdownViewer → theme-matched). -->
    <Resource Include="Resources\Guide.*.md" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- 1.13.0: 워커 태스크 큐(스킬→백로그 · Core WorkerTaskStore · 워커별 큐) · 탭형 사이드 패인 · 작업 보고 수신함+복사 -->
    <Version>1.13.0</Version>
    <Product>AgentManager</Product>
  </PropertyGroup>

</Project>
