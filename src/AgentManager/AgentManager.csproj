<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\AgentManager.Core\AgentManager.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle IBM Plex (OFL) for design-fidelity typography; Korean falls back to system. -->
    <Resource Include="Resources\Fonts\*.ttf" />
    <!-- Install/setup guide content (rendered by MarkdownViewer → theme-matched). -->
    <Resource Include="Resources\Guide.*.md" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- 1.16.2: 프로젝트-로컬 상태(.am/project.json) · 오피스/PDF 경로 패스스루 · 드래그드롭 첨부 · 폴더 열기 · 백로그 갱신 · 컴포저 전송 수정 -->
    <Version>1.16.2</Version>
    <Product>AgentManager</Product>
  </PropertyGroup>

</Project>
