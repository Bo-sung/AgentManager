<Window x:Class="AgentManager.Views.ActivityHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgentManager.Controls"
        Title="{StaticResource L.ActivityHistoryTitle}"
        Height="560" Width="860" MinHeight="420" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1}" Foreground="{StaticResource Txt0}"
        FontFamily="{StaticResource Sans}" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}"
                BorderThickness="0,0,0,1" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{StaticResource L.ActivityHistoryHeader}" Style="{StaticResource Lbl}"
                           Foreground="{StaticResource Txt1}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Grid.Column="1" Text="{Binding SummaryText}" FontFamily="{StaticResource Mono}"
                           FontSize="10.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>

                <Border Grid.Column="3" Background="{StaticResource Bg1}" BorderBrush="{StaticResource Line}"
                        BorderThickness="1" CornerRadius="7" Padding="6,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:IconView Grid.Column="0" Icon="{StaticResource IconSearch}" Width="13" Height="13"
                                           Foreground="{StaticResource Txt2}" Margin="4,0,6,0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Style="{StaticResource ComposerInput}" Background="Transparent"
                                 BorderThickness="0" Padding="0,7" VerticalAlignment="Center"
                                 AcceptsReturn="False" TextWrapping="NoWrap"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}"
                BorderThickness="0,1,0,0" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="{Binding FilterSummaryText}" FontFamily="{StaticResource Mono}"
                           FontSize="10.5" Foreground="{StaticResource Txt3}" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Refresh}" Click="Refresh_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Close}" Click="Close_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Margin="14" Background="{StaticResource Bg0}" BorderBrush="{StaticResource Line}"
                BorderThickness="1" CornerRadius="8">
            <ListView ItemsSource="{Binding RowsView}" Background="Transparent" BorderThickness="0"
                      SelectionMode="Single" ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8,4" CornerRadius="7" Padding="11,9"
                                BorderBrush="{StaticResource LineSoft}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Bg1}"/>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Bg3}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="82"/>
                                    <ColumnDefinition Width="104"/>
                                    <ColumnDefinition Width="74"/>
                                    <ColumnDefinition Width="68"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Top" Margin="0,6,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource Txt3}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Fill" Value="{StaticResource Ok}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Fill" Value="{StaticResource Err}"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Fill" Value="{StaticResource Warn}"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <Border Grid.Column="1" Width="26" Height="24" CornerRadius="4"
                                        Background="{StaticResource Bg0}" BorderBrush="{StaticResource LineBright}"
                                        BorderThickness="1" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Badge}" FontFamily="{StaticResource Mono}" FontSize="10"
                                               FontWeight="SemiBold" Foreground="{StaticResource Txt1}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="2" Margin="2,0,14,0">
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Right" Background="{StaticResource Bg3}"
                                                BorderBrush="{StaticResource Line}" BorderThickness="1"
                                                CornerRadius="6" Padding="6,2" Margin="8,0,0,0"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BoolVis}}">
                                            <TextBlock Text="{StaticResource L.ArchivedBadge}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                       Foreground="{StaticResource Txt2}"/>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource Txt0}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Project}" FontFamily="{StaticResource Mono}" FontSize="10.5"
                                                   Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="260"/>
                                        <TextBlock Text=" / " FontFamily="{StaticResource Mono}" FontSize="10"
                                                   Foreground="{StaticResource Txt3}"/>
                                        <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                   Foreground="{StaticResource Txt3}" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="230"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Column="3" Text="{Binding StartedText}" FontFamily="{StaticResource Mono}"
                                           FontSize="10.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding TokensText}" FontFamily="{StaticResource Mono}"
                                           FontSize="10.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="{Binding CostText}" FontFamily="{StaticResource Mono}"
                                           FontSize="10.5" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="{Binding BlocksText}" FontFamily="{StaticResource Mono}"
                                           FontSize="10" Foreground="{StaticResource Txt3}" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </DockPanel>
</Window>
