<UserControl x:Class="AgentManager.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Name="SessionRoot">
    <Grid>
                    <!-- empty state -->
                    <TextBlock Text="{StaticResource L.NoSessionStart}" FontFamily="{StaticResource Mono}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel>
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>

                        <!-- tabbar -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="14,0">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Project}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" Text="  ›  " Foreground="{DynamicResource Txt3}" VerticalAlignment="Center"/>
                                <!-- 리뷰 토글은 최우측: 패널이 우측에서 열리므로 위치=동작 (사용자 요청) -->
                                <Button DockPanel.Dock="Right" Width="30" Height="30"
                                        ToolTip="{StaticResource L.DiffReviewToggleTip}"
                                        Command="{Binding DataContext.ToggleReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1" CornerRadius="6">
                                                            <controls:IconView Icon="{StaticResource IconPanel}"
                                                                               Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding DataContext.IsReviewOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="20" Padding="8,3" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Branch}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Txt1}"/>
                                </Border>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.OpenIdeTip}"
                                        Command="{Binding DataContext.OpenIdeCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconIde}" Width="13" Height="13"
                                                           Foreground="{DynamicResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.OpenIde}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.ExportTip}" Click="ExportTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconFile}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.Export}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.CopyAllTip}" Click="CopyTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconCopy}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.CopyAll}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>

                        <!-- status strip -->
                        <Border DockPanel.Dock="Top" Height="38" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="16,0" LastChildFill="False" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusLabel}" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Border DockPanel.Dock="Left" Background="{DynamicResource AccentDim}"
                                        BorderThickness="1" CornerRadius="13" Padding="9,3" VerticalAlignment="Center" Margin="0,0,16,0"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <controls:Spinner VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="{StaticResource L.Running}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{DynamicResource Txt0}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding LastSignalLabel}" Foreground="{DynamicResource Txt2}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.StatusAgent}"/><Run Text="{Binding AgentName, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.StatusModel}"/><Run Text="{Binding Model, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                              IsChecked="{Binding TranslationEnabled, Mode=TwoWay}"
                                              IsEnabled="{Binding DataContext.CanTranslate, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Content="{Binding TranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"
                                              Margin="16,0,0,0"/>
                                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}"
                                              IsChecked="{Binding RequireApproval, Mode=TwoWay}"
                                              Content="{StaticResource L.Approval}" ToolTip="{StaticResource L.ApprovalToggleTip}"
                                              Margin="8,0,0,0"/>
                                <ComboBox DockPanel.Dock="Left" ItemsSource="{Binding Source={StaticResource SandboxModes}}"
                                          SelectedItem="{Binding Sandbox, Mode=TwoWay}"
                                          FontFamily="{StaticResource Mono}" FontSize="10" Width="132" Height="24"
                                          Background="{DynamicResource Bg1}" Foreground="{DynamicResource Txt1}"
                                          BorderBrush="{DynamicResource Line}" Margin="8,0,0,0"/>
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.Tkn}"/><Run Text="{Binding TokensLabel, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}" Margin="0,0,16,0">
                                    <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding CostLabel, Mode=OneWay}" Foreground="{DynamicResource Ok}"/></TextBlock>
                            </DockPanel>
                        </Border>

                        <!-- native workers / subagents -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="16,8"
                                Visibility="{Binding HasNativeWorkItems, Converter={StaticResource BoolVis}}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Width="128" VerticalAlignment="Center">
                                    <TextBlock Text="{StaticResource L.NativeWorkers}" Style="{StaticResource Lbl}" Foreground="{DynamicResource Txt2}"/>
                                    <TextBlock Text="{Binding NativeWorkItems.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding NativeWorkItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border MinWidth="160" MaxWidth="260" Margin="0,0,8,0" Padding="9,7" CornerRadius="6"
                                                    Background="{DynamicResource Bg2}" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Ok}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Err}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel>
                                                    <Ellipse DockPanel.Dock="Left" Width="7" Height="7" Margin="0,4,8,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource Txt3}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Accent}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Ok}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource Err}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Txt0}" FontSize="11.5" FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Status}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                                       Foreground="{DynamicResource Txt2}" Margin="8,0,0,0"/>
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding Source}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt3}"
                                                                   Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,3,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <!-- composer (bottom) -->
                        <Border DockPanel.Dock="Bottom" Margin="14,0,14,14" MinWidth="520" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <!-- 보고 수신함 (워커 위임 ready 보고) -->
                                <Border Margin="4,0,4,8" Background="{DynamicResource InfoDim}" BorderBrush="{DynamicResource InfoLine}" BorderThickness="1" CornerRadius="8" Padding="11,8"
                                        Visibility="{Binding DataContext.HasReadyReportsActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}">
                                    <DockPanel>
                                        <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconLayers}" Width="15" Height="15" Foreground="{DynamicResource Info}" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" VerticalAlignment="Center"
                                                Visibility="{Binding DataContext.CanMergeReports, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}"
                                                Command="{Binding DataContext.MergeReportsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:IconView Icon="{StaticResource IconLayers}" Width="12" Height="12" Foreground="{DynamicResource Txt1}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock VerticalAlignment="Center"><Run Text="{StaticResource L.MergePaste}"/><Run Text=" ("/><Run Text="{Binding DataContext.ReadyReportsActiveCount, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/><Run Text=")"/></TextBlock>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{StaticResource L.ReportInbox}" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" FontSize="11.5" Margin="0,0,8,0"/>
                                            <TextBlock Foreground="{DynamicResource Txt2}" FontSize="11" VerticalAlignment="Center"><Run Text="{Binding DataContext.ReadyReportsActiveCount, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/><Run Text=" READY"/></TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border Margin="4,0,4,8" Background="{DynamicResource AccentDim}" BorderThickness="1" CornerRadius="8"
                                        Padding="11,8" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{DynamicResource Txt0}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding LastSignalLabel}" Foreground="{DynamicResource Txt2}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource L.Running}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding BusyLine}" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Border Background="{DynamicResource Bg3}" BorderThickness="1.5" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource GxLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AgyLine}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Bottom" Padding="9,0,9,9" Height="50">
                                            <DockPanel VerticalAlignment="Bottom" LastChildFill="True">
                                                <Button DockPanel.Dock="Left" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{StaticResource L.AttachImageTip}"
                                                        Click="AttachImage_Click">
                                                    <controls:IconView Icon="{StaticResource IconAttach}" Width="15" Height="15"/>
                                                </Button>
                                                <Border DockPanel.Dock="Left" Height="30" CornerRadius="15" Padding="12,0" BorderThickness="1"
                                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                                        ToolTip="{StaticResource L.AgentEngineTip}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                    <Setter Property="Background" Value="{DynamicResource GxDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource GxLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                    <Setter Property="Background" Value="{DynamicResource AgyDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AgyLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Style="{StaticResource EngineIcon}" Width="16" Height="16"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Text="{Binding Badge}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Gx}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                            <Setter Property="Foreground" Value="{DynamicResource Agy}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <Border DockPanel.Dock="Left" Style="{StaticResource ComposerPill}" Margin="0,0,8,0"
                                                        VerticalAlignment="Center" ToolTip="{Binding Branch}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconBranch}" Width="13" Height="13"
                                                                           Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" Foreground="{DynamicResource Txt1}"
                                                                   VerticalAlignment="Center">
                                                            <Run Text="{StaticResource L.WorktreePrefix}" Foreground="{DynamicResource Txt2}"/><Run Text="{Binding BranchTail, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                                                    <ToggleButton x:Name="ModelMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand" ToolTip="{StaticResource L.ModelSelectTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconSpark}" Width="13" Height="13"
                                                                               Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding Model}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Gx}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Agy}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{DynamicResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=ModelMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="200">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7">
                                                                    <Run Text="{Binding AgentName, Mode=OneWay}"/><Run Text="{StaticResource L.DotModel}"/>
                                                                </TextBlock>
                                                                <ItemsControl ItemsSource="{Binding AvailableModels}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="ModelOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="mi" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="mi" Property="Background" Value="{DynamicResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0"
                                                      Visibility="{Binding HasEffort, Converter={StaticResource BoolVis}}">
                                                    <ToggleButton x:Name="EffortMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand"
                                                                  ToolTip="{StaticResource L.EffortTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                                               Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding ReasoningEffort}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Gx}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{DynamicResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=EffortMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="160">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7" Text="{StaticResource L.ReasoningEffort}"/>
                                                                <ItemsControl ItemsSource="{Binding EffortOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="EffortOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="ei" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="ei" Property="Background" Value="{DynamicResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <Button DockPanel.Dock="Right" Width="32" Height="32" Cursor="Hand" Foreground="White"
                                                        Margin="6,0,0,0" ToolTip="{StaticResource L.StopTip}"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                                                        Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <controls:IconView Icon="{StaticResource IconStop}" Filled="True" Width="14" Height="14"/>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="sb" Background="{DynamicResource Err}" CornerRadius="7">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="sb" Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource SendButton}"
                                                        Foreground="{DynamicResource AccentText}" ToolTip="{StaticResource L.SendTip}"
                                                        Command="{Binding DataContext.SendCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                                </Button>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0" Click="Dictate_Click"
                                                        ToolTip="{StaticResource L.DictateTip}">
                                                    <controls:IconView Icon="{StaticResource IconMic}" Width="15" Height="15"/>
                                                </Button>
                                                <TextBlock/>
                                            </DockPanel>
                                        </Border>
                                        <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding PendingImages}" Margin="13,0,13,4">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource AccentLine}" BorderThickness="1"
                                                            CornerRadius="10" Padding="8,3" Margin="0,2,6,2" ToolTip="{Binding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🖼" FontSize="10" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                                       Foreground="{DynamicResource Txt1}" MaxWidth="180"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            <Button Content="✕" FontSize="9" Margin="6,0,0,0" Padding="2,0"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                    Foreground="{DynamicResource Txt2}" ToolTip="{StaticResource L.Remove}"
                                                                    Click="RemovePendingImage_Click"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid MinHeight="58">
                                            <TextBox x:Name="ComposerBox" Style="{StaticResource ComposerInput}" MinHeight="58" MaxHeight="160"
                                                     Padding="15,12,15,2"
                                                     VerticalContentAlignment="Top"
                                                     Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}"
                                                     KeyDown="Composer_KeyDown"
                                                     PreviewKeyDown="Composer_PreviewKeyDown"
                                                     TextChanged="ComposerBox_TextChanged"/>
                                            <TextBlock Margin="15,12,15,0" Foreground="{DynamicResource Txt2}" IsHitTestVisible="False"
                                                       FontSize="13.5" LineHeight="20" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Draft}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{StaticResource L.MessagePrefix}"/><Run Text="{Binding Cli, Mode=OneWay}"/><Run Text="{StaticResource L.MessageSuffix}"/>
                                            </TextBlock>
                                            <Popup x:Name="ComposerSuggestionPopup"
                                                   IsOpen="{Binding DataContext.IsComposerSuggestionOpen, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   PlacementTarget="{Binding ElementName=ComposerBox}"
                                                   Placement="Top"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="False"
                                                   HorizontalOffset="10"
                                                   VerticalOffset="-5">
                                                <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Width="380" MaxHeight="250">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="3"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <!-- Header -->
                                                        <Border Grid.Row="0" Background="{DynamicResource Bg3}" Padding="10,6" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                                                            <TextBlock Text="{Binding DataContext.ComposerSuggestionHeader, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource Txt1}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource Mono}"/>
                                                        </Border>
                                                        <!-- Suggestions List -->
                                                        <ListBox Grid.Row="1" x:Name="SuggestionList"
                                                                 ItemsSource="{Binding DataContext.ComposerSuggestions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 SelectedItem="{Binding DataContext.SelectedComposerSuggestion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 MouseDoubleClick="SuggestionList_DoubleClick"
                                                                 KeyDown="SuggestionList_KeyDown"
                                                                 MaxHeight="200" Padding="0,4">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Padding" Value="10,6"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg3}"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsSelected" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,3,0"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Icon/Indicator based on type -->
                                                                        <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="📄"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Session">
                                                                                            <Setter Property="Text" Value="⚡"/>
                                                                                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Command">
                                                                                            <Setter Property="Text" Value="⚙️"/>
                                                                                            <Setter Property="Foreground" Value="{DynamicResource Info}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <!-- Label -->
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{DynamicResource Txt0}" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource Mono}"/>
                                                                        <!-- Type Text -->
                                                                        <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="{DynamicResource Txt2}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="{StaticResource Mono}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Grid>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DockPanel>
                                </Border>
                                <DockPanel Margin="4,6,4,0" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="9.5">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.EnterHint}" Foreground="{DynamicResource Txt3}"/>
                                    <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource Txt3}">
                                        <Run Text="{Binding Cli, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding Branch, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- transcript -->
                        <!-- 가상화 필수: 긴 트랜스크립트(CLI 가져오기 수백 블록)에서 보이는 항목만 생성한다.
                             가상화가 동작하려면 ScrollViewer가 ItemsControl 템플릿 안에 있어야 함 -->
                        <ItemsControl x:Name="TranscriptList" ItemsSource="{Binding Transcript}"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel"
                                      PreviewMouseWheel="TranscriptScroll_PreviewMouseWheel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer x:Name="PART_TranscriptScroll" VerticalScrollBarVisibility="Auto" Focusable="False">
                                        <!-- 전폭 사용: 중앙 880px 캡 대신 좌우 최소 여백 (사용자 요청) -->
                                        <ItemsPresenter Margin="14,16,14,12"/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                    </DockPanel>
                </Grid>
</UserControl>
