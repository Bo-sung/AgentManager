<UserControl x:Class="AgentManager.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Name="SessionRoot">
    <Grid>
                    <!-- empty state -->
                    <TextBlock Text="{StaticResource L.NoSessionStart}" FontFamily="{StaticResource Mono}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel>
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.HasActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>

                        <!-- tabbar -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="14,0">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Project}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" Text="  ›  " Foreground="{DynamicResource Txt3}" VerticalAlignment="Center"/>
                                <!-- 리뷰 토글은 최우측: 패널이 우측에서 열리므로 위치=동작 (사용자 요청) -->
                                <Button DockPanel.Dock="Right" Width="30" Height="30"
                                        ToolTip="{StaticResource L.DiffReviewToggleTip}"
                                        Command="{Binding DataContext.ToggleReviewCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource Bg3}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1" CornerRadius="6">
                                                            <controls:IconView Icon="{StaticResource IconPanel}"
                                                                               Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Txt0}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBright}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding DataContext.IsReviewOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="20" Padding="8,3" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding BranchDisplay}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Txt1}"/>
                                </Border>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.OpenIdeTip}"
                                        Command="{Binding DataContext.OpenIdeCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconIde}" Width="13" Height="13"
                                                           Foreground="{DynamicResource Accent}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.OpenIde}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.ExportTip}" Click="ExportTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconFile}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.Export}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="0,0,8,0"
                                        ToolTip="{StaticResource L.CopyAllTip}" Click="CopyTranscript_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconCopy}" Width="12" Height="12"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.CopyAll}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>

                        <!-- status strip -->
                        <Border DockPanel.Dock="Top" Height="38" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1">
                            <DockPanel Margin="16,0" LastChildFill="False" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusLabel}" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <Border DockPanel.Dock="Left" Background="{DynamicResource AccentDim}"
                                        BorderThickness="1" CornerRadius="13" Padding="9,3" VerticalAlignment="Center" Margin="0,0,16,0"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <controls:Spinner VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Text="{StaticResource L.Running}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{DynamicResource Txt0}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding LastSignalLabel}" Foreground="{DynamicResource Txt2}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.StatusAgent}"/><Run Text="{Binding AgentName, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.StatusModel}"/><Run Text="{Binding Model, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <!-- 권한/안전 모드는 컴포저 바의 칩으로 이동(engine-aware) -->
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}">
                                    <Run Text="{StaticResource L.Tkn}"/><Run Text="{Binding TokensLabel, Mode=OneWay}" Foreground="{DynamicResource Txt0}"/></TextBlock>
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="{DynamicResource Txt2}" Margin="0,0,16,0">
                                    <Run Text="{StaticResource L.Cost}"/><Run Text="{Binding CostLabel, Mode=OneWay}" Foreground="{DynamicResource Ok}"/></TextBlock>
                            </DockPanel>
                        </Border>

                        <!-- composer (bottom) -->
                        <Border DockPanel.Dock="Bottom" Margin="14,0,14,14" MinWidth="520" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <Border Margin="4,0,4,8" Background="{DynamicResource AccentDim}" BorderThickness="1" CornerRadius="8"
                                        Padding="11,8" Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsQuiet}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="10.5">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding RunningElapsedLabel}" Foreground="{DynamicResource Txt0}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding LastSignalLabel}" Foreground="{DynamicResource Txt2}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{StaticResource L.Running}" Foreground="{DynamicResource Accent}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding BusyLine}" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <!-- 빠른 응답 — 어시스턴트 선택지(A/B · 1/2) 자동 감지 → 클릭 시 전송 -->
                                <!-- ask_user_input 스타일(단일선택) — 플랫 행 + 주황 포커스 바 + 인라인 "기타" 입력. 옵션 0개면 collapse. -->
                                <Border x:Name="QuickReplyPanel" Margin="4,0,4,9" CornerRadius="10" BorderThickness="1"
                                        Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}"
                                        KeyDown="QuickReply_KeyDown" IsVisibleChanged="QuickReplyPanel_IsVisibleChanged"
                                        Visibility="{Binding HasChoice, Converter={StaticResource BoolVis}}">
                                    <StackPanel>
                                        <!-- 헤더: [‹ 이전] 질문 [N/M] [✕ 직접입력] -->
                                        <DockPanel Margin="14,12,12,10">
                                            <Button DockPanel.Dock="Right" Width="24" Height="24" Cursor="Hand" ToolTip="{StaticResource L.CustomInputTip}"
                                                    Command="{Binding DataContext.DismissChoiceCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="xb" Background="Transparent" CornerRadius="5">
                                                            <controls:IconView Icon="{StaticResource IconX}" Width="13" Height="13" Foreground="{DynamicResource Txt2}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="xb" Property="Background" Value="{DynamicResource Bg3}"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <!-- 번역 토글 (✕ 왼쪽): ON=선택지·직접입력 번역 / OFF=원문 -->
                                            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Height="22" Padding="9,0" Margin="0,0,6,0"
                                                          VerticalAlignment="Center" IsChecked="{Binding TranslationEnabled, Mode=TwoWay}"
                                                          Content="{Binding TranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"/>
                                            <TextBlock DockPanel.Dock="Right" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt3}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding ActiveChoice.PagerLabel}"
                                                       Visibility="{Binding ActiveChoice.HasPager, Converter={StaticResource BoolVis}}"/>
                                            <Button DockPanel.Dock="Left" Width="22" Height="22" Cursor="Hand" Margin="0,0,8,0" ToolTip="{StaticResource L.PrevQuestion}"
                                                    Visibility="{Binding ActiveChoice.HasPrev, Converter={StaticResource BoolVis}}"
                                                    Command="{Binding DataContext.ChoicePrevCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="pb" Background="Transparent" CornerRadius="5">
                                                            <TextBlock Text="‹" FontSize="17" Foreground="{DynamicResource Txt1}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="pb" Property="Background" Value="{DynamicResource Bg3}"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding ActiveChoice.Current.HeaderText}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" Foreground="{DynamicResource Txt0}"/>
                                        </DockPanel>
                                        <!-- 옵션 행 (단일=마커+화살표 / 멀티=체크박스, ↑↓ 네비) -->
                                        <ItemsControl ItemsSource="{Binding ActiveChoice.Current.Options, NotifyOnTargetUpdated=True}" Binding.TargetUpdated="Options_TargetUpdated"
                                                      KeyboardNavigation.DirectionalNavigation="Cycle">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Cursor="Hand" ToolTip="{Binding Label}" HorizontalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.ChoiceActivateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="row" Background="Transparent">
                                                                    <Grid>
                                                                        <Rectangle x:Name="bar" Width="2" HorizontalAlignment="Left" Visibility="Collapsed"
                                                                                   Fill="{Binding DataContext.AgentId, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource EngineBrush}, ConverterParameter=main}"/>
                                                                        <DockPanel Margin="17,12,18,12">
                                                                            <Grid x:Name="lead" DockPanel.Dock="Left" Width="18" Margin="0,0,14,0" VerticalAlignment="Center">
                                                                                <TextBlock x:Name="num" Text="{Binding Marker}" FontFamily="{StaticResource Mono}" FontSize="13" TextAlignment="Center" Foreground="{DynamicResource Txt2}"/>
                                                                                <Border x:Name="cbox" Width="16" Height="16" CornerRadius="4" BorderThickness="1.5" HorizontalAlignment="Center"
                                                                                        BorderBrush="{DynamicResource Txt3}" Background="Transparent" Visibility="Collapsed">
                                                                                    <controls:IconView x:Name="chk" Icon="{StaticResource IconCheck}" Width="11" Height="11" Foreground="#FF0A0E12" Visibility="Collapsed"/>
                                                                                </Border>
                                                                            </Grid>
                                                                            <controls:IconView x:Name="arrow" DockPanel.Dock="Right" Icon="{StaticResource IconChevRight}" Width="15" Height="15"
                                                                                               Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"
                                                                                               Foreground="{Binding DataContext.AgentId, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource EngineBrush}, ConverterParameter=main}"/>
                                                                            <TextBlock x:Name="lbl" Text="{Binding Label}" FontSize="13.5" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                                        </DockPanel>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="row" Property="Background" Value="{DynamicResource Bg3}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                                        <Setter TargetName="row" Property="Background">
                                                                            <Setter.Value>
                                                                                <Binding Path="DataContext.AgentId" Converter="{StaticResource EngineBrush}" ConverterParameter="dim" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter TargetName="bar" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="num" Property="Foreground">
                                                                            <Setter.Value>
                                                                                <Binding Path="DataContext.AgentId" Converter="{StaticResource EngineBrush}" ConverterParameter="main" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter TargetName="num" Property="FontWeight" Value="SemiBold"/>
                                                                        <Setter TargetName="lbl" Property="Foreground" Value="{DynamicResource Txt0}"/>
                                                                    </Trigger>
                                                                    <!-- 멀티: 체크박스 노출, 마커/화살표 숨김 (포커스 트리거보다 뒤 → 우선) -->
                                                                    <DataTrigger Binding="{Binding DataContext.ActiveChoice.Multi, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                                        <Setter TargetName="cbox" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="num" Property="Visibility" Value="Collapsed"/>
                                                                        <Setter TargetName="arrow" Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <!-- 선택됨(멀티): 체크 채움(엔진색) -->
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                                                                        <Setter TargetName="lbl" Property="Foreground" Value="{DynamicResource Txt0}"/>
                                                                        <Setter TargetName="cbox" Property="Background">
                                                                            <Setter.Value><Binding Path="DataContext.AgentId" Converter="{StaticResource EngineBrush}" ConverterParameter="main" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/></Setter.Value>
                                                                        </Setter>
                                                                        <Setter TargetName="cbox" Property="BorderBrush">
                                                                            <Setter.Value><Binding Path="DataContext.AgentId" Converter="{StaticResource EngineBrush}" ConverterParameter="main" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/></Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border Height="1" Background="{DynamicResource LineSoft}"/>
                                        <!-- 단일선택 푸터: "기타" 인라인 입력 (Draft 재사용) — 연필 + 입력 + KO→EN 번역 토글 + 전송/건너뛰기 -->
                                        <DockPanel Margin="17,9,12,11">
                                            <DockPanel.Style>
                                                <Style TargetType="DockPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveChoice.Multi}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DockPanel.Style>
                                            <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconEdit}" Width="15" Height="15" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                            <Button DockPanel.Dock="Right" Width="28" Height="28" Cursor="Hand" Margin="8,0,0,0" ToolTip="{StaticResource L.SendTip}"
                                                    Command="{Binding DataContext.ChoiceFreeInputCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="gb" CornerRadius="14"
                                                                            Background="{Binding AgentId, Converter={StaticResource EngineBrush}, ConverterParameter=main}">
                                                                        <controls:IconView Icon="{StaticResource IconSend}" Width="13" Height="13" Foreground="#FF0A0E12"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="gb" Property="Opacity" Value="0.88"/></Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanSend}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Content="{StaticResource L.Skip}" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.DismissChoiceCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource ChipButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanSend}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Grid>
                                                <TextBox Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}" PreviewKeyDown="ChoiceOther_PreviewKeyDown"
                                                         Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Txt0}" FontSize="13.5" VerticalContentAlignment="Center"/>
                                                <TextBlock Text="{StaticResource L.CustomInput}" Foreground="{DynamicResource Txt2}" FontSize="13.5" VerticalAlignment="Center" IsHitTestVisible="False" Margin="3,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Draft}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DockPanel>
                                        <!-- 멀티선택 푸터: N 선택됨 + 제출 -->
                                        <DockPanel Margin="17,9,12,11">
                                            <DockPanel.Style>
                                                <Style TargetType="DockPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveChoice.Multi}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DockPanel.Style>
                                            <Button DockPanel.Dock="Right" Cursor="Hand" Height="32" MinWidth="84" Padding="22,0" Margin="8,0,0,0" ToolTip="{StaticResource L.SubmitTip}"
                                                    Command="{Binding DataContext.ChoiceSubmitCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    IsEnabled="{Binding ActiveChoice.Current.HasSelection}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="sb" CornerRadius="16" Padding="{TemplateBinding Padding}"
                                                                Background="{Binding AgentId, Converter={StaticResource EngineBrush}, ConverterParameter=main}">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="{StaticResource L.Submit}" Foreground="#FF0A0E12" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                <controls:IconView Icon="{StaticResource IconSend}" Width="12" Height="12" Foreground="#FF0A0E12" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="sb" Property="Opacity" Value="0.88"/></Trigger>
                                                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="sb" Property="Opacity" Value="0.3"/></Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button DockPanel.Dock="Right" Content="{StaticResource L.Skip}" Margin="8,0,0,0" Style="{StaticResource ChipButton}"
                                                    Command="{Binding DataContext.DismissChoiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <controls:IconView Icon="{StaticResource IconCheck}" Width="13" Height="13" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding ActiveChoice.Current.SelectedCount}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{StaticResource L.SelectedSuffix}" FontSize="13" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <Border Height="1" Background="{DynamicResource LineSoft}"/>
                                        <!-- 키보드 힌트 바 (단일/멀티에 따라 문구 변경) -->
                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Txt3}" HorizontalAlignment="Center" Margin="0,8,0,9">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{StaticResource L.QuickReplyHint}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActiveChoice.Multi}" Value="True"><Setter Property="Text" Value="{StaticResource L.MultiHint}"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <!-- 선택지가 떠 있으면 입력창을 내린다(클로드 코드 데스크톱식) — 번역 토글/직접입력은 위 푸터에 -->
                                <Border Background="{DynamicResource Bg3}" BorderThickness="1.5" CornerRadius="10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasChoice}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource CcBrandLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource GxBrandLine}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AgyGradient}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Bottom" Padding="9,0,9,9" Height="50">
                                            <DockPanel VerticalAlignment="Bottom" LastChildFill="True">
                                                <Button DockPanel.Dock="Left" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0"
                                                        ToolTip="{StaticResource L.AttachImageTip}"
                                                        Click="AttachImage_Click">
                                                    <controls:IconView Icon="{StaticResource IconAttach}" Width="15" Height="15"/>
                                                </Button>
                                                <Border DockPanel.Dock="Left" Height="30" CornerRadius="15" Padding="12,0" BorderThickness="1"
                                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                                        ToolTip="{StaticResource L.AgentEngineTip}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                    <Setter Property="Background" Value="{DynamicResource CcBrandDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource CcBrandLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                    <Setter Property="Background" Value="{DynamicResource GxBrandDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource GxBrandLine}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                    <Setter Property="Background" Value="{DynamicResource AgyBrandDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AgyBrandLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Style="{StaticResource EngineIcon}" Width="16" Height="16"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Text="{Binding Badge}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Txt1}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="cc">
                                                                            <Setter Property="Foreground" Value="{DynamicResource CcBrand}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                            <Setter Property="Foreground" Value="{DynamicResource GxBrand}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AgyBrand}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AgentId}" Value="pi">
                                                                            <Setter Property="Foreground" Value="{DynamicResource PiBrand}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                                <Border DockPanel.Dock="Left" Style="{StaticResource ComposerPill}" Margin="0,0,8,0"
                                                        VerticalAlignment="Center" ToolTip="{Binding WorktreePill}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconBranch}" Width="13" Height="13"
                                                                           Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding WorktreePill}" FontFamily="{StaticResource Mono}" FontSize="11.5"
                                                                   Foreground="{DynamicResource Txt1}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                                                    <ToggleButton x:Name="ModelMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand" ToolTip="{StaticResource L.ModelSelectTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconSpark}" Width="13" Height="13"
                                                                               Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding Model}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource CcBrand}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{DynamicResource GxBrand}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="agy">
                                                                                <Setter Property="Foreground" Value="{DynamicResource AgyBrand}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="pi">
                                                                                <Setter Property="Foreground" Value="{DynamicResource PiBrand}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{DynamicResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=ModelMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="200">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7">
                                                                    <Run Text="{Binding AgentName, Mode=OneWay}"/><Run Text="{StaticResource L.DotModel}"/>
                                                                </TextBlock>
                                                                <ItemsControl ItemsSource="{Binding AvailableModels}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="ModelOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="mi" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="mi" Property="Background" Value="{DynamicResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0"
                                                      Visibility="{Binding HasEffort, Converter={StaticResource BoolVis}}">
                                                    <ToggleButton x:Name="EffortMenuBtn" Style="{StaticResource TogglePillButton}"
                                                                  Height="30" Padding="12,0" Cursor="Hand"
                                                                  ToolTip="{StaticResource L.EffortTip}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="13" Height="13"
                                                                               Foreground="{DynamicResource Txt2}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11.5" VerticalAlignment="Center"
                                                                       Text="{Binding ReasoningEffort}" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource CcBrand}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="gx">
                                                                                <Setter Property="Foreground" Value="{DynamicResource GxBrand}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AgentId}" Value="pi">
                                                                                <Setter Property="Foreground" Value="{DynamicResource PiBrand}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11"
                                                                               Foreground="{DynamicResource Txt2}" Margin="7,1,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToggleButton>
                                                    <Popup IsOpen="{Binding IsChecked, ElementName=EffortMenuBtn, Mode=TwoWay}"
                                                           StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                        <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                                                CornerRadius="7" Padding="5" Margin="8" MinWidth="160">
                                                            <Border.Effect>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                            </Border.Effect>
                                                            <StackPanel>
                                                                <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7" Text="{StaticResource L.ReasoningEffort}"/>
                                                                <ItemsControl ItemsSource="{Binding EffortOptions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Click="EffortOption_Click" Cursor="Hand"
                                                                                    Background="Transparent" BorderThickness="0"
                                                                                    HorizontalContentAlignment="Stretch" Padding="0">
                                                                                <Button.Template>
                                                                                    <ControlTemplate TargetType="Button">
                                                                                        <Border x:Name="ei" Background="Transparent" CornerRadius="4" Padding="9,7">
                                                                                            <ContentPresenter/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="ei" Property="Background" Value="{DynamicResource Bg4}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </Button.Template>
                                                                                <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt0}" Text="{Binding}"/>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </Popup>
                                                </Grid>
                                                <!-- 권한/안전 모드 칩 (engine-aware: cc/gx 선택, agy/pi 잠금 배지) — 색=위험도 -->
                                                <Grid DockPanel.Dock="Left" Margin="0,0,8,0">
                                                    <!-- 선택 가능 (cc/gx) -->
                                                    <Grid Visibility="{Binding HasPermissionModeChoice, Converter={StaticResource BoolVis}}">
                                                        <ToggleButton x:Name="PermMenuBtn" Height="30" Cursor="Hand" ToolTip="{StaticResource L.PermissionMode}">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border CornerRadius="15" Padding="11,0" BorderThickness="1"
                                                                            Background="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=dim}"
                                                                            BorderBrush="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=line}">
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                                     Fill="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=main}"/>
                                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                                                                       Text="{Binding CurrentPermissionModeItem.Name}"
                                                                                       Foreground="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=text}"/>
                                                                            <controls:IconView Icon="{StaticResource IconChevDown}" Width="11" Height="11" Margin="6,1,0,0" VerticalAlignment="Center"
                                                                                               Foreground="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=text}"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <Popup IsOpen="{Binding IsChecked, ElementName=PermMenuBtn, Mode=TwoWay}"
                                                               StaysOpen="False" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade">
                                                            <Border Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1"
                                                                    CornerRadius="7" Padding="6" Margin="8" MinWidth="290" MaxWidth="330">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.45" Color="#FF000000"/>
                                                                </Border.Effect>
                                                                <StackPanel>
                                                                    <TextBlock Style="{StaticResource Lbl}" Margin="9,5,9,7" Text="{StaticResource L.PermissionMode}"/>
                                                                    <ItemsControl ItemsSource="{Binding PermissionModeItems}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Button Click="PermissionOption_Click" Cursor="Hand" Background="Transparent" BorderThickness="0"
                                                                                        HorizontalContentAlignment="Stretch" Padding="0">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border x:Name="po" Background="Transparent" CornerRadius="5" Padding="9,7">
                                                                                                <ContentPresenter/>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="po" Property="Background" Value="{DynamicResource Bg4}"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                    <DockPanel>
                                                                                        <Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,3,10,0" VerticalAlignment="Top"
                                                                                                 Fill="{Binding Risk, Converter={StaticResource RiskBrush}, ConverterParameter=main}"/>
                                                                                        <StackPanel>
                                                                                            <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" Text="{Binding Name}"/>
                                                                                            <TextBlock FontSize="10.5" Foreground="{DynamicResource Txt2}" TextWrapping="Wrap" Margin="0,2,0,0" Text="{Binding Desc}"/>
                                                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" Text="{Binding Flag}"/>
                                                                                        </StackPanel>
                                                                                    </DockPanel>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                    <!-- 잠금 (agy/pi): 정적 배지 + 툴팁 -->
                                                    <Border Height="30" CornerRadius="15" Padding="11,0" BorderThickness="1" Opacity="0.72"
                                                            ToolTip="{Binding PermissionLockReason}"
                                                            Background="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=dim}"
                                                            BorderBrush="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=line}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPermissionModeChoice}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <controls:IconView Icon="{StaticResource IconLock}" Width="11" Height="11" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                               Foreground="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=text}"/>
                                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="11" VerticalAlignment="Center"
                                                                       Text="{Binding CurrentPermissionModeItem.Name}"
                                                                       Foreground="{Binding PermissionRisk, Converter={StaticResource RiskBrush}, ConverterParameter=text}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                <!-- 번역 토글 (모델/effort 옆) — Ollama 미실행 시 비활성 -->
                                                <ToggleButton DockPanel.Dock="Left" Style="{StaticResource TogglePillButton}" Height="30" Padding="12,0" Margin="0,0,8,0"
                                                              IsChecked="{Binding TranslationEnabled, Mode=TwoWay}"
                                                              Content="{Binding TranslationLabel}" ToolTip="{StaticResource L.TranslationToggleTip}"/>
                                                <!-- Ollama 꺼짐 경고(번역 미적용) — 클릭 시 설정으로 -->
                                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconWarn}" Width="15" Height="15" Margin="0,0,8,0"
                                                                   VerticalAlignment="Center" Foreground="{DynamicResource Warn}" Cursor="Hand"
                                                                   ToolTip="{StaticResource L.OllamaOffWarn}"
                                                                   Visibility="{Binding DataContext.OllamaDown, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolVis}}"
                                                                   controls:MouseClick.Command="{Binding DataContext.ShowSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                <Button DockPanel.Dock="Right" Width="32" Height="32" Cursor="Hand" Foreground="White"
                                                        Margin="6,0,0,0" ToolTip="{StaticResource L.StopTip}"
                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"
                                                        Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <controls:IconView Icon="{StaticResource IconStop}" Filled="True" Width="14" Height="14"/>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="sb" Background="{DynamicResource Err}" CornerRadius="7">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="sb" Property="Opacity" Value="0.85"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button DockPanel.Dock="Right" ToolTip="{StaticResource L.SendTip}"
                                                        Command="{Binding DataContext.SendCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SendButton}">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentText}"/>
                                                            <Style.Triggers>
                                                                <!-- 실행 중엔 Send 숨김 → 옆의 빨강 Stop이 단독 주 버튼이 되어 명확 -->
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <controls:IconView Icon="{StaticResource IconSend}" Width="15" Height="15"/>
                                                </Button>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ComposerIconButton}"
                                                        Margin="0,0,8,0" Click="Dictate_Click"
                                                        ToolTip="{StaticResource L.DictateTip}">
                                                    <controls:IconView Icon="{StaticResource IconMic}" Width="15" Height="15"/>
                                                </Button>
                                                <TextBlock/>
                                            </DockPanel>
                                        </Border>
                                        <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding PendingAttachments}" Margin="13,0,13,4">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource AccentLine}" BorderThickness="1"
                                                            CornerRadius="10" Padding="6,3" Margin="0,2,6,2" ToolTip="{Binding Path}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <!-- image: rounded thumbnail -->
                                                            <Border Width="26" Height="26" CornerRadius="5" Margin="0,0,6,0"
                                                                    Visibility="{Binding IsImage, Converter={StaticResource BoolVis}}">
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding Path, Converter={StaticResource PathThumb}}" Stretch="UniformToFill"/>
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- doc: glyph -->
                                                            <TextBlock Text="📄" FontSize="13" Margin="1,0,5,0" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding FileName}" FontFamily="{StaticResource Mono}" FontSize="9.5"
                                                                       Foreground="{DynamicResource Txt1}" MaxWidth="160"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                            <Button Content="✕" FontSize="9" Margin="6,0,0,0" Padding="2,0"
                                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                    Foreground="{DynamicResource Txt2}" ToolTip="{StaticResource L.Remove}"
                                                                    Click="RemovePendingImage_Click"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid MinHeight="58">
                                            <TextBox x:Name="ComposerBox" Style="{StaticResource ComposerInput}" MinHeight="58" MaxHeight="160"
                                                     Padding="15,12,15,2"
                                                     VerticalContentAlignment="Top"
                                                     Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}"
                                                     PreviewKeyDown="Composer_PreviewKeyDown"
                                                     TextChanged="ComposerBox_TextChanged"/>
                                            <TextBlock Margin="15,12,15,0" Foreground="{DynamicResource Txt2}" IsHitTestVisible="False"
                                                       FontSize="13.5" LineHeight="20" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Draft}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="{StaticResource L.MessagePrefix}"/><Run Text="{Binding Cli, Mode=OneWay}"/><Run Text="{StaticResource L.MessageSuffix}"/>
                                            </TextBlock>
                                            <Popup x:Name="ComposerSuggestionPopup"
                                                   IsOpen="{Binding DataContext.IsComposerSuggestionOpen, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   PlacementTarget="{Binding ElementName=ComposerBox}"
                                                   Placement="Top"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="False"
                                                   HorizontalOffset="10"
                                                   VerticalOffset="-5">
                                                <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Width="380" MaxHeight="250">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.5" ShadowDepth="3"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <!-- Header -->
                                                        <Border Grid.Row="0" Background="{DynamicResource Bg3}" Padding="10,6" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                                                            <TextBlock Text="{Binding DataContext.ComposerSuggestionHeader, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{DynamicResource Txt1}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource Mono}"/>
                                                        </Border>
                                                        <!-- Suggestions List -->
                                                        <ListBox Grid.Row="1" x:Name="SuggestionList"
                                                                 ItemsSource="{Binding DataContext.ComposerSuggestions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 SelectedItem="{Binding DataContext.SelectedComposerSuggestion, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 MouseDoubleClick="SuggestionList_DoubleClick"
                                                                 KeyDown="SuggestionList_KeyDown"
                                                                 MaxHeight="200" Padding="0,4">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                                    <Setter Property="BorderThickness" Value="0"/>
                                                                    <Setter Property="Padding" Value="10,6"/>
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg3}"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsSelected" Value="true">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                                                        <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,3,0"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Icon/Indicator based on type -->
                                                                        <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Text" Value="📄"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource Txt2}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Session">
                                                                                            <Setter Property="Text" Value="⚡"/>
                                                                                            <Setter Property="Foreground" Value="{DynamicResource Accent}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Type}" Value="Command">
                                                                                            <Setter Property="Text" Value="⚙️"/>
                                                                                            <Setter Property="Foreground" Value="{DynamicResource Info}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <!-- Label -->
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" Foreground="{DynamicResource Txt0}" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource Mono}"/>
                                                                        <!-- Type Text -->
                                                                        <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="{DynamicResource Txt2}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0" FontFamily="{StaticResource Mono}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Grid>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DockPanel>
                                </Border>
                                <DockPanel Margin="4,6,4,0" TextElement.FontFamily="{StaticResource Mono}" TextElement.FontSize="9.5">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.EnterHint}" Foreground="{DynamicResource Txt3}"/>
                                    <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource Txt3}">
                                        <Run Text="{Binding Cli, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding BranchDisplay, Mode=OneWay}"/>
                                    </TextBlock>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- transcript -->
                        <!-- 가상화 필수: 긴 트랜스크립트(CLI 가져오기 수백 블록)에서 보이는 항목만 생성한다.
                             가상화가 동작하려면 ScrollViewer가 ItemsControl 템플릿 안에 있어야 함 -->
                        <ItemsControl x:Name="TranscriptList" ItemsSource="{Binding Transcript}"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel"
                                      PreviewMouseWheel="TranscriptScroll_PreviewMouseWheel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer x:Name="PART_TranscriptScroll" VerticalScrollBarVisibility="Auto" Focusable="False">
                                        <!-- 전폭 사용: 중앙 880px 캡 대신 좌우 최소 여백 (사용자 요청) -->
                                        <ItemsPresenter Margin="14,16,14,12"/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                        </ItemsControl>
                    </DockPanel>
                </Grid>
</UserControl>
