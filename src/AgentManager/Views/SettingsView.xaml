<UserControl x:Class="AgentManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Name="SettingsRoot"
             Background="{DynamicResource Bg0}">
    <UserControl.Resources>
        <!-- "주로 쓰는 모델" 체크리스트 — 엔진 공통(cc/gx/agy/pi). 카드에서 ContentControl로 바인딩. -->
        <DataTemplate DataType="{x:Type vm:ModelChecklistVm}">
            <StackPanel Margin="0,10,0,0">
                <!-- 헤더(클릭하면 펼침/접힘) + 선택 개수 -->
                <ToggleButton Style="{StaticResource ExpanderHeaderToggle}" IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource L.PrimaryModels}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CheckedCount, StringFormat=· {0}}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <!-- 펼침 시 내용: 필터(pi) + 체크리스트 -->
                <StackPanel Margin="0,6,0,0" Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}">
                    <TextBox Style="{StaticResource SettingsInput}" Margin="0,0,0,5"
                             Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding ShowFilter, Converter={StaticResource BoolVis}}"/>
                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" MaxHeight="150" Padding="8,6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Choices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource ModelCheck}" Content="{Binding Model}" IsChecked="{Binding IsChecked, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <!-- 세부 버전 직접 추가 (별칭 목록에 없는 풀네임/핀 버전) -->
                    <DockPanel Margin="0,5,0,0" LastChildFill="True">
                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Margin="5,0,0,0"
                                Content="{StaticResource L.AddModel}" Command="{Binding AddModelCommand}"/>
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding NewModelDraft, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{StaticResource L.AddModelHint}"/>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
                    <DockPanel LastChildFill="True">
                        <!-- header -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel LastChildFill="False">
                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="32" Height="30"
                                        VerticalAlignment="Center" Command="{Binding CancelSettingsCommand}" ToolTip="{StaticResource L.CloseTip}">
                                    <controls:IconView Icon="{StaticResource IconX}" Width="15" Height="15" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource Txt0}"/>
                                </Button>
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconSettings}" Width="16" Height="16" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SettingsSubtitle}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SettingsWorkspace}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </DockPanel>
                        </Border>
                        <!-- footer -->
                        <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,1,0,0" Background="{DynamicResource Bg1}" Padding="16,12">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.Cancel}" Margin="0,0,9,0" Command="{Binding CancelSettingsCommand}"/>
                                    <Button Style="{StaticResource AccentButton}" Content="{StaticResource L.SaveSettings}" Command="{Binding SaveSettingsCommand}"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Margin="0,0,12,0" Command="{Binding OpenSettingsFileCommand}" Content="{StaticResource L.OpenSettingsJson}" ToolTip="{StaticResource L.OpenSettingsJsonTip}"/>
                                <TextBlock Text="{Binding SettingsStatus}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Ok}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <!-- body: TOC + sections -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="168"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="16,18,4,0" TextElement.FontSize="11.5">
                                <TextBlock Text="{StaticResource L.SecRuntimes}" Tag="SecRuntimes" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecTranslation}" Tag="SecTranslation" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecOrchestration}" Tag="SecOrchestration" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecPermissions}" Tag="SecPermissions" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecAppearance}" Tag="SecAppearance" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecProject}" Tag="SecProject" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                                <TextBlock Text="{StaticResource L.SecSkills}" Tag="SecSkills" MouseLeftButtonUp="SettingsToc_Click" Foreground="{DynamicResource Txt1}" Cursor="Hand" Padding="6" Margin="0,0,0,2"/>
                            </StackPanel>

                            <ScrollViewer Grid.Column="1" x:Name="SettingsScroll" VerticalScrollBarVisibility="Auto" Padding="6,0,0,0">
                                <StackPanel Margin="14,18,18,18" MaxWidth="720" HorizontalAlignment="Left">
                                    <!-- 01 Runtimes -->
                                    <StackPanel x:Name="SecRuntimes">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="01" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecRuntimes}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.GuideBtn}" Command="{Binding OpenInstallGuideCommand}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <!-- Claude (cc) -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="5" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,10,0">
                                                        <controls:IconView Icon="{StaticResource IconEngineClaude}" Filled="True" Foreground="{DynamicResource CcBrand}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineCc, Mode=TwoWay}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Claude Code" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                        <TextBlock Text="claude · anthropic · cli" FontSize="10" Foreground="{DynamicResource Txt2}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{Binding ClaudeDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ClaudeDetectLabel}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{StaticResource L.ClaudeCliPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Detect}" Command="{Binding DetectEnginePathCommand}" CommandParameter="cc" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                    <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsClaudePath, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.DefaultModel}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                <ComboBox ItemsSource="{Binding CcModels}" SelectedItem="{Binding SettingsModelCc, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="240"/>
                                                <ContentControl Content="{Binding CcChecklist}"/>
                                                <TextBlock Text="{StaticResource L.Authentication}" Style="{StaticResource Lbl}" Margin="0,12,0,6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="cc:subscription" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6" Margin="0,0,8,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthCc}" Value="subscription"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.AuthSubscription}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                    </Border>
                                                    <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="cc:api" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthCc}" Value="api"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.AuthApiKey}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                    </Border>
                                                </StackPanel>
                                                <DockPanel>
                                                    <DockPanel.Style>
                                                        <Style TargetType="DockPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding SettingsAuthCc}" Value="subscription"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                                                    </DockPanel.Style>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Command="{Binding SignInCommand}" CommandParameter="cc" Content="{StaticResource L.SignIn}" VerticalAlignment="Center"/>
                                                    <Grid VerticalAlignment="Center">
                                                        <TextBlock Text="{StaticResource L.AuthCliManaged}" FontSize="9.5" Foreground="{DynamicResource Txt3}" TextWrapping="Wrap">
                                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CcAccount}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                        </TextBlock>
                                                        <StackPanel Orientation="Horizontal">
                                                            <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding CcAccount}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                            <controls:IconView Icon="{StaticResource IconCheck}" Width="12" Height="12" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding CcAccount}" FontSize="10.5" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DockPanel>
                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding SettingsAuthCc}" Value="api"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                                                    </StackPanel.Style>
                                                    <PasswordBox Style="{StaticResource ApiKeyBox}" controls:PasswordBoxAssistant.BoundPassword="{Binding SettingsApiKeyCc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="{StaticResource L.ApiKeyHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,10,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsAutoApiCc, Mode=TwoWay}" Content="{StaticResource L.AutoApiOnLimit}" ToolTip="{StaticResource L.AutoApiOnLimitTip}"/>
                                                <TextBlock Text="{StaticResource L.AutoApiOnLimitDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Codex (gx) -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,10">
                                                    <Border DockPanel.Dock="Left" Width="28" Height="28" CornerRadius="5" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,10,0">
                                                        <controls:IconView Icon="{StaticResource IconEngineOpenAi}" Filled="True" Foreground="{DynamicResource GxBrand}" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineGx, Mode=TwoWay}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Codex" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                        <TextBlock Text="codex · openai · cli" FontSize="10" Foreground="{DynamicResource Txt2}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{Binding CodexDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding CodexDetectLabel}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{StaticResource L.CodexCliPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Detect}" Command="{Binding DetectEnginePathCommand}" CommandParameter="gx" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                    <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsCodexPath, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.DefaultModel}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                <ComboBox ItemsSource="{Binding GxModels}" SelectedItem="{Binding SettingsModelGx, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="240"/>
                                                <ContentControl Content="{Binding GxChecklist}"/>
                                                <TextBlock Text="{StaticResource L.Authentication}" Style="{StaticResource Lbl}" Margin="0,12,0,6"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="gx:subscription" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6" Margin="0,0,8,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthGx}" Value="subscription"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.AuthSubscription}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                    </Border>
                                                    <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="gx:api" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthGx}" Value="api"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{StaticResource L.AuthApiKey}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                    </Border>
                                                </StackPanel>
                                                <DockPanel>
                                                    <DockPanel.Style>
                                                        <Style TargetType="DockPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding SettingsAuthGx}" Value="subscription"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                                                    </DockPanel.Style>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Command="{Binding SignInCommand}" CommandParameter="gx" Content="{StaticResource L.SignIn}" VerticalAlignment="Center"/>
                                                    <Grid VerticalAlignment="Center">
                                                        <TextBlock Text="{StaticResource L.AuthCliManaged}" FontSize="9.5" Foreground="{DynamicResource Txt3}" TextWrapping="Wrap">
                                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding GxAccount}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                                        </TextBlock>
                                                        <StackPanel Orientation="Horizontal">
                                                            <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding GxAccount}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                            <controls:IconView Icon="{StaticResource IconCheck}" Width="12" Height="12" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding GxAccount}" FontSize="10.5" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DockPanel>
                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding SettingsAuthGx}" Value="api"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                                                    </StackPanel.Style>
                                                    <PasswordBox Style="{StaticResource ApiKeyBox}" controls:PasswordBoxAssistant.BoundPassword="{Binding SettingsApiKeyGx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="{StaticResource L.ApiKeyHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,10,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsAutoApiGx, Mode=TwoWay}" Content="{StaticResource L.AutoApiOnLimit}" ToolTip="{StaticResource L.AutoApiOnLimitTip}"/>
                                                <TextBlock Text="{StaticResource L.AutoApiOnLimitDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Antigravity auto-detect -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="5" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                                            <controls:IconView Icon="{StaticResource IconEngineAgy}" Filled="True" Foreground="{DynamicResource AgyGradient}" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEngineAgy, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Antigravity" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding AgyDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding AgyDetectLabel}"/>
                                                    <TextBlock Text="{StaticResource L.AgyCliPath}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Detect}" Command="{Binding DetectEnginePathCommand}" CommandParameter="agy" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsAgyPath, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DockPanel>
                                                    <ComboBox ItemsSource="{Binding AgyModels}" SelectedItem="{Binding SettingsModelAgy, Mode=TwoWay}" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                                    <ContentControl Content="{Binding AgyChecklist}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding AgyAccount}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                                                        <controls:IconView Icon="{StaticResource IconCheck}" Width="12" Height="12" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding AgyAccount}" FontSize="10.5" Foreground="{DynamicResource Ok}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Button Style="{StaticResource ChipButton}" Command="{Binding SignInCommand}" CommandParameter="agy" Content="{StaticResource L.SignIn}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                                    <!-- 인증 모드: subscription(CLI/ConPTY, 구독) vs API(Antigravity SDK, Gemini API 과금). cc/gx 블록과 동일 구조. -->
                                                    <TextBlock Text="{StaticResource L.Authentication}" Style="{StaticResource Lbl}" Margin="0,12,0,6"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="agy:subscription" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6" Margin="0,0,8,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                    <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthAgy}" Value="subscription"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{StaticResource L.AuthSubscription}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                        </Border>
                                                        <Border controls:MouseClick.Command="{Binding AuthModeCommand}" controls:MouseClick.CommandParameter="agy:api" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,6">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{DynamicResource Bg1}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                                    <Style.Triggers><DataTrigger Binding="{Binding SettingsAuthAgy}" Value="api"><Setter Property="Background" Value="{DynamicResource AccentDim}"/><Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/></DataTrigger></Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{StaticResource L.AuthApiKey}" FontSize="11" Foreground="{DynamicResource Txt0}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding SettingsAuthAgy}" Value="api"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                                                        </StackPanel.Style>
                                                        <PasswordBox Style="{StaticResource ApiKeyBox}" controls:PasswordBoxAssistant.BoundPassword="{Binding SettingsApiKeyAgy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        <TextBlock Text="{StaticResource L.AgyApiKeyHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{StaticResource L.AgyApiBillsViaGemini}" FontSize="9.5" Foreground="{DynamicResource Warn}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,10,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsAutoApiAgy, Mode=TwoWay}" Content="{StaticResource L.AutoApiOnLimit}" ToolTip="{StaticResource L.AutoApiOnLimitTip}"/>
                                                    <TextBlock Text="{StaticResource L.AutoApiOnLimitDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                        </Border>
                                        <!-- pi(pi.dev): 멀티 provider. node cli.js RPC 모드. provider·인증은 pi 자체 관리(~/.pi) -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,6">
                                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="5" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                                            <controls:IconView Icon="{StaticResource IconEnginePi}" Filled="True" Foreground="{DynamicResource PiBrand}" Width="15" Height="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource TogglePillButton}" Content="{StaticResource L.EngineEnabled}" IsChecked="{Binding SettingsEnginePi, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Pi" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding PiDetectLabel}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis" ToolTip="{Binding PiDetectLabel}"/>
                                                    <TextBlock Text="{StaticResource L.PiCliPath}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Detect}" Command="{Binding DetectEnginePathCommand}" CommandParameter="pi" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsPiPath, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DockPanel>
                                                    <DockPanel Margin="0,10,0,0">
                                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.QueryModels}" Command="{Binding QueryPiModelsCommand}" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                        <ComboBox IsEditable="True" ItemsSource="{Binding PiModels}" Text="{Binding SettingsModelPi, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding PiModelsStatus}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0"/>
                                                    <TextBlock Text="{Binding PiConnectedProviders}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="2,6,0,0" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{StaticResource L.PiProviderNote}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,8,0,0" TextWrapping="Wrap"/>
                                                    <ContentControl Content="{Binding PiChecklist}"/>
                                                </StackPanel>
                                        </Border>
                                        <!-- Usage check -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Command="{Binding CheckUsageCommand}" ToolTip="{StaticResource L.CheckUsage}" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconView Icon="{StaticResource IconRefresh}" Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{StaticResource L.CheckUsage}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Border DockPanel.Dock="Left" Width="30" Height="30" CornerRadius="6" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,10,0">
                                                    <controls:IconView Icon="{StaticResource IconClock}" Width="15" Height="15" Foreground="{DynamicResource Accent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{StaticResource L.UsageCheckTitle}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                    <TextBlock Text="{StaticResource L.UsageCheckDesc}" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="0,2,0,6" TextWrapping="Wrap"/>
                                                    <!-- 엔진별 사용량 막대 -->
                                                    <ItemsControl ItemsSource="{Binding UsageRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,7">
                                                                    <DockPanel>
                                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="10.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                                        <TextBlock Text="{Binding Note}" HorizontalAlignment="Right" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt3}" TextTrimming="CharacterEllipsis"/>
                                                                    </DockPanel>
                                                                    <ItemsControl ItemsSource="{Binding Bars}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,3,0,0">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="34"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="38"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="9" Foreground="{DynamicResource Txt3}" VerticalAlignment="Center"/>
                                                                                    <Border Grid.Column="1" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="4" Height="8" VerticalAlignment="Center">
                                                                                        <Grid>
                                                                                            <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="{Binding FillStar}"/>
                                                                                                <ColumnDefinition Width="{Binding RestStar}"/>
                                                                                            </Grid.ColumnDefinitions>
                                                                                            <Border Grid.Column="0" CornerRadius="4">
                                                                                                <Border.Style>
                                                                                                    <Style TargetType="Border">
                                                                                                        <Setter Property="Background" Value="{DynamicResource Ok}"/>
                                                                                                        <Style.Triggers>
                                                                                                            <DataTrigger Binding="{Binding Level}" Value="warn"><Setter Property="Background" Value="{DynamicResource Warn}"/></DataTrigger>
                                                                                                            <DataTrigger Binding="{Binding Level}" Value="crit"><Setter Property="Background" Value="{DynamicResource Err}"/></DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                    </Style>
                                                                                                </Border.Style>
                                                                                            </Border>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                    <TextBlock Grid.Column="2" Text="{Binding Percent, StringFormat={}{0}%}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Txt1}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- 확인 중 / 데이터 없음 fallback -->
                                                    <TextBlock Text="{Binding UsageStatusText}" Visibility="{Binding UsageFallbackVisible}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Txt2}" TextWrapping="Wrap"/>
                                                    <!-- 안내: 비공식 추정치 -->
                                                    <TextBlock Text="{StaticResource L.UsageApproxNote}" FontSize="9" Foreground="{DynamicResource Txt3}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 02 Translation (ours) -->
                                    <StackPanel x:Name="SecTranslation" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="02" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecTranslation}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <!-- UI 언어 -->
                                                <TextBlock Text="{StaticResource L.UiLanguage}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt1}"/>
                                                <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedValuePath="Id" SelectedValue="{Binding SettingsLanguage, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="200" Margin="0,4,0,0">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{StaticResource L.EnglishUiTip}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" TextWrapping="Wrap"/>

                                                <Border Height="1" Background="{DynamicResource LineSoft}" Margin="0,14"/>

                                                <!-- 번역 전/후 언어 -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{StaticResource L.TranslateSource}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt1}"/>
                                                        <TextBlock Text="{StaticResource L.TranslateSourceDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                                        <ComboBox ItemsSource="{Binding AvailableTranslationLanguages}" SelectedValuePath="Id" SelectedValue="{Binding SettingsTranslateSource, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{StaticResource L.TranslateTarget}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt1}"/>
                                                        <TextBlock Text="{StaticResource L.TranslateTargetDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,2,0,4" TextWrapping="Wrap"/>
                                                        <ComboBox ItemsSource="{Binding AvailableTranslationLanguages}" SelectedValuePath="Id" SelectedValue="{Binding SettingsTranslateTarget, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Height="1" Background="{DynamicResource LineSoft}" Margin="0,14"/>

                                                <!-- Translation provider picker: Ollama / installed agent (cc/gx/pi) / custom OpenAI-compatible -->
                                                <TextBlock Text="{StaticResource L.TranslationProvider}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding TranslationProviders}" SelectedValuePath="Id" SelectedValue="{Binding SettingsTranslationSelectedId, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{StaticResource L.TranslationProviderDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{StaticResource L.CustomProviderWarning}" FontSize="9.5" Foreground="{DynamicResource Warn}" TextWrapping="Wrap" Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCustomProviderSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Ollama config — visible only when the Ollama provider is selected -->
                                                <StackPanel Margin="0,12,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsTranslationSelectedId}" Value="ollama"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                <TextBlock Text="{StaticResource L.Endpoint}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsOllamaEndpoint, UpdateSourceTrigger=PropertyChanged}"/>
                                                <!-- Ollama 서비스 상태 + 제어 -->
                                                <DockPanel Margin="0,8,0,0">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.Refresh}" Command="{Binding RefreshOllamaStatusCommand}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    <Button DockPanel.Dock="Right" Command="{Binding StartOllamaCommand}" Content="{StaticResource L.OllamaStart}" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ChipButton}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding OllamaStopped}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                    </Button>
                                                    <Button DockPanel.Dock="Right" Command="{Binding OpenInstallGuideCommand}" Content="{StaticResource L.InstallGuide}" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ChipButton}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding OllamaAbsent}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                    </Button>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{DynamicResource Txt3}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding OllamaRunning}" Value="True"><Setter Property="Fill" Value="{DynamicResource Ok}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding OllamaStopped}" Value="True"><Setter Property="Fill" Value="{DynamicResource Warn}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding OllamaAbsent}" Value="True"><Setter Property="Fill" Value="{DynamicResource Err}"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding OllamaStatusText}" FontSize="10.5" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.TranslationModel}" Style="{StaticResource Lbl}" Margin="0,10,0,6"/>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.QueryModels}" Command="{Binding QueryOllamaModelsCommand}" VerticalAlignment="Top" Margin="8,0,0,0"/>
                                                    <ComboBox IsEditable="True" ItemsSource="{Binding OllamaModels}" Text="{Binding SettingsOllamaModel, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding OllamaModelsStatus}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0"/>
                                                <TextBlock Text="{StaticResource L.TranslationTimeout}" Style="{StaticResource Lbl}" Margin="0,12,0,6"/>
                                                <ComboBox ItemsSource="{Binding OllamaTimeoutOptions}" SelectedItem="{Binding SettingsOllamaTimeoutSeconds}" HorizontalAlignment="Left" MinWidth="130">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding StringFormat={}{0} s}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Text="{StaticResource L.TranslationTimeoutTip}" FontSize="9.5" Foreground="{DynamicResource Txt3}" TextWrapping="Wrap" Margin="2,4,0,0"/>
                                                </StackPanel>

                                                <!-- Agent provider: which model translates (visible when an agent provider is selected) -->
                                                <StackPanel Margin="0,12,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAgentProviderSelected}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{StaticResource L.AgentTranslationModel}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                    <ComboBox IsEditable="True" ItemsSource="{Binding TranslationAgentModels}" Text="{Binding SettingsTranslationAgentModel, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>

                                                <!-- Custom OpenAI-compatible endpoints: existing entries + add form -->
                                                <ItemsControl ItemsSource="{Binding CustomTranslationProviders}" Margin="0,12,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                                                <DockPanel LastChildFill="True">
                                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Content="{StaticResource L.RemoveCustom}"
                                                                            Command="{Binding DataContext.RemoveCustomProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"/>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}" FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock FontSize="9.5" FontFamily="{StaticResource Mono}" Foreground="{DynamicResource Txt3}" TextTrimming="CharacterEllipsis">
                                                                            <Run Text="{Binding Endpoint}"/><Run Text=" · "/><Run Text="{Binding Model}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Expander Header="{StaticResource L.AddCustomEndpoint}" Margin="0,4,0,0" Foreground="{DynamicResource Txt1}">
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock Text="{StaticResource L.CustomNameHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding NewCustomName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                                        <TextBlock Text="{StaticResource L.CustomEndpointHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding NewCustomEndpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,4"/>
                                                        <TextBlock Text="{StaticResource L.RemoteEndpointWarning}" FontSize="9.5" Foreground="{DynamicResource Warn}" TextWrapping="Wrap" Margin="0,0,0,6">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsNewCustomEndpointRemote}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{StaticResource L.CustomModelHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding NewCustomModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6"/>
                                                        <TextBlock Text="{StaticResource L.CustomKeyHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                                                        <TextBox Style="{StaticResource SettingsInput}" Text="{Binding NewCustomKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>
                                                        <Button Style="{StaticResource ChipButton}" HorizontalAlignment="Left" Content="{StaticResource L.AddCustomEndpoint}" Command="{Binding AddCustomProviderCommand}"/>
                                                    </StackPanel>
                                                </Expander>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,12,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsDefaultTranslationEnabled, Mode=TwoWay}" Content="{StaticResource L.DefaultTranslation}" ToolTip="{StaticResource L.DefaultTranslationTip}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 03 Orchestration -->
                                    <StackPanel x:Name="SecOrchestration" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="03" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecOrchestration}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.ConcurrentLimit}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Width="120" HorizontalAlignment="Left" Text="{Binding MaxConcurrentSessions, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.MaxWorkers}" Style="{StaticResource Lbl}" Margin="0,12,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Width="120" HorizontalAlignment="Left" Text="{Binding MaxConcurrentWorkers, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.MaxWorkersDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" Margin="0,12,0,0" HorizontalAlignment="Left" IsChecked="{Binding SettingsWarnNoWorktree, Mode=TwoWay}" Content="{StaticResource L.NonGitNotice}" ToolTip="{StaticResource L.NonGitNoticeTip}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.WorktreeBase}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Text="{Binding SettingsWorktreeBase, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.WorktreeBaseHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <ToggleButton Style="{StaticResource TogglePillButton}" IsChecked="{Binding SettingsAutoStart, Mode=TwoWay}" Content="{StaticResource L.AutoStartLast}"/>
                                                    <ToggleButton Style="{StaticResource TogglePillButton}" Margin="8,0,0,0" IsChecked="{Binding SettingsStreamLogs, Mode=TwoWay}" Content="{StaticResource L.StreamLogsToggle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <!-- 워커 행동 규칙 기본 템플릿 -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.WorkerPreamble}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Text="{Binding WorkerBehaviorPreamble, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
                                                <TextBlock Text="{StaticResource L.WorkerPreambleDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 04 Permissions -->
                                    <StackPanel x:Name="SecPermissions" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="04" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecPermissions}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.ApprovalPolicyTitle}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.ApprovalPolicyDesc}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,2,0,10" TextWrapping="Wrap"/>
                                                <!-- ask -->
                                                <Border controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="policy:ask" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9" Margin="0,0,0,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="ask">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicyAsk}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicyAskSub}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- safe -->
                                                <Border controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="policy:safe" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9" Margin="0,0,0,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="safe">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentLine}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicySafe}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicySafeSub}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- yolo -->
                                                <Border controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="policy:yolo" Cursor="Hand" BorderThickness="1" CornerRadius="6" Padding="11,9">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource Bg1}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SettingsApprovalPolicy}" Value="yolo">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentDim}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{StaticResource L.PolicyYolo}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                        <TextBlock Text="{StaticResource L.PolicyYoloSub}" FontSize="10" Foreground="{DynamicResource Txt2}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="{StaticResource L.PermNetworkNote}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Privacy: 익명 텔레메트리 (데이터 공유는 권한/프라이버시 영역) -->
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.Privacy}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" Margin="0,0,0,8"/>
                                                <ToggleButton Style="{StaticResource TogglePillButton}" HorizontalAlignment="Left" IsChecked="{Binding SettingsTelemetry, Mode=TwoWay}" Content="{StaticResource L.Telemetry}"/>
                                                <TextBlock Text="{StaticResource L.TelemetryDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 05 Appearance -->
                                    <StackPanel x:Name="SecAppearance" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="05" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecAppearance}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.Theme}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.ThemeDesc}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,2,0,10"/>
                                                <ItemsControl ItemsSource="{Binding AvailableThemes}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="6" Padding="11,6" Margin="0,0,8,8" Cursor="Hand" Background="{DynamicResource Bg1}" BorderThickness="1"
                                                                    controls:MouseClick.Command="{Binding DataContext.ThemeSelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    controls:MouseClick.CommandParameter="{Binding Id}">
                                                                <Border.BorderBrush>
                                                                    <MultiBinding Converter="{StaticResource SelBrush}">
                                                                        <Binding Path="Id"/>
                                                                        <Binding Path="DataContext.SettingsTheme" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                    </MultiBinding>
                                                                </Border.BorderBrush>
                                                                <TextBlock Text="{Binding Name}" FontSize="11.5" Foreground="{DynamicResource Txt0}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <!-- Accent color -->
                                                <TextBlock Text="{StaticResource L.AccentColor}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.AccentColorDesc}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,2,0,10"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Resources>
                                                        <Style TargetType="Border" x:Key="Swatch">
                                                            <Setter Property="Width" Value="26"/>
                                                            <Setter Property="Height" Value="26"/>
                                                            <Setter Property="CornerRadius" Value="13"/>
                                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="ember"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="ember"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="amber"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="amber"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="teal"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="teal"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="azure"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="azure"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="violet"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="violet"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="coral"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="coral"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="green"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="green"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                                <MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding SettingsAccent}" Value="cobalt"/><Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="cobalt"/></MultiDataTrigger.Conditions><Setter Property="BorderBrush" Value="{DynamicResource Txt0}"/></MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Resources>
                                                    <Border Style="{StaticResource Swatch}" Tag="ember"  Background="#FFFF5A2C" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:ember" ToolTip="Ember"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="amber"  Background="#FFF5B531" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:amber" ToolTip="Amber"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="teal"   Background="#FF2BD4C4" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:teal" ToolTip="Teal"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="azure"  Background="#FF5B8CFF" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:azure" ToolTip="Azure"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="violet" Background="#FFA87BFF" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:violet" ToolTip="Violet"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="coral"  Background="#FFD97757" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:coral" ToolTip="Coral (Claude)"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="green"  Background="#FF10A37F" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:green" ToolTip="Green (Codex)"/>
                                                    <Border Style="{StaticResource Swatch}" Tag="cobalt" Background="#FF4285F4" controls:MouseClick.Command="{Binding SettingsSegCommand}" controls:MouseClick.CommandParameter="accent:cobalt" ToolTip="Cobalt (Antigravity)"/>
                                                </StackPanel>
                                                <!-- 커스텀 강조색 (hex) -->
                                                <DockPanel Margin="0,10,0,0">
                                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.AccentCustom}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Style="{StaticResource SettingsInput}" Width="150" HorizontalAlignment="Left"
                                                             Text="{Binding SettingsAccentCustom, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DockPanel>
                                                <!-- UI Zoom (Ctrl+휠) -->
                                                <TextBlock Text="{StaticResource L.Zoom}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" Margin="0,16,0,2"/>
                                                <TextBlock Text="{StaticResource L.ZoomDesc}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,0,0,8"/>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right" VerticalAlignment="Top" Style="{StaticResource ChipButton}"
                                                            Content="{StaticResource L.ZoomReset}" Command="{Binding ZoomResetAllCommand}"/>
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,6">
                                                            <TextBlock DockPanel.Dock="Left" Width="48" Text="{StaticResource L.ZoomBody}" FontSize="11.5" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center"/>
                                                            <ComboBox HorizontalAlignment="Left" MinWidth="92" ItemsSource="{Binding ZoomPercentOptions}" SelectedItem="{Binding BodyScalePercent, Mode=TwoWay}">
                                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat={}{0}%}"/></DataTemplate></ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </DockPanel>
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Left" Width="48" Text="{StaticResource L.ZoomModal}" FontSize="11.5" Foreground="{DynamicResource Txt1}" VerticalAlignment="Center"/>
                                                            <ComboBox HorizontalAlignment="Left" MinWidth="92" ItemsSource="{Binding ZoomPercentOptions}" SelectedItem="{Binding ModalScalePercent, Mode=TwoWay}">
                                                                <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat={}{0}%}"/></DataTemplate></ComboBox.ItemTemplate>
                                                            </ComboBox>
                                                        </DockPanel>
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Text="{StaticResource L.ZoomHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>


                                    <!-- 06 Project (ours) -->
                                    <StackPanel x:Name="SecProject" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="06" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecProject}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,0,0,12" TextWrapping="Wrap">
                                                    <Run Text="{StaticResource L.ProjectScopeDesc}"/><Run Text=" "/><Run Text="{Binding ActiveProject.Name, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource Accent}"/>
                                                </TextBlock>
                                                <TextBlock Text="{StaticResource L.McpConfigPath}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" Text="{Binding ActiveProject.McpConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="{StaticResource L.McpConfigDesc}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,4,0,0" TextWrapping="Wrap"/>
                                                <DockPanel Margin="0,14,0,0">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" ToolTip="{StaticResource L.AddExtraPathTip}" Click="AddExtraPath_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{StaticResource L.AddFolder}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <TextBlock Text="{StaticResource L.ExtraFolders}" Style="{StaticResource Lbl}" VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding ActiveProject.ExtraPaths}" Margin="0,8,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,0,0,4">
                                                                <Button DockPanel.Dock="Right" Style="{StaticResource MenuButton}" Width="26" ToolTip="{StaticResource L.Remove}" Command="{Binding DataContext.RemoveExtraPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                    <controls:IconView Icon="{StaticResource IconX}" Width="10" Height="10"/>
                                                                </Button>
                                                                <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="9,6" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Txt1}" TextTrimming="CharacterEllipsis"/>
                                                                </Border>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 07 Skills (engine skill injection) -->
                                    <StackPanel x:Name="SecSkills" Margin="0,14,0,0">
                                        <DockPanel Margin="0,0,0,10">
                                            <TextBlock DockPanel.Dock="Left" Text="07" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.SecSkills}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                            <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        </DockPanel>
                                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.SkillInjectDesc}" FontSize="10.5" Foreground="{DynamicResource Txt2}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                                <TextBlock Text="{StaticResource L.SkillContent}" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>
                                                <TextBox Style="{StaticResource SettingsInput}" AcceptsReturn="True" TextWrapping="NoWrap"
                                                         MinHeight="180" MaxHeight="340" FontFamily="{StaticResource Mono}" FontSize="11"
                                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                                         Text="{Binding SettingsSkillContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBlock Text="{StaticResource L.SkillDirs}" Style="{StaticResource Lbl}" Margin="0,14,0,6"/>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="cc" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource CcBrand}" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding SettingsSkillDirCc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="gx" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource GxBrand}" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding SettingsSkillDirGx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="agy" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource AgyBrand}" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding SettingsSkillDirAgy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="pi" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource PiBrand}" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsInput}" Text="{Binding SettingsSkillDirPi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <TextBlock Text="{StaticResource L.SkillInjectNote}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="2,8,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SkillInjectStatus}" FontFamily="{StaticResource Mono}" FontSize="10.5" Foreground="{DynamicResource Ok}" Margin="0,8,0,0" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SkillInjectStatus}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
</UserControl>
