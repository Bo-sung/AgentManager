<UserControl x:Class="AgentManager.Views.ModelManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             Background="{DynamicResource Bg0}">
    <UserControl.Resources>
        <!-- One engine's section: name + model rows + bulk-add -->
        <DataTemplate DataType="{x:Type vm:EngineModelsVm}">
            <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding EngineName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding EngineId}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt3}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </DockPanel>

                    <!-- column headers -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{StaticResource L.MmModel}" FontSize="9.5" Foreground="{DynamicResource Txt3}"/>
                        <TextBlock Grid.Column="1" Text="{StaticResource L.MmPreferred}" FontSize="9.5" Foreground="{DynamicResource Txt3}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{StaticResource L.MmDefault}" FontSize="9.5" Foreground="{DynamicResource Txt3}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{StaticResource L.MmEffort}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Visibility="{Binding HasEfforts, Converter={StaticResource BoolVis}}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Models}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ManagedModelVm}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Id}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Id}"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding Preferred, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsDefault, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="3" ItemsSource="{Binding EffortOptions}" SelectedItem="{Binding DefaultEffort, Mode=TwoWay}"
                                              Visibility="{Binding HasEfforts, Converter={StaticResource BoolVis}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Button Grid.Column="4" Style="{StaticResource MenuButton}" Width="24" Height="24" Command="{Binding RemoveCommand}" ToolTip="{StaticResource L.MmRemove}" VerticalAlignment="Center">
                                        <controls:IconView Icon="{StaticResource IconX}" Width="11" Height="11" Foreground="{DynamicResource Txt2}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- bulk add: newline / comma separated ids -->
                    <TextBlock Text="{StaticResource L.MmAddHint}" FontSize="9.5" Foreground="{DynamicResource Txt3}" Margin="0,10,0,4" TextWrapping="Wrap"/>
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Margin="6,0,0,0" VerticalAlignment="Top"
                                Content="{StaticResource L.MmAdd}" Command="{Binding AddCommand}"/>
                        <TextBox Style="{StaticResource SettingsInput}" AcceptsReturn="True" TextWrapping="Wrap" MinLines="1" MaxHeight="80"
                                 VerticalScrollBarVisibility="Auto" Text="{Binding NewModelsDraft, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel LastChildFill="True">
        <!-- header -->
        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Left" Style="{StaticResource ChipButton}" Command="{Binding CloseModelManagerCommand}" VerticalAlignment="Center" Margin="0,0,10,0"
                        Content="{StaticResource L.MmBack}"/>
                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconSettings}" Width="15" Height="15" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.MmTitle}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.MmSubtitle}" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="18" MaxWidth="760" HorizontalAlignment="Left">
                <ItemsControl ItemsSource="{Binding ModelManagerEngines}"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
