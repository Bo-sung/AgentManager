<UserControl x:Class="AgentManager.Views.OrchestratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Name="ViewRoot"
             Background="{DynamicResource Bg0}">
    <Grid>
                    <Grid.Resources>
                        <!-- Spark Animation (5 staggered bars equalizer style scale) -->
                        <Storyboard x:Key="SparkStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.13">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar3" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.26">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar4" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.39">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar5" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.52">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>

                        <!-- shared orchestrator session card (live + recent) -->
                        <DataTemplate x:Key="OrchCardTemplate">
                            <Border Width="236" Margin="0,0,12,12" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="12"
                                    controls:BorderHover.Brush="{DynamicResource AccentLine}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLive}" Value="False">
                                                <Setter Property="Opacity" Value="0.72"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel LastChildFill="True">
                                    <!-- Head -->
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4" Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                            <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Margin="0,0,5,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource Txt3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Foreground" Value="{DynamicResource Accent}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Foreground" Value="{DynamicResource Warn}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Foreground" Value="{DynamicResource Ok}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Foreground" Value="{DynamicResource Err}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <controls:StatusDot Status="{Binding Status}" VerticalAlignment="Center" Margin="-5,0"/>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AgentName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}"/>
                                            <TextBlock Text="{Binding Model}" FontSize="9" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Foot -->
                                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="10" Height="10" Foreground="{DynamicResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TokensLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4"
                                                Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{StaticResource L.OpenSessionBtn}" FontSize="10" VerticalAlignment="Center"/>
                                                <controls:IconView Icon="{StaticResource IconChevRight}" Width="11" Height="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4" Margin="0,0,6,0" Command="{Binding DataContext.OpenSessionReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:IconView Icon="{StaticResource IconLayers}" Width="10" Height="10" Foreground="{DynamicResource Txt1}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{StaticResource L.OrchDiff}" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>

                                    <!-- Body -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <controls:IconView Icon="{StaticResource IconBranch}" Width="10" Height="10" Foreground="{DynamicResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BranchTail}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RunningElapsedLabel}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Accent}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="9" Margin="0,0,8,0">
                                                <Border x:Name="Bar1" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar2" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar3" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar4" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar5" Width="2" Height="9" Background="{DynamicResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{DynamicResource Accent}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiff}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Border Height="5" CornerRadius="2.5" Background="{DynamicResource Bg4}" Margin="0,6,0,4" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding DiffAddedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemovedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemainderStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{DynamicResource Add}"/>
                                                    <Border Grid.Column="1" Background="{DynamicResource Del}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="10">
                                                <Run Text="+" Foreground="{DynamicResource Add}"/><Run Text="{Binding DiffAdded, Mode=OneWay}" Foreground="{DynamicResource Add}"/>
                                                <Run Text=" "/>
                                                <Run Text="−" Foreground="{DynamicResource Del}"/><Run Text="{Binding DiffRemoved, Mode=OneWay}" Foreground="{DynamicResource Del}"/>
                                                <Run Text=" · " Foreground="{DynamicResource Txt2}"/>
                                                <Run Text="{Binding DiffFiles, Mode=OneWay}" Foreground="{DynamicResource Txt2}"/>
                                                <Run Text=" " Foreground="{DynamicResource Txt2}"/>
                                                <Run Text="{Binding FilesSuffix, Mode=OneWay}" Foreground="{DynamicResource Txt2}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- 실행 중 이퀄라이저: Style이 아닌 DataTemplate.Triggers에서 시작해야 TargetName(Bar*) 해석 가능 -->
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="SparkAnimation" Storyboard="{StaticResource SparkStoryboard}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SparkAnimation"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </Grid.Resources>
                    <DockPanel LastChildFill="True">
                        <!-- Head -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{DynamicResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel LastChildFill="False">
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconGrid}" Width="16" Height="16" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Orchestrator}" FontSize="13.5" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <Run Text="· "/><Run Text="{StaticResource L.OrchSubtitle}"/></TextBlock>
                                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Command="{Binding NewAgentCommand}" VerticalAlignment="Center" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11" Foreground="{DynamicResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.NewAgent}" Foreground="{DynamicResource AccentText}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>

                        <!-- Scrollable view -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16" HorizontalAlignment="Stretch">
                                <!-- KPIs -->
                                <UniformGrid Columns="5" Rows="1" Height="78" Margin="0,0,0,22">
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiActive}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding RunningCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiActiveSub}" FontSize="9" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiAwaiting}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Warn}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding WaitingCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiAwaitingSub}" FontSize="9" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiCompleted}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Ok}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding DoneCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiCompletedSub}" FontSize="9" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFailed}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Err}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding FailedCount}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiFailedSub}" FontSize="9" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource AccentLine}" BorderThickness="1" CornerRadius="6" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFleet}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Txt1}" Margin="0,0,0,3" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FleetThroughputLabel}" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Accent}"/>
                                                <TextBlock Text="{StaticResource L.KpiFleetSub}" FontSize="9" Foreground="{DynamicResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- Worker backlog (from the worker-prompt skill's task spool) -->
                                <StackPanel Margin="0,0,0,8" Visibility="{Binding HasWorkerTasks, Converter={StaticResource BoolVis}}">
                                    <DockPanel Margin="0,8,0,8">
                                        <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.WorkerBacklog}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}"/>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding BacklogCount}" Style="{StaticResource CodeChip}"/>
                                        <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding BacklogTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="6" Padding="11,8" Margin="0,0,0,6">
                                                    <DockPanel>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                                                            <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.AssignToWorker}"
                                                                    Command="{Binding DataContext.AssignTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                            <Button Style="{StaticResource MenuButton}" Width="28" Margin="4,0,0,0" ToolTip="{StaticResource L.Remove}"
                                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                <controls:IconView Icon="{StaticResource IconX}" Width="11" Height="11"/>
                                                            </Button>
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <Border DockPanel.Dock="Left" Background="{DynamicResource AccentDim}" CornerRadius="3" Padding="5,0" Margin="0,0,7,0"
                                                                        VerticalAlignment="Center" Visibility="{Binding HasEngine, Converter={StaticResource BoolVis}}">
                                                                    <TextBlock Text="{Binding EngineLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Accent}"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" FontSize="12.5" TextTrimming="CharacterEllipsis"/>
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding PromptPreview}" Foreground="{DynamicResource Txt2}" FontSize="10.5" TextWrapping="Wrap" MaxHeight="44" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- per-worker queues -->
                                    <DockPanel Margin="0,8,0,8" Visibility="{Binding HasWorkerQueues, Converter={StaticResource BoolVis}}">
                                        <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.WorkerQueues}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}"/>
                                        <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding WorkerQueues}" Visibility="{Binding HasWorkerQueues, Converter={StaticResource BoolVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="7" Padding="9,8" Margin="0,0,0,7">
                                                    <StackPanel>
                                                        <!-- queue header: worker + run-all -->
                                                        <DockPanel Margin="0,0,0,6">
                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                <Button Style="{StaticResource ChipButton}" Content="{StaticResource L.RunQueue}"
                                                                        Command="{Binding DataContext.RunQueueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                <Button Style="{StaticResource MenuButton}" Width="28" Margin="4,0,0,0" ToolTip="{StaticResource L.ClearFinished}"
                                                                        Visibility="{Binding HasFinished, Converter={StaticResource BoolVis}}"
                                                                        Command="{Binding DataContext.ClearFinishedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                    <controls:IconView Icon="{StaticResource IconCheck}" Width="11" Height="11"/>
                                                                </Button>
                                                            </StackPanel>
                                                            <Border DockPanel.Dock="Left" Background="{DynamicResource AccentDim}" CornerRadius="3" Padding="5,0" Margin="0,0,7,0"
                                                                    VerticalAlignment="Center" Visibility="{Binding HasEngine, Converter={StaticResource BoolVis}}">
                                                                <TextBlock Text="{Binding EngineLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Accent}"/>
                                                            </Border>
                                                            <TextBlock DockPanel.Dock="Left" Text="{Binding WorkerName}" FontWeight="SemiBold" Foreground="{DynamicResource Txt0}" FontSize="12.5" VerticalAlignment="Center"/>
                                                            <TextBlock DockPanel.Dock="Left" Text="{Binding CountLabel}" Style="{StaticResource CodeChip}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                            <Border/>
                                                        </DockPanel>
                                                        <!-- the worker's ordered tasks -->
                                                        <ItemsControl ItemsSource="{Binding Tasks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="5" Padding="9,5" Margin="0,0,0,4">
                                                                        <DockPanel>
                                                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                                <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                                <Button Style="{StaticResource MenuButton}" Width="24" ToolTip="{StaticResource L.MoveUp}"
                                                                                        Command="{Binding DataContext.MoveTaskUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                                    <controls:IconView Icon="{StaticResource IconChevUp}" Width="10" Height="10"/>
                                                                                </Button>
                                                                                <Button Style="{StaticResource MenuButton}" Width="24" Margin="2,0,0,0" ToolTip="{StaticResource L.MoveDown}"
                                                                                        Command="{Binding DataContext.MoveTaskDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                                    <controls:IconView Icon="{StaticResource IconChevDown}" Width="10" Height="10"/>
                                                                                </Button>
                                                                                <Button Style="{StaticResource ChipButton}" Margin="4,0,0,0" Content="{StaticResource L.RunTask}"
                                                                                        Command="{Binding DataContext.RunTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                                                                <Button Style="{StaticResource MenuButton}" Width="24" Margin="4,0,0,0" ToolTip="{StaticResource L.Unassign}"
                                                                                        Command="{Binding DataContext.UnassignTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                                    <controls:IconView Icon="{StaticResource IconChevUp}" Width="10" Height="10"/>
                                                                                </Button>
                                                                                <Button Style="{StaticResource MenuButton}" Width="24" Margin="2,0,0,0" ToolTip="{StaticResource L.Remove}"
                                                                                        Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                                                    <controls:IconView Icon="{StaticResource IconX}" Width="10" Height="10"/>
                                                                                </Button>
                                                                            </StackPanel>
                                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Txt0}" FontSize="11.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <!-- finished-task history (hidden by default; toggle to review) -->
                                                        <Button Style="{StaticResource MenuButton}" HorizontalAlignment="Left" Margin="0,3,0,0" Padding="7,3"
                                                                Visibility="{Binding HasFinished, Converter={StaticResource BoolVis}}"
                                                                Command="{Binding DataContext.ToggleQueueHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                            <TextBlock FontSize="10" Foreground="{DynamicResource Txt3}"><Run Text="{StaticResource L.FinishedHistory}"/><Run Text=" "/><Run Text="{Binding FinishedCount, Mode=OneWay}"/></TextBlock>
                                                        </Button>
                                                        <ItemsControl ItemsSource="{Binding FinishedTasks}" Margin="0,3,0,0"
                                                                      Visibility="{Binding ShowHistory, Converter={StaticResource BoolVis}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{DynamicResource Bg1}" BorderBrush="{DynamicResource LineSoft}" BorderThickness="1" CornerRadius="5" Padding="9,4" Margin="0,0,0,3" Opacity="0.72">
                                                                        <DockPanel>
                                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                            <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconCheck}" Width="10" Height="10" Foreground="{DynamicResource Txt3}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Txt2}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- worker picker popup (opened by 할당) -->
                                    <Popup IsOpen="{Binding ShowAssignPicker, Mode=TwoWay}" StaysOpen="False" Placement="Mouse" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border x:Name="AssignPickerRoot" Background="{DynamicResource Bg3}" BorderBrush="{DynamicResource LineBright}" BorderThickness="1" CornerRadius="7" Padding="5" MinWidth="170" Margin="6">
                                            <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.45" Color="#000000"/></Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.AssignToWorker}" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="6,3,6,5"/>
                                                <ItemsControl ItemsSource="{Binding WorkerPool}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource MenuButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,5" Margin="0,1"
                                                                    Command="{Binding DataContext.AssignToWorkerCommand, ElementName=AssignPickerRoot}" CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border Background="{DynamicResource AccentDim}" CornerRadius="3" Padding="4,0" Margin="0,0,7,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding AgentId}" FontFamily="{StaticResource Mono}" FontSize="8.5" Foreground="{DynamicResource Accent}"/>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Txt0}" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <Border Height="1" Background="{DynamicResource LineSoft}" Margin="4,5"/>
                                                <TextBlock Text="{StaticResource L.AddNewWorker}" FontSize="10" Foreground="{DynamicResource Txt3}" Margin="6,1,6,4"/>
                                                <UniformGrid Columns="4">
                                                    <Button Style="{StaticResource MenuButton}" Content="CC" Margin="2" FontFamily="{StaticResource Mono}" FontSize="10"
                                                            Command="{Binding DataContext.AssignToNewWorkerCommand, ElementName=AssignPickerRoot}" CommandParameter="cc"/>
                                                    <Button Style="{StaticResource MenuButton}" Content="GX" Margin="2" FontFamily="{StaticResource Mono}" FontSize="10"
                                                            Command="{Binding DataContext.AssignToNewWorkerCommand, ElementName=AssignPickerRoot}" CommandParameter="gx"/>
                                                    <Button Style="{StaticResource MenuButton}" Content="AGY" Margin="2" FontFamily="{StaticResource Mono}" FontSize="10"
                                                            Command="{Binding DataContext.AssignToNewWorkerCommand, ElementName=AssignPickerRoot}" CommandParameter="agy"/>
                                                    <Button Style="{StaticResource MenuButton}" Content="PI" Margin="2" FontFamily="{StaticResource Mono}" FontSize="10"
                                                            Command="{Binding DataContext.AssignToNewWorkerCommand, ElementName=AssignPickerRoot}" CommandParameter="pi"/>
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </StackPanel>

                                <!-- Live workers -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.LiveWorkers}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ActiveSessions.Count}" Style="{StaticResource CodeChip}"/>
                                    <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyLive}" FontSize="11" Foreground="{DynamicResource Txt3}" Margin="2,0,0,12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ActiveSessions}" ItemTemplate="{StaticResource OrchCardTemplate}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- Recent &amp; completed -->
                                <DockPanel Margin="0,8,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.RecentCompleted}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ProjectSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{DynamicResource Txt2}" VerticalAlignment="Center"/>
                                    <Border Height="1" Background="{DynamicResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyRecent}" FontSize="11" Foreground="{DynamicResource Txt3}" Margin="2,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProjectSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ProjectSessions}" ItemTemplate="{StaticResource OrchCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
    </Grid>
</UserControl>
