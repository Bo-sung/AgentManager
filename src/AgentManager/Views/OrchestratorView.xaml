<UserControl x:Class="AgentManager.Views.OrchestratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AgentManager.Controls"
             xmlns:vm="clr-namespace:AgentManager.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Name="ViewRoot"
             Background="{StaticResource Bg0}">
    <Grid>
                    <Grid.Resources>
                        <!-- Spark Animation (5 staggered bars equalizer style scale) -->
                        <Storyboard x:Key="SparkStoryboard">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar1" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar2" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.13">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar3" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.26">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar4" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.39">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Bar5" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" RepeatBehavior="Forever" Duration="0:0:1.1" BeginTime="0:0:0.52">
                                <EasingDoubleKeyFrame KeyTime="0%" Value="0.22"/>
                                <EasingDoubleKeyFrame KeyTime="50%" Value="1.0">
                                    <EasingDoubleKeyFrame.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </EasingDoubleKeyFrame.EasingFunction>
                                </EasingDoubleKeyFrame>
                                <EasingDoubleKeyFrame KeyTime="100%" Value="0.22"/>
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>

                        <!-- shared orchestrator session card (live + recent) -->
                        <DataTemplate x:Key="OrchCardTemplate">
                            <Border Width="236" Margin="0,0,12,12" Background="{StaticResource Bg2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1.0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLive}" Value="False">
                                                <Setter Property="Opacity" Value="0.72"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel LastChildFill="True">
                                    <!-- Head -->
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Border DockPanel.Dock="Left" Width="24" Height="24" CornerRadius="4" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBright}" BorderThickness="1" Margin="0,0,8,0">
                                            <controls:IconView Style="{StaticResource EngineIcon}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Margin="0,0,5,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Txt3}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="running"><Setter Property="Foreground" Value="{StaticResource Accent}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="waiting"><Setter Property="Foreground" Value="{StaticResource Warn}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="done"><Setter Property="Foreground" Value="{StaticResource Ok}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error"><Setter Property="Foreground" Value="{StaticResource Err}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <controls:StatusDot Status="{Binding Status}" VerticalAlignment="Center" Margin="-5,0"/>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AgentName}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt0}"/>
                                            <TextBlock Text="{Binding Model}" FontSize="9" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Foot -->
                                    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                            <controls:IconView Icon="{StaticResource IconBolt}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TokensLabel}" FontFamily="{StaticResource Mono}" FontSize="9" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4"
                                                Command="{Binding DataContext.SelectSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{StaticResource L.OpenSessionBtn}" FontSize="10" VerticalAlignment="Center"/>
                                                <controls:IconView Icon="{StaticResource IconChevRight}" Width="11" Height="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource ChipButton}" Padding="9,4" Margin="0,0,6,0" Command="{Binding DataContext.OpenSessionReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <controls:IconView Icon="{StaticResource IconLayers}" Width="10" Height="10" Foreground="{StaticResource Txt1}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{StaticResource L.OrchDiff}" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DockPanel>

                                    <!-- Body -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <controls:IconView Icon="{StaticResource IconBranch}" Width="10" Height="10" Foreground="{StaticResource Txt2}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BranchTail}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RunningElapsedLabel}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Accent}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="9" Margin="0,0,8,0">
                                                <Border x:Name="Bar1" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar2" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar3" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar4" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1" Margin="0,0,1,0">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                                <Border x:Name="Bar5" Width="2" Height="9" Background="{StaticResource Accent}" CornerRadius="1" Opacity="0.55" RenderTransformOrigin="0.5,1">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleY="0.22"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Activity}" FontFamily="{StaticResource Mono}" FontSize="9.5" Foreground="{StaticResource Accent}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,6">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasDiff}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Border Height="5" CornerRadius="2.5" Background="{StaticResource Bg4}" Margin="0,6,0,4" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding DiffAddedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemovedStar}"/>
                                                        <ColumnDefinition Width="{Binding DiffRemainderStar}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource Add}"/>
                                                    <Border Grid.Column="1" Background="{StaticResource Del}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock FontFamily="{StaticResource Mono}" FontSize="10">
                                                <Run Text="+" Foreground="{StaticResource Add}"/><Run Text="{Binding DiffAdded, Mode=OneWay}" Foreground="{StaticResource Add}"/>
                                                <Run Text=" "/>
                                                <Run Text="−" Foreground="{StaticResource Del}"/><Run Text="{Binding DiffRemoved, Mode=OneWay}" Foreground="{StaticResource Del}"/>
                                                <Run Text=" · " Foreground="{StaticResource Txt2}"/>
                                                <Run Text="{Binding DiffFiles, Mode=OneWay}" Foreground="{StaticResource Txt2}"/>
                                                <Run Text=" " Foreground="{StaticResource Txt2}"/>
                                                <Run Text="{Binding FilesSuffix, Mode=OneWay}" Foreground="{StaticResource Txt2}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- 실행 중 이퀄라이저: Style이 아닌 DataTemplate.Triggers에서 시작해야 TargetName(Bar*) 해석 가능 -->
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="SparkAnimation" Storyboard="{StaticResource SparkStoryboard}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SparkAnimation"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </Grid.Resources>
                    <DockPanel LastChildFill="True">
                        <!-- Head -->
                        <Border DockPanel.Dock="Top" Height="44" BorderBrush="{StaticResource LineSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                            <DockPanel LastChildFill="False">
                                <controls:IconView DockPanel.Dock="Left" Icon="{StaticResource IconGrid}" Width="16" Height="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.Orchestrator}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource Txt0}" VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Left" FontSize="11" Foreground="{StaticResource Txt2}" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <Run Text="· "/><Run Text="{StaticResource L.OrchSubtitle}"/></TextBlock>
                                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Command="{Binding NewAgentCommand}" VerticalAlignment="Center" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconView Icon="{StaticResource IconPlus}" Width="11" Height="11" Foreground="{StaticResource AccentText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{StaticResource L.NewAgent}" Foreground="{StaticResource AccentText}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>

                        <!-- Scrollable view -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16" HorizontalAlignment="Stretch">
                                <!-- KPIs -->
                                <UniformGrid Columns="5" Rows="1" Height="78" Margin="0,0,0,22">
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiActive}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding RunningCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiActiveSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiAwaiting}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Warn}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding WaitingCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiAwaitingSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiCompleted}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Ok}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding DoneCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiCompletedSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource LineSoft}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFailed}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Err}" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding FailedCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Txt0}"/>
                                                <TextBlock Text="{StaticResource L.KpiFailedSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource Bg2}" BorderBrush="{StaticResource AccentLine}" BorderThickness="1" CornerRadius="6" Padding="12,9">
                                        <Grid>
                                            <Control Style="{StaticResource HudTicks}"/>
                                            <StackPanel>
                                                <TextBlock Text="{StaticResource L.KpiFleet}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource Txt1}" Margin="0,0,0,3" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FleetThroughputLabel}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                                                <TextBlock Text="{StaticResource L.KpiFleetSub}" FontSize="9" Foreground="{StaticResource Txt3}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- Live workers -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.LiveWorkers}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ActiveSessions.Count}" Style="{StaticResource CodeChip}"/>
                                    <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyLive}" FontSize="11" Foreground="{StaticResource Txt3}" Margin="2,0,0,12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ActiveSessions}" ItemTemplate="{StaticResource OrchCardTemplate}" Margin="0,0,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- Recent &amp; completed -->
                                <DockPanel Margin="0,8,0,8">
                                    <TextBlock DockPanel.Dock="Left" Text="{StaticResource L.RecentCompleted}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Txt2}"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ProjectSessions.Count}" FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Txt2}" VerticalAlignment="Center"/>
                                    <Border Height="1" Background="{StaticResource LineSoft}" VerticalAlignment="Center" Margin="10,0"/>
                                </DockPanel>
                                <TextBlock Text="{StaticResource L.OrchEmptyRecent}" FontSize="11" Foreground="{StaticResource Txt3}" Margin="2,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProjectSessions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding ProjectSessions}" ItemTemplate="{StaticResource OrchCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
    </Grid>
</UserControl>
